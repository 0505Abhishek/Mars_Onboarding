<script>
    document.addEventListener("DOMContentLoaded", function () {
    let distributors = <%- JSON.stringify(distributors) %>;

    try {
            if (typeof distributors.documents === "string" && distributors.documents.trim() !== "") {
                distributors.documents = JSON.parse(distributors.documents);
            } else {
                distributors.documents = [];
            }
        } catch (error) {
            console.error("Error parsing documents:", error);
            distributors.documents = [];
        }

    // Hide all rows initially
    document.querySelectorAll("#documentTable tbody tr").forEach(row => {
        row.style.display = "none";
    });


    distributors.documents.forEach(doc => {
        if(doc.status=='cross')
       {
        const fileInput = document.querySelector(`input[name="${doc.doc_key}"]`);
        if (fileInput) {
            const row = fileInput.closest("tr");
            row.style.display = "table-row"; 

            const remarksInput = row.querySelector("input[type='text']");
            if (remarksInput) {
                remarksInput.value = doc.remarks;
            }
        }
      }
    });

    document.getElementById("documentForm").addEventListener("submit", function (event) {
        let allFilesUploaded = true;
        let missingDocs = [];

        document.querySelectorAll("#documentTable tbody tr").forEach(row => {
            if (row.style.display !== "none") { // Validate only visible rows
                const fileInput = row.querySelector("input[type='file']");
                if (fileInput && fileInput.files.length === 0) {
                    allFilesUploaded = false;
                    const docName = row.querySelector("td:nth-child(2)").textContent;
                    missingDocs.push(docName);
                }
            }
        });

        if (!allFilesUploaded) {
            event.preventDefault(); 

            Swal.fire({
                icon: "error",
                title: "Missing Documents!",
                text: "Please upload all required documents: \n" + missingDocs.join(", "),
                confirmButtonText: "OK",
            });
        }else 
        {
            submitBtn.disabled = true;
            submitBtn.textContent = "Submitting...";
        }
     });
  });

</script>
    
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const fileInputs = document.querySelectorAll('input[type="file"]');
        fileInputs.forEach(input => {
        input.addEventListener('change', function () {
            if (this.files.length > 0) {
            const label = this.closest('.file-upload');
            label.classList.add('uploaded');
            }
        });
        });
    });
    </script>


