<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<style>
    .modal-backdrop {
        display: none !important;
    }

  .modal-body {
        max-height: 440px;
        overflow-y: auto;
    }
    .modal-dialog{
        width:75%;
    }

     table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            border: 1px solid #ccc;
            padding: 10px;
            text-align: center;
        }
        input[type="file"] {
            display: none;
        }
        td input[type="text"] {
            width: 100%;
        }
        .upload-icon {
            cursor: pointer;
            font-size: 20px;
        }
        .view-icon {
            cursor: pointer;
            font-size: 20px;
            display: none;
        }

</style>
<style>
    .file-upload {
      display: inline-block;
      background: #007bff; /* blue */
      color: white;
      padding: 6px 12px;
      border-radius: 5px;
      cursor: pointer;
      font-size: 14px;
    }

    .file-upload:hover {
      background: #0056b3;
    }

    .file-upload i {
      margin-right: 5px;
    }

    /* Green style after file is uploaded */
    .file-upload.uploaded {
      background: #28a745 !important; /* Bootstrap green */
    }

    input[type="file"] {
      display: none;
    }
  </style>
  <style>

    .table-dark th {
        color: #0000A0 !important; 
        background-color: #E0E0FC;
        border: 1px solid rgb(224, 203, 203);
    }

    #distributorTable tbody tr:nth-child(odd) td {
        background: #FFFFFF !important; 
    }

    #distributorTable tbody tr:nth-child(even) td {
        background: #EFEFFF !important; 
    }
</style>



<div class="container mt-4">

    <form id="documentForm" action="/lead_status/correction/<%= application_id %>" method="POST" enctype="multipart/form-data">
        <div class="table-responsive">
          <table id="documentTable" class="table">
            <thead>
              <tr>
                <th>S. No.</th>
                <th>Document Name</th>
                <th>Upload</th>
                <th>View</th>
                <th>Remarks</th>
              </tr>
            </thead>
            <tbody>
              <% const docFields = [
                { label: "CRF Form", name: "crf_form", remarks: "remarks_crf", original: originalFileName?.crf_form_original },
                { label: "GST Certificate", name: "gst_certificate", remarks: "remarks_gst", original: originalFileName?.gst_certificate_original },
                { label: "FSSAI Certificate", name: "fssai_certificate", remarks: "remarks_fssai",  original: originalFileName?.fssai_certificate_original },
                { label: "PAN Card", name: "pan_card", remarks: "remarks_pan",  original: originalFileName?.pan_card_original },
                { label: "Cancelled Cheque", name: "cancelled_cheque", remarks: "remarks_cheque",  original: originalFileName?.cancelled_cheque_original },
                { label: "DB Agreement", name: "db_agreement", remarks: "remarks_db",  original: originalFileName?.db_agreement_original },
                { label: "Godown Insurance", name: "godown_insurance", remarks: "remarks_insurance", original: originalFileName?.godown_insurance_original },
                <!-- { label: "RSM Email Approval", name: "rsm_email_approval", remarks: "remarks_rsm", original: originalFileName?.rsm_email_approval_original }, -->
                { label: "If GST & FSSAI address mis-match,<br>then FSSAI amendment application copy", name: "fssai_amendment_copy", remarks: "remarks_fssai_amendment_copy",  original: originalFileName?.fssai_amendment_copy_original },
                { label: "Freight Sheet", name: "freight_sheet", remarks: "remarks_freight_sheet", original: originalFileName?.freight_sheet_original },
                { label: "Bank Statement", name: "bank_statement", remarks: "remarks_bank_statement",  original: originalFileName?.bank_statement_original },
                { label: "RSM Document", name: "rsm_document", remarks: "remarks_rsm_document", original: originalFileName?.rsm_document },
                { label: "Resignation of replaced DB", name: "Resignation_DB", remarks: "remarks_Resignation_DB", original: originalFileName?.Resignation_DB },
                { label: "NOC Document", name: "noc_document", remarks: "remarks_noc_document", original: originalFileName?.noc_document },

                 // New custom-named documents
                { label: uploadDocumentData[0]?.other_doc_1_name || "Other Document 1", name: "other_doc_1_file", original: originalFileName?.other_doc_1_original },
                { label: uploadDocumentData[0]?.other_doc_2_name || "Other Document 2", name: "other_doc_2_file", original: originalFileName?.other_doc_2_original },
                { label: uploadDocumentData[0]?.other_doc_3_name || "Other Document 3", name: "other_doc_3_file", original: originalFileName?.other_doc_3_original }
              ]; %>
      
              <% docFields.forEach((doc, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><%- doc.label %></td>
                  <td>
                    <label class="file-upload">
                      <input type="file" name="<%= doc.name %>" data-view="<%= doc.view %>" hidden>
                      <i class="fa fa-upload"></i>
                    </label>
                  </td>
                  <td>
                    <% if (doc.original) { %>
                      <small class="text-muted"><%= doc.original %></small>
                    <% } else { %>
                      <span id="<%= doc.view %>" class="view-icon" style="display: none;">👁</span>
                    <% } %>
                  </td>
                  <td><input type="text" name="<%= doc.remarks %>" placeholder="Enter remarks" readonly></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="mt-3 d-flex justify-content-center">
          <button type="submit" id="submitBtn" class="btn btn-primary btn-sm py-2" style="width: 30%; font-size: 17px;">
            Submit
          </button>
        </div>



      </form>
      
</div>




<div class="modal" id="fileModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Modal title</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body text-center">
            <div id="filePreview"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
    const fileInputs = document.querySelectorAll(".file-upload input[type='file']");
    const viewIcons = document.querySelectorAll(".view-icon");
    const modalElement = document.getElementById("fileModal");
    const modalBody = document.getElementById("filePreview");
    const closeModalBtn = modalElement.querySelector("[data-bs-dismiss='modal']");
    let modalInstance = new bootstrap.Modal(modalElement);

    const allowedTypes = [
    "image/jpeg",
    "image/png",
    "image/jpg",
    "application/pdf",
    "application/vnd.ms-excel", 
    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", 
    "text/csv" 
    ];

    const DEFAULT_MAX_FILE_SIZE_MB = 3;
    const DEFAULT_MAX_FILE_SIZE = DEFAULT_MAX_FILE_SIZE_MB * 1024 * 1024;

    const RESIGNATION_MAX_FILE_SIZE_MB = 15;
    const RESIGNATION_MAX_FILE_SIZE = RESIGNATION_MAX_FILE_SIZE_MB * 1024 * 1024;

    fileInputs.forEach((input) => {
        input.addEventListener("change", function () {
            const file = this.files[0];
            const viewId = this.dataset.view;
            const fileNameId = this.dataset.filename;
            const label = this.closest(".file-upload");

            if (fileNameId) {
                document.getElementById(fileNameId).textContent = 'No file selected';
            }
            if (label) {
                label.classList.remove('uploaded');
            }

            if (file) {
                if (!allowedTypes.includes(file.type)) {
                    alert("❌ Only PDF, DOC, XLS, XLSX, CSV, and image files (JPG, JPEG, PNG) are allowed.");
                    this.value = ""; 
                    return;
                }

                
                let maxSize = (this.name === "db_agreement") 
                    ? RESIGNATION_MAX_FILE_SIZE 
                    : DEFAULT_MAX_FILE_SIZE;

                let maxSizeMB = (this.name === "db_agreement") 
                    ? RESIGNATION_MAX_FILE_SIZE_MB 
                    : DEFAULT_MAX_FILE_SIZE_MB;

                if (file.size > maxSize) {
                    alert(`❌ "${file.name}" exceeds ${maxSizeMB}MB. Please upload a smaller file.`);
                    this.value = "";
                    return;
                }

                // Valid file
                const fileUrl = URL.createObjectURL(file);
                const viewIcon = document.getElementById(viewId);

                // Show filename only for valid files
                if (fileNameId) {
                    document.getElementById(fileNameId).textContent = file.name;
                }

                if (label) {
                    label.classList.add('uploaded');
                }

                if (viewIcon) {
                    viewIcon.dataset.file = fileUrl;
                    viewIcon.dataset.type = file.type;
                    viewIcon.style.display = "inline";
                }
            }

        });
    });

    viewIcons.forEach((icon) => {
        icon.addEventListener("click", function () {
            const fileUrl = this.dataset.file;
            const fileType = this.dataset.type;

            if (fileUrl && fileType) {
                if (fileType.startsWith("image")) {
                    modalBody.innerHTML = `<img src="${fileUrl}" style="width: 80%; height: auto;">`;
                } else if (fileType === "application/pdf") {
                    modalBody.innerHTML = `<embed src="${fileUrl}" type="application/pdf" width="80%" height="500px" />`;
                } else if (
                    fileType === "application/vnd.ms-excel" ||
                    fileType === "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" ||
                    fileType === "text/csv"
                ) {
                    modalBody.innerHTML = `<p>✅ File "${fileUrl.split('/').pop()}" is selected (Excel/CSV file)</p>`;
                } else {
                    modalBody.innerHTML = `<p>❌ Unsupported file type</p>`;
                }

                modalInstance.show();
            }
        });
    });

    closeModalBtn.addEventListener("click", function () {
        modalInstance.hide();
    });

    // SweetAlert
    <% if (notification) { %>
        Swal.fire({
            icon: '<%= notification.type %>',
            title: '<%= notification.message %>',
            showConfirmButton: false,
            timer: 2000
        });
    <% } %>
});

</script>


