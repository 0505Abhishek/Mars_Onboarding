<%- include("../shared/super_header.ejs") %>

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">User Transfer</h4>
                        
                        <form id="userTransferForm" action="/user_management/user-transfer/transfer" method="POST">
                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <label>To User</label>
                                   <select name="to_user_id" class="select2-dropdown" required>
                                       <option value="">Select User</option>
                                       <% transferableUsers.forEach(function(user) { %>
                                           <option value="<%= user.id %>" 
                                               data-email="<%= user.email_id %>" 
                                               data-territory="<%= user.territory %>"
                                               data-region="<%= user.region %>"
                                               data-channel="<%= user.channel %>">
                                               <%= user.employee_name %> - (<%= user.email_id %>) - (<%= user.territory %> )
                                           </option>
                                       <% }); %>
                                   </select>
                                </div>
                                <div class="col-md-12 form-group">
                                    <label>From User</label>
                                    <select name="from_user_id" class="select2-dropdown" required>
                                        <option value="">Select User</option>
                                        <% transferableUsers.forEach(function(user) { %>
                                            <option value="<%= user.id %>" 
                                                data-email="<%= user.email_id %>" 
                                                data-territory="<%= user.territory %>"
                                                data-region="<%= user.region %>"
                                                data-channel="<%= user.channel %>">
                                                <%= user.employee_name %> - (<%= user.email_id %>) - (<%= user.territory %> )
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary">Transfer User</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<%- include("../shared/super_footer.ejs") %>

<!-- Ensure jQuery is loaded -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
(function($) {
    function initSelect2() {
        if ($ && $.fn.select2) {

            $('.select2-dropdown').select2({
                placeholder: 'Select User',
                allowClear: true,
                templateResult: formatUser,
                templateSelection: formatUserSelection,
                matcher: customMatcher
            });

            function formatUser(user) {
                if (!user.id) { return user.text; }
                
                var $user = $(
                    `<div class="user-select-option">
                        <strong>${$(user.element).text().split('-')[0].trim()}</strong><br>
                        <small>Email: ${$(user.element).data('email')}</small><br>
                        <small>Territory: ${$(user.element).data('territory')}</small><br>
                        <small>Region: ${$(user.element).data('region')}</small>
                    </div>`
                );
                return $user;
            }

            function formatUserSelection(user) {
                if (!user.id) { return user.text; }
                return $(user.element).text().split('-')[0].trim();
            }

            function customMatcher(params, data) {
                if ($.trim(params.term) === '') {
                    return data;
                }
                var searchTerm = params.term.toLowerCase();
                var $element = $(data.element);
                var email = $element.data('email') || '';
                var territory = $element.data('territory') || '';
                var region = $element.data('region') || '';
                var name = $element.text() || '';
                if (
                    name.toLowerCase().indexOf(searchTerm) > -1 ||
                    email.toLowerCase().indexOf(searchTerm) > -1 ||
                    territory.toLowerCase().indexOf(searchTerm) > -1 ||
                    region.toLowerCase().indexOf(searchTerm) > -1
                ) {
                    return data;
                }
                return null;
            }

            $('#userTransferForm select[name="to_user_id"], #userTransferForm select[name="from_user_id"]').on('change', function() {
                var toUser = $('select[name="to_user_id"]').val();
                var fromUser = $('select[name="from_user_id"]').val();

                if (toUser && fromUser && toUser === fromUser) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid Selection',
                        text: 'You cannot transfer from and to the same user!'
                    });
                    $(this).val('').trigger('change');
                }
            });
        } else {
            console.error('jQuery or Select2 is not loaded');
            setTimeout(initSelect2, 100);
        }
    }
    initSelect2();
})(jQuery);
</script>

<style>
.select2-container .select2-selection--single {
    height: 38px;
    padding: 5px;
}
.select2-container--default .select2-selection--single .select2-selection__rendered {
    line-height: 28px;
}
.user-select-option {
    line-height: 1.5;
    padding: 5px;
}
.user-select-option small {
    color: #6c757d;
}
.select2-container {
    box-sizing: border-box;
    display: inline-block;
    margin: 0;
    position: relative;
    vertical-align: middle;
    width: 896.333px !important;
}
</style>