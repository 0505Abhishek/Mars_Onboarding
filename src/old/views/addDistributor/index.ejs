<script>
    async function fetchTerritories(regionId) {
        const territorySelect = document.getElementById('territory');
        territorySelect.innerHTML = '<option selected disabled>Loading...</option>';

        try {
            const response = await fetch('/Add_distributor/get-territory', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ regionId })
            });

            const data = await response.json();
            territorySelect.innerHTML = '<option value="" selected disabled>Select Territory</option>';

            if (data.length === 0) {
                territorySelect.innerHTML += '<option value="">No territories found</option>';
            } else {
                data.forEach(territory => {
                    const option = document.createElement('option');
                    option.value = territory.territory_id;
                    option.textContent = territory.territory_name;
                    territorySelect.appendChild(option);
                });

                if (data.length === 1) {
                    territorySelect.value = data[0].territory_id;
                    fetchSoTerritories(data[0].territory_id, regionId); 
                }
            }
        } catch (error) {
            console.error('Error fetching territories:', error);
            territorySelect.innerHTML = '<option value="" selected disabled>Error loading data</option>';
        }
    }

    async function fetchSoTerritories(territoryId, regionId) {
        const soTerrSelect = document.getElementById('SO_Terr');
        const soNameInput = document.getElementById('SO_Name');
        soTerrSelect.innerHTML = '<option selected disabled>Loading...</option>';

        try {
            const response = await fetch('/Add_distributor/get-so-territory', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ territoryId, regionId }) 
            });

            const data = await response.json();
            soTerrSelect.innerHTML = '<option value="" selected disabled>Select SO Territory</option>';

            if (!data || data.length === 0) {
                soTerrSelect.innerHTML += '<option value="">No SO territories found</option>';
            } else {
            data.forEach(so => {
                const option = document.createElement('option');
                option.value = so.so_territories_id;  
                option.textContent = so.so_territory_name;
                option.dataset.soName = so.so_name;
                soTerrSelect.appendChild(option);
            });

            if (data.length === 1) {
                soTerrSelect.value = data[0].so_territories_id;
                soNameInput.value = data[0].so_name; 
            }
        }
        } catch (error) {
            console.error('Error fetching SO territories:', error);
            soTerrSelect.innerHTML = '<option value="" selected disabled>Error loading data</option>';
        }
    }


    document.addEventListener('DOMContentLoaded', function () {
        const regionSelect = document.getElementById('region_id');
        const territorySelect = document.getElementById('territory');

        const soTerrSelect = document.getElementById('SO_Terr');
        const soNameInput = document.getElementById('SO_Name');

        soTerrSelect.addEventListener('change', function () {
            const selectedOption = this.options[this.selectedIndex];
            if (selectedOption && selectedOption.dataset.soName) {
                soNameInput.value = selectedOption.dataset.soName;
            } else {
                soNameInput.value = '';
            }
        });

        regionSelect.addEventListener('change', function () {
            const region = this.value;
            if (region) fetchTerritories(region);
        });

        territorySelect.addEventListener('change', function () {
            const territoryId = this.value;
            const regionId = document.getElementById('region_id').value; 
            if (territoryId && regionId) {
                fetchSoTerritories(territoryId, regionId);
            }
        });


        if (regionSelect.value) {
            fetchTerritories(regionSelect.value);
        }
    });
                
</script>



<script>
document.addEventListener("DOMContentLoaded", async () => {
    const cityInput = document.getElementById("cityInput");
    const dropdown = document.getElementById("cityDropdown");
    const cityError = document.getElementById("cityError");
    const form = cityInput.closest("form");
    let cities = [];

    try {
        const res = await fetch("https://countriesnow.space/api/v0.1/countries");
        const data = await res.json();
        
        const india = data.data.find(c => c.country === "India");
        if (india && india.cities) {
            cities = india.cities
                .map(c => c.trim())
                .sort((a, b) => a.localeCompare(b));
        }
    } catch (err) {
        console.error("Error loading cities:", err);
    }

    // Input event for filtering dropdown
    cityInput.addEventListener("input", () => {
        const query = cityInput.value.toLowerCase().trim();
        dropdown.innerHTML = "";
        if (!query) {
            dropdown.classList.remove("show");
            return;
        }

        const filtered = cities.filter(city => city.toLowerCase().includes(query)).slice(0, 10);
        filtered.forEach(city => {
            const item = document.createElement("div");
            item.classList.add("dropdown-item");
            item.style.cursor = "pointer";
            item.textContent = city;
            item.onmousedown = () => {  // Use mousedown instead of click
                cityInput.value = city;
                dropdown.innerHTML = "";
                dropdown.classList.remove("show");
                cityError.textContent = "";
            };
            dropdown.appendChild(item);
        });

        dropdown.classList.add("show");
    });

    // Validate on blur
    cityInput.addEventListener("blur", () => {
        setTimeout(() => {  // Delay to allow mousedown to fire first
            const inputVal = cityInput.value.trim().toLowerCase();
            const isValid = cities.some(city => city.toLowerCase() === inputVal);
            if (!isValid) {
                cityInput.value = "";
                cityError.textContent = "Please select a valid city from the list.";
                dropdown.classList.remove("show");
            } else {
                cityError.textContent = "";
            }
        }, 100);
    });

    // Prevent form submission if invalid city
    if (form) {
        form.addEventListener("submit", (e) => {
            const inputVal = cityInput.value.trim().toLowerCase();
            const isValid = cities.some(city => city.toLowerCase() === inputVal);
            if (!isValid) {
                e.preventDefault();
                cityError.textContent = "Please select a valid city from the list.";
                cityInput.focus();
            }
        });
    }

    // Hide dropdown when clicking outside input or dropdown
    document.addEventListener("click", (e) => {
        if (!e.target.closest("#cityInput") && !e.target.closest("#cityDropdown")) {
            dropdown.classList.remove("show");
        }
    });
});
</script>


<script>
  const freightInput = document.getElementById("FreightExpenses");
  const freightError = document.getElementById("FreightExpensesError");

  freightInput.addEventListener("keypress", function (e) {
    const char = String.fromCharCode(e.which);

    if (!/[0-9.]/.test(char)) {
      e.preventDefault();
      return;
    }

    const currentValue = freightInput.value;
    
    if (char === '.' && currentValue.includes('.')) {
      e.preventDefault();
      return;
    }

    if (currentValue.includes('.')) {
      const [intPart, decimalPart] = currentValue.split('.');
      if (decimalPart.length >= 2 && freightInput.selectionStart > currentValue.indexOf('.')) {
        e.preventDefault();
        return;
      }
    }
    if (currentValue.length >= 20) {
      e.preventDefault();
      return;
    }
  });

  freightInput.addEventListener("input", function () {
    const value = freightInput.value.trim();

    if (value.length > 20) {
      freightError.textContent = "Total number should not exceed 20 characters.";
      return;
    }

    const validFormat = /^\d{1,18}(\.\d{0,2})?$/;

    if (value && !validFormat.test(value)) {
      freightError.textContent = "Enter a valid number with up to 2 decimal places.";
    } else {
      freightError.textContent = "";
    }
  });
</script>

