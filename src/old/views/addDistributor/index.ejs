<%- include("../shared/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<style>
    .button-container {
        display: flex;
        justify-content: center; /* Center the buttons */
        gap: 20px; /* Spacing between buttons */
        margin-top: 20px;
        margin-bottom: 10px;
    }

    .custom-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px; /* Space between icon and text */
        width: 224px;
        height: 49px;
        background: #FFFFFF;
        border: 1px solid #0000A0;
        font-size: 16px;
        font-weight: bold;
        color: #0000A0;
        cursor: pointer;
        transition: all 0.3s ease;
        border-radius: 12px;
    }


</style>

<style>
    .hidden { display: none; }
</style>
<style>
    .scroll-section {
      max-height: 500px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
  </style>

    <style>
    .dropdown-menu.show {
        display: block;
        max-height: 200px;
        overflow-y: auto;
    }
    </style>

   
<div class="container mt-2">

    <div class="d-flex justify-content-between align-items-center">
        <h4 style="color: #41378d;">Basic Information</h4>
        <!-- <a href="/distributor_draft_list" class="btn btn-primary">Draft List</a> -->
        <div class="button-container">
            <a href="/distributor_draft_list"  style="text-decoration: none; color: inherit;">
                <button class="custom-btn">
                    <i class="fa-solid fa-clock-rotate-left"></i> Invite History
                </button>
            </a>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <form id="multiStepForm" method="post" action="/Add_distributor">
                
                <!-- Step 1: Add Distributor -->
                <div class="step" id="step1">
                
                    <!-- Application Type -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Application Type</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="new" value="New" required>
                                <label class="form-check-label" for="new">New</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="replacement" value="Replacement" required>
                                <label class="form-check-label" for="replacement">Replacement</label>
                            </div>
                              
                        </div>
                        <div class="text-danger error-message" id="applicationTypeError"></div>
                    </div>

                    <div class="mb-3" id="replacement-options-container" style="display: none;">
                        <label for="replacementOption" class="form-label fw-bold">Choose Replacement Option</label>
                        <select id="replacementOption" name="replacedFirmName" class="form-select">
                            <option value="">-- Select --</option>
                            <% replacementOptions?.forEach(function(option) { %>
                                <option value="<%= option?.id %>">
                                    <%= option?.firmName %> (<%= option?.distributor_code || option?.cdCode %>)
                                </option>
                            <% }) %>
                        </select>
                        <div class="text-danger error-message" id="replacementOptionError"></div>
                    </div>
                
                    <!-- DB Channel -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="dbType" class="form-label fw-bold">DB Channel</label>
                            <select class="form-select" id="dbType" name="dbType" required>
                                <option value="" selected disabled>Select DB Channel</option>
                                <option value="Hub">Hub</option>
                                <option value="TT">TT</option>
                                <option value="MT">MT</option>
                                <option value="OOH">OOH</option>
                                <option value="DCOM">DCOM</option>
                                <option value="Railway">Railway</option>
                            </select>
                            <div class="text-danger error-message" id="dbTypeError"></div>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="region" class="form-label fw-bold">Region</label>
                            <select class="form-select" name="region_id" id="region_id" required>
                                <% if (regions.length !== 1) { %>
                                    <option value="" selected disabled>Select Region</option>
                                <% } %>
                        
                                <% regions.forEach(region => { %>
                                    <option 
                                        value="<%= region.id %>" 
                                        <%= regions.length === 1 ? 'selected' : '' %>>
                                        <%= region.region_name %>
                                    </option>
                                <% }) %>
                            </select>
                        
                            <div class="text-danger error-message" id="RegionError"></div>
                        </div>
                        
                    </div>

                    <div class="row"> 
                        <!-- Territory dropdown -->
                        <div class="col-md-6 mb-3">
                            <label for="territory" class="form-label fw-bold">Territory</label>
                            <select class="form-select" id="territory" name="territory_id" required>
                             <option value="" selected disabled>Select Territory</option>
                            </select>
                            <div class="text-danger error-message" id="TerritoryError"></div>
                        </div>

                        <div class="col-md-6 mb-3 position-relative">
                            <label for="cityInput" class="form-label fw-bold">City</label>
                            <input type="text" class="form-control" id="cityInput" name="city" placeholder="Search city..." autocomplete="off" required>
                            <div class="dropdown-menu w-100" id="cityDropdown"></div>
                            <div class="text-danger error-message" id="cityError"></div>
                        </div>
                    
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="SO_Terr" class="form-label fw-bold">SO Territory</label>
                            <select class="form-select" id="SO_Terr" name="SO_Terr" required>
                                <option value="" selected disabled>Select SO Territory</option>
                            </select>
                            <div class="text-danger error-message" id="SO_TerrError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="SO_Name" class="form-label fw-bold">SO Name</label>
                            <input type="text" class="form-control" id="SO_Name" name="SO_Name" placeholder="Enter So's Name" required readonly>
                            <div class="text-danger error-message" id="SO_NameError"></div>
                        </div>
                    </div>
                
                    <!-- Two-Column Form Layout -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="firmName" class="form-label fw-bold">Firm's Name</label>
                            <input type="text" class="form-control" id="firmName" name="firmName" placeholder="Enter Firm's Name" required>
                            <div class="text-danger error-message" id="firmNameError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="distributorName" class="form-label fw-bold">Distributor's Name</label>
                            <input type="text" class="form-control" id="distributorName" name="distributorName" placeholder="Enter Distributor's Name" required>
                            <div class="text-danger error-message" id="distributorNameError"></div>
                        </div>
                    </div>
                
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label fw-bold">Email ID</label>
                            <input type="email" class="form-control" id="email" name="email" placeholder="Enter Email ID" required>
                            <div class="text-danger error-message" id="emailError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="contactNumber" class="form-label fw-bold">Contact Number</label>
                            <input type="text" class="form-control" id="contactNumber" name="contactNumber" placeholder="Enter Contact Number" required maxlength="10">
                            <div class="text-danger error-message" id="contactNumberError"></div>
                        </div>
                    </div>
                
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="experienceDistribution" class="form-label fw-bold">Years of Experience in Distribution Business</label>
                            <input type="number" class="form-control" id="experienceDistribution" name="experienceDistribution" placeholder="Enter years of experience" required>
                            <div class="text-danger error-message" id="experienceDistributionError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="experienceFMCG" class="form-label fw-bold">Years of Experience in FMCG Distribution</label>
                            <input type="number" class="form-control" id="experienceFMCG" name="experienceFMCG" placeholder="Enter years of FMCG experience" required>
                            <div class="text-danger error-message" id="experienceFMCGError"></div>
