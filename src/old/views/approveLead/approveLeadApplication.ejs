<%- include("../shared/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
    .hidden { display: none; }
</style>
<style>
    .scroll-section {
      max-height: 600px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
  </style>
<style>
    .back-link {
        font-size: 18px;
        font-weight: bold;
        text-decoration: none;
        color: #1a1a1a; 
        display: flex;
        align-items: center;
        margin-bottom:20px;
    }

    .back-link i {
        font-size: 20px;
        margin-right: 8px;
    }
</style>


   
<div class="container mt-5">
    <div class="card">
        <div class="card-body">
            <form id="multiStepForm" method="post" action="/edit_distributor?id=<%= distributorData?.id %>">
                
                <div class="step" id="step1">
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="/approve_lead" class="back-link">
                            <i class="fa fa-angle-left"></i> Approve Lead
                        </a>
                    </div>
                
                    <div class="mb-3">
                        <label class="form-label fw-bold">Application Type</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="new" value="New" 
                                    <% if(distributorData?.applicationType === 'New') { %> checked <% } %> disabled>
                                <label class="form-check-label" for="new">New</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="replacement" value="Replacement"
                                    <% if(distributorData?.applicationType === 'Replacement') { %> checked <% } %> disabled>
                                <label class="form-check-label" for="replacement">Replacement</label>
                            </div>
                        </div>                        
                    </div>
                

                    <div class="mb-3" id="replacement-options-container" style="display: none;">
                        <label for="replacementOption" class="form-label fw-bold">Choose Replacement Option</label>
                        <select id="replacementOption" name="replacedFirmName" class="form-select" disabled>
                            <option value="<%= distributorData?.replaced_mars_code ? 'selected' : '' %>"><%= distributorData?.replaced_firmName%> (<%=distributorData?.replaced_distributor_code || distributorData?.cdCode %>)</option>
                        </select>
                        <div class="text-danger error-message" id="replacementOptionError"></div>
                    </div>

                    <div class="row">
                       <div class="col-md-6 mb-3">
                        <label for="dbType" class="form-label fw-bold">DB Channel</label>
                            <select class="form-select" id="dbType" name="dbType" disabled>
                                <option value="" disabled>Select DB Channel</option>
                                <option value="Hub" <% if(distributorData?.dbType === 'Hub') { %> selected <% } %>>Hub</option>
                                <option value="TT" <% if(distributorData?.dbType === 'TT') { %> selected <% } %>>TT</option>
                                <option value="MT" <% if(distributorData?.dbType === 'MT') { %> selected <% } %>>MT</option>
                                <option value="OOH" <% if(distributorData?.dbType === 'OOH') { %> selected <% } %>>OOH</option>
                                <option value="DCOM" <% if(distributorData?.dbType === 'DCOM') { %> selected <% } %>>DCOM</option>
                                <option value="Railway" <% if(distributorData?.dbType === 'Railway') { %> selected <% } %>>Railway</option>
                            </select>
                        </div>
                        <!-- Region -->
                        <div class="col-md-6 mb-3">
                            <label for="region_id" class="form-label fw-bold">Region</label>
                        
                            <div class="form-control bg-light">
                                <%= distributorData?.region_name || "N/A" %>
                            </div>
                        
                            <input type="hidden" name="region_id" value="<%= distributorData?.region_id %>">
                        
                            <div class="text-danger error-message" id="RegionError"></div>
                        </div>
                                              
                    </div>
                
                    
                    <div class="row">
                        <div class="col-md-6 mb-3 position-relative">
                            <label for="territory_id" class="form-label fw-bold">Territory</label>
                            
                            <div class="form-control bg-light">
                                <%= distributorData?.territory_name || "N/A" %>
                            </div>
                            
                            <input type="hidden" name="territory_id" value="<%= distributorData?.territory_id %>">
                        
                            <div class="text-danger error-message" id="TerritoryError"></div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="city" class="form-label fw-bold">City</label>
                            <input type="text" class="form-control" id="city" name="city" placeholder="Enter City Name"
                                   value="<%= distributorData?.city || '' %>" readonly>
                            <div class="text-danger error-message" id="cityError"></div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="SO_Terr" class="form-label fw-bold">SO Territory</label>
                            <input type="text" class="form-control" id="SO_Terr" name="SO_Terr" placeholder="Enter So's Territory" value="<%= distributorData?.so_territory_name %>"  disabled>
                            <div class="text-danger error-message" id="SO_TerrError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="SO_Name" class="form-label fw-bold">SO Name</label>
                            <input type="text" class="form-control" id="SO_Name" name="SO_Name" placeholder="Enter So's Name" value="<%= distributorData.SO_Name %>" disabled>
                            <div class="text-danger error-message" id="SO_NameError"></div>
                        </div>
                    </div>



                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="firmName" class="form-label fw-bold">Firm's Name</label>
                            <input type="text" class="form-control" id="firmName" name="firmName" value="<%= distributorData?.firmName %>" readonly>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="distributorName" class="form-label fw-bold">Distributor's Name</label>
                            <input type="text" class="form-control" id="distributorName" name="distributorName" value="<%= distributorData?.distributorName %>" readonly>
                        </div>
                    </div>
                
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label fw-bold">Email ID</label>
                            <input type="email" class="form-control" id="email" name="email" value="<%= distributorData?.email %>" readonly>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="contactNumber" class="form-label fw-bold">Contact Number</label>
                            <input type="text" class="form-control" id="contactNumber" name="contactNumber" value="<%= distributorData?.contactNumber %>" readonly>
                        </div>
                    </div>
                
                    <div class="row">
                        <!-- Years of Experience in Distribution Business -->
                        <div class="col-md-6 mb-3">
                            <label for="experienceDistribution" class="form-label fw-bold">Years of Experience in Distribution Business</label>
                            <input type="text" class="form-control" id="experienceDistribution" name="experienceDistribution" 
                                value="<%= distributorData.experienceDistribution %>" disabled>
                        </div>
                    
                        <!-- Years of Experience in FMCG Distribution Business -->
                        <div class="col-md-6 mb-3">
                            <label for="experienceFMCG" class="form-label fw-bold">Years of Experience in FMCG Distribution Business</label>
                            <input type="text" class="form-control" id="experienceFMCG" name="experienceFMCG" 
                                value="<%= distributorData.experienceFMCG %>" disabled>
                        </div>
                    </div>
                    
                    
                    <div class="row">
                        <!-- Number of Outlets Covered -->
                        <div class="col-md-6 mb-3">
                            <label for="outletsCovered" class="form-label fw-bold">Number of Outlets Covered</label>
                            <input type="text" class="form-control" id="outletsCovered" name="outletsCovered"
                                value="<%= distributorData.outletsCovered %>" disabled>
                        </div>
                        
                    
                        <!-- Total Monthly Turnover -->
                        <div class="col-md-6 mb-3">
                            <label for="monthlyTurnover" class="form-label fw-bold">Total Monthly Turnover</label>
                            <input type="text" class="form-control" id="monthlyTurnover" name="monthlyTurnover" placeholder="Enter Monthly Turnover" value="<%= distributorData?.monthlyTurnover%>" readonly/>
                            <div class="text-danger error-message" id="monthlyTurnoverError"></div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="FreightExpenses" class="form-label fw-bold">Freight Expenses %</label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="FreightExpenses" 
                                name="FreightExpenses" 
                                placeholder="Enter Freight Expenses %" 
                                value="<%= distributorData.FreightExpenses %>"
                                disabled
                            >
                            <div class="text-danger error-message" id="FreightExpensesError"></div>
                        </div>

                        <div class="col-md-6 mb-3">
                            
                        </div>
                    </div>
                    
                    
                    <div class="d-flex justify-content-end">
                        <button type="button" class="btn btn-primary next" style="width: 125px;">Next</button>
                    </div>
                </div>
                
                
                
                
                <!-- Step 2: Questions -->
                <div class="step hidden" id="step2">
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="#" class="back-link prev"> 
                            <i class="fa fa-angle-left"></i> Approve Lead
                        </a>                                               
                    </div>  
                    <div class="container mt-4">                
                        <!-- Scroll 1: Commercial Structure -->
                        <div class="scroll-section">
                            <h4>Commercial Structure</h4>
                        
                            <div class="mb-3">
                                <label class="form-label" for="stores_covered">How many stores does the DTR cover? (Mars Wrigley stores and non-Mars Wrigley stores)</label>
                                <input type="number" id="stores_covered" name="stores_covered" class="form-control" placeholder="Enter number of stores" min="0" value="<%= distributorData.stores_covered %>" readonly>
                             </div>

                            <div class="mb-3">
                                <label class="form-label" for="roi">What is the Annual Return of Investment (ROI %)?</label>
                                <input type="number" id="roi" name="roi" class="form-control" placeholder="Enter ROI percentage" value="<%= distributorData.roi || '' %>" readonly>
                            </div>
                        
                        
                            <div class="mb-3">
                                <label class="form-label" for="fmcg_companies">Does the distributor work with other FMCG companies?</label>
                                <select class="form-select" name="fmcg_companies" id="fmcg_companies" disabled>
                                    <option value="">Select</option>

                                    <option value="Yes" <%= distributorData.fmcg_companies === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.fmcg_companies === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>
                        
                            
                            <div class="mb-3">
                                <label class="form-label" for="fmcg_experience">How many years of FMCG experience does the distributor have?</label>
                                <input type="number" id="fmcg_experience" name="fmcg_experience" class="form-control" placeholder="Enter number of years" value="<%= distributorData.fmcg_experience %>" min="0" readonly>
                            </div>

                                                    
                            <div class="mb-3">
                                <label class="form-label" for="stores_mars">How many stores does the DB cover with Mars Wrigley?</label>
                                <input type="number" id="stores_mars" name="stores_mars" class="form-control" placeholder="Enter number of stores" value="<%= distributorData.stores_mars %>" min="0" readonly>
                            </div>
                        
                
                        <!-- Scroll 2: Commercial WoW -->
                            <h5>Commercial WoW</h5>
                            <div class="mb-3">
                                <label class="form-label" for="selling_model">What selling model does the distributor operate with?</label>
                                <select id="selling_model" name="selling_model" class="form-control" disabled>
                                    <option value="">Select</option>
                                    <option value="Ready Stock Model" <%= distributorData.selling_model === 'Ready Stock Model' ? 'selected' : '' %>>Ready Stock Model</option>
                                    <option value="Order Fillment Model" <%= distributorData.selling_model === 'Order Fillment Model' ? 'selected' : '' %>>Order Fillment Model</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="mw_compliance">Is the distributor compliant with MW standards?</label>
                                <select class="form-select" id="mw_compliance" name="mw_compliance" disabled>
                                    <option value="">-- Select --</option>
                                    <option value="Yes" <%= distributorData.mw_compliance === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.mw_compliance === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>
                
                        <!-- Scroll 3: Data Sharing -->
                            <h4>Data Sharing</h4>

                            <div class="mb-3">
                                <label class="form-label" for="cost_structure">Does the distributor provide visibility on distributor cost structure to MW?</label>
                                <select class="form-select" id="cost_structure" name="cost_structure" disabled>
                                    <option value="">Select</option>
                                    <option value="Yes" <%= distributorData.cost_structure === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.cost_structure === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>
                        
                
                        <!-- Scroll 4: Platform to Scale Up -->
                            <h4>Digital Readiness</h4></br>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the DB have a data operator for DMS?</label>
                                <select class="form-select" name="data_operator" id="data_operator" disabled>
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.data_operator === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.data_operator === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Does the DB have an internet connection for computer?</label>
                                <select class="form-select" name="internet_access" id="internet_access" disabled>
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.internet_access === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.internet_access === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Does the DB use a printer?</label>
                                <select class="form-select" name="printer_use" id="printer_use" disabled>
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.printer_use === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.printer_use === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>
                                    
                            <div class="mb-3">
                                <label class="form-label" for="dms_count">How many DMS for other companies including does the DB use?</label>
                                <input type="number" id="dms_count" name="dms_count" class="form-control" placeholder="Enter number of dms count" value="<%= distributorData.dms_count %>" min="0" readonly    
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Which system is used to print final in-market bill?</label>
                                <select class="form-select" name="print_system" id="print_system" disabled>
                                    <option value="">-- Select an option --</option>
                                    <option value="Ivy DMS" <%= distributorData.print_system === "Ivy DMS" ? "selected" : "" %>>Ivy DMS</option>
                                    <option value="Tally" <%= distributorData.print_system === "Tally" ? "selected" : "" %>>Tally</option>
                                    <option value="Others" <%= distributorData.print_system === "Others" ? "selected" : "" %>>Others</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">If DB is not using Ivy DMS, is DB ok to integrate their system with Mars DMS for final in-market bill?</label>
                                <select class="form-select" name="mars_integration" id="mars_integration" disabled>
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.mars_integration === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.mars_integration === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>
                        
                        
                
                            <h4>Logistics</h4>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the distributor have controlled temperature storage and transportation?</label>
                                <select class="form-select" name="temp_storage" id="temp_storage" disabled>
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.temp_storage === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.temp_storage === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="delivery_time">What is the average delivery time for the distributor?</label>
                                <input type="text" id="delivery_time" name="delivery_time" class="form-control" placeholder="Enter delivery time in days" value="<%= distributorData.delivery_time %>" readonly>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="returns_rate">What is the average returns rate on total sales for the distributor? (in percentage)</label>
                                <input
                                    type="text"
