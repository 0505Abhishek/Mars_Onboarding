    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const viewIcons = document.querySelectorAll(".view-icon");
        const modalElement = document.getElementById("fileModal");
        const modalBody = document.getElementById("filePreview");
        const downloadLink = document.getElementById("downloadFile");
        const modalInstance = new bootstrap.Modal(modalElement);
        
        viewIcons.forEach((icon) => {
            icon.addEventListener("click", function (event) {
                event.preventDefault();

                const fileName = this.getAttribute("data-url");
                const fileType = this.getAttribute("data-type");

                const fileUrl = `/public/uploads/${fileName}`;

                if (fileUrl && fileType) {
                    downloadLink.href = fileUrl; 
                    const fileName = fileUrl.split("/").pop();
                    downloadLink.setAttribute("download", fileName);
                    if (fileType === "image") {
                        modalBody.innerHTML = `<img src="${fileUrl}" style="width: 100%; height: auto;">`;
                    } else if (fileType === "pdf") {
                        modalBody.innerHTML = `<embed src="${fileUrl}" type="application/pdf" width="100%" height="500px" />`;
                    } else if (fileType === "excel") {
                    fetch(fileUrl)
                        .then(res => res.arrayBuffer())
                        .then(buffer => {
                            const data = new Uint8Array(buffer);
                            const workbook = XLSX.read(data, { type: "array" });
                            const sheetName = workbook.SheetNames[0];
                            const jsonData = XLSX.utils.sheet_to_json(workbook.Sheets[sheetName], { header: 1 });

                            let tableHtml = `<table class="table table-bordered table-sm table-striped"><thead><tr>`;

                            jsonData[0].forEach(cell => {
                                tableHtml += `<th>${cell || ''}</th>`;
                            });
                            tableHtml += `</tr></thead><tbody>`;

                            jsonData.slice(1).forEach(row => {
                                tableHtml += `<tr>`;
                                row.forEach(cell => {
                                    tableHtml += `<td>${cell !== undefined ? cell : ''}</td>`;
                                });
                                tableHtml += `</tr>`;
                            });

                            tableHtml += `</tbody></table>`;

                            modalBody.innerHTML = `
                                <div style="max-height: 500px; overflow:auto;">${tableHtml}</div>
                            `;
                        });
                }else {
                    modalBody.innerHTML = `<p>Preview not available for this file type.</p>`;
                }

                    modalInstance.show();
                }
            });
        });

         modalElement.addEventListener('hidden.bs.modal', function () {
            modalBody.innerHTML = '';
            downloadBtn.href = '#';
        });
    });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tabs = document.querySelectorAll(".nav-link[data-bs-toggle='tab']");
            const tabContents = document.querySelectorAll(".tab-content");

            tabs.forEach(tab => {
                tab.addEventListener("click", function (e) {
                    e.preventDefault();

                    tabs.forEach(t => t.classList.remove("active"));

                    tabContents.forEach(content => content.classList.add("d-none"));

                    // Activate the clicked tab
                    this.classList.add("active");
                    const target = this.getAttribute("data-tab");
                    document.getElementById(target).classList.remove("d-none");
                });
            });
        });
    </script>

   
<script>
    document.getElementById("DistributorMargin").addEventListener("input", function () {
   this.value = this.value
    .replace(/[^0-9.]/g, '') 
    .replace(/(\..*?)\..*/g, '$1');
 });
</script>

<script>

  let submitButton = document.getElementById("submitButton");

  let token1 = <%- JSON.stringify(token[0]) %>;

   if (localStorage.getItem("isSubmitting") === "true") {
        submitButton.disabled = true;
    }

        
    submitButton.addEventListener("click", function (event) {
        event.preventDefault(); 

        if (submitButton.disabled) {
            return; 
        }
        
        submitButton.disabled = true; 

        localStorage.setItem("isSubmitting", "true");

        let approvalStatus1 = document.getElementById("approvalStatus").value.trim();
        let remarkInput = document.getElementById("remarkInput").value.trim();
        let CdCode = document.getElementById("CdCode")?.value || null;
        let distributorMarginValue = document.getElementById("DistributorMargin")?.value || null;

        let ivyLogin = document.getElementById("ivyLogin")?.checked ? 1 : 0;
        let masterData = document.getElementById("masterData")?.checked ? 1 : 0;
        let stockUpload = document.getElementById("stockUpload")?.checked ? 1 : 0;
        let pricingDetails = document.getElementById("pricingDetails")?.checked ? 1 : 0;
        let additionalRemarks = document.getElementById("additionalRemarks")?.checked ? 1 : 0;
        const cfaChecked = document.querySelectorAll('input[name="cfaList[]"]:checked');
        const selectedCFAs = Array.from(document.querySelectorAll('input[name="cfaList[]"]:checked'))
        .map(cb => cb.value);

        if (token1.correction_from_cd === 1) {

            const additionalCheckboxes = [
                ivyLogin,
                masterData,
                stockUpload,
                pricingDetails,
                additionalRemarks
            ];

            const isAllChecked = additionalCheckboxes.every(checked => checked === 1);

            if (!isAllChecked) {
                Swal.fire({
                    icon: "warning",
                    title: "Additional Selection Required",
                    text: "Please select all options under Additional Details.",
                    confirmButtonText: "OK"
                });
                resetButton();
                return;
            }
        }
        
            if (cfaChecked.length === 0 && token1?.role_id == 11) {
                Swal.fire({
                    icon: "warning",
                    title: "CFA Selection Required",
                    text: "Please select at least one CFA from the list.",
                    confirmButtonText: "OK"
                });
                resetButton();
                return;
            }


            if (token1.correction_from_executive === 1 && (!CdCode || !/^\d{10}$/.test(CdCode))) {
                Swal.fire({
                    icon: "warning",
                    title: "Invalid DB CODE",
                    text: "Please enter a valid 10-digit numeric DB CODE.",
                    confirmButtonText: "OK"
                });
                resetButton();
                return;
            }



        if (approvalStatus1 === "") {
            Swal.fire({
                icon: "warning",
                title: "Select an choice.",
                text: "Please select an choice.",
                confirmButtonText: "OK"
            });
            resetButton();
            return;
        }

        if(remarkInput===""){
            Swal.fire({
                icon: "warning",
                title: "Remark.",
                text: "Please add Remark.",
                confirmButtonText: "OK"
            });
            resetButton();
            return;
        }

        let checkedFields = [];
        let affectedPages = new Set();

        document.querySelectorAll("tbody tr").forEach(row => { 
            let checkbox = row.querySelector("input[type='checkbox']");
            
            if (checkbox && checkbox.checked) {  
                let inputField = row.querySelector("input.form-control");  
                let fieldName = inputField ? inputField.name || inputField.id : ""; 
                let remarkInput = row.querySelector("input[type='text']:not([readonly])");
                let remark = remarkInput ? remarkInput.value.trim() : ""; 

                if (fieldName) {
                    checkedFields.push({ fieldName, remark });

                    let pageSection = row.closest(".details"); 
                    if (pageSection) {
                        affectedPages.add(pageSection.id);
                    }
                }
            }
        });

        let approvalStatus = document.getElementById("approvalStatus").value;

        if (approvalStatus === "correction" && checkedFields.length === 0) {
            Swal.fire({
                icon: "warning",
                title: "Correction Required",
                text: "For 'Correction', you must select at least one field.",
                confirmButtonText: "OK"
            });
            resetButton();
            return;
        }

        if (approvalStatus === "approve" && checkedFields.length > 0) {
            Swal.fire({
                icon: "error",
                title: "Invalid Selection",
                text: "You have selected fields for correction, but also chose 'Approve'. Please deselect fields or change the approval status.",
                confirmButtonText: "OK"
            });
            resetButton();
            return;
        }

        let id = "<%= applicationID %>"; 
        fetch(`/approver_indox/${id}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ 
                fields: checkedFields, 
                status: approvalStatus, 
                pages: [...affectedPages],
                overallremark: remarkInput,
                CdCode: CdCode, 
                DistributorMargin: distributorMarginValue,
                ivyLogin: ivyLogin,  
                masterData: masterData,  
                stockUpload: stockUpload,  
                pricingDetails: pricingDetails,  
                additionalRemarks: additionalRemarks,
                cfaList: selectedCFAs 
            })
        }).then(response => response.json())
        .then(data => {
            localStorage.removeItem("isSubmitting");
            if (data.status === "success") {
                Swal.fire({
                    icon: "success",
                    title: data.message,
                    confirmButtonText: "OK"
                }).then(() => {
                    window.location.href = "/approver_indox";
                });
            } else {
                Swal.fire({
                    icon: "warning",
                    title: data.message,
                    confirmButtonText: "OK"
                }).then(() => {
                    window.location.href = "/approver_indox";
                });
                resetButton();
            }
        }).catch(error => {
            console.error("Error:", error);
            Swal.fire({
                icon: "error",
                title: "An error occurred. Please try again.",
                confirmButtonText: "OK"
            });
            resetButton();
        });
    });
    
    function resetButton() {
        submitButton.disabled = false;
        submitButton.innerText = "Submit";
        localStorage.removeItem("isSubmitting"); 
    }

</script>

<script>
    document.getElementById('approvalStatus').addEventListener('change', function () {
        const selectedValue = this.value;
        if (selectedValue === 'approve') {
            this.style.color = 'green';
        } else if (selectedValue === 'reject') {
            this.style.color = 'red';
        } else if (selectedValue === 'correction') {
            this.style.color = 'goldenrod';
        } else {
            this.style.color = 'black';
        }
    });
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const searchInput = document.getElementById("cfaSearchInput");
    const optionContainer = document.getElementById("cfaOptions");

    searchInput.addEventListener("keyup", function () {
      const filter = searchInput.value.toLowerCase();
      const options = optionContainer.querySelectorAll(".form-check");

      options.forEach(option => {
        const label = option.textContent.toLowerCase();
        option.style.display = label.includes(filter) ? "" : "none";
      });
    });
  });
</script>


