<%- include("../shared/header.ejs") %>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Application Details - Overview</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>

        .nav-tabs .nav-link.active {
            background-color: #007bff;
            color: white;
        }
        #card-body2
        {
            margin-top: -30px;
        }
        #card-body3{
            margin-top: -30px;
        }
        .modal-backdrop {
        display: none !important;
    }

    .modal-body {
        max-height: 440px;
        overflow-y: auto;
    }
    .modal-dialog{
        width:75%;
    }
    .view-icon {
        font-size: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
    }
    .custom-width {
      width: 150px;
    }

    </style>

    <style>
        .list-group-item {
            font-size: 18px; 
            cursor: pointer; 
        }
    </style>

<style>
  .custom-multiselect {
    width: 100%;
  }

  #cfaSearchInput {
    font-size: 14px;
  }

  #cfaOptions .form-check {
    margin-bottom: 5px;
  }

</style>


<style>
    @media (max-width: 1400px) {
    .table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
        margin-bottom: 0;
    }

    .table th, .table td {
        min-width: 150px;
    }
}

</style>
    
</head>
<body class="bg-light">
    <div class="container mt-4">
        <div class="d-flex align-items-center mb-3">
            <a href="/approver_indox" class="text-decoration-none text-black d-flex align-items-center">
                <i class="fas fa-arrow-left"></i>
                <h1 class="ms-2 h5 mb-0">Application Details</h1>
            </a>
        </div>

        <strong class="text-primary mb-3 d-block"> <span style="color: black;">Firm Name -</span> <%= distributor?.firmName %> </strong>
        <div class="card">
            <!-- Navigation Tabs -->
            <ul class="nav nav-tabs" id="myTabs">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" data-tab="overview" href="#">OVERVIEW</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" data-tab="history" href="#">HISTORY</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" data-tab="documents" href="#">DOCUMENTS & DETAILS</a>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="card-body" id="card-body1">
                <div id="overview" class="tab-content active">
                    <p class="h6"><%= distributor?.distributorName%></p>
                    <p class="mt-3">
                        <span class="text-primary">Application Type -</span> <%= distributor?.applicationType%>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">Application Start Date -</span> 
                        <%= new Date(distributor?.application_start_date).toLocaleString('en-GB', { timeZone: 'Asia/Kolkata' }).split(',')[0] %>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">ASM Name-</span> 
                        <%= distributor?.employee_name%>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">Territory Name -</span> 
                        <%= distributor?.territory_name%>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">DB Name -</span> 
                        <%= distributor?.distributorName%>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">Replacement DB Name -</span> 
                        <%= distributor?.ReplacedDBName %>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">Replacement DB CODE -</span> 
                        <%= distributor?.replaced_cdCode %>
                    </p>

                    <p class="mt-2">
                        <span class="text-primary">DB Channel -</span> 
                        <%= distributor?.dbType %>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">DB CODE -</span> 
                        <%= CdCodeAndMargin[0]?.cdCode %>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">Distributor Margin % -</span> 
                        <%= CdCodeAndMargin[0]?.distributorMargin %>
                    </p>
                    <p class="mt-2">
                        <span class="text-primary">CFA List -</span> 
                        <%= submittedCfaList[0]?.cfaList %>
                    </p>
                      
                </div>
            </div> 

            <div class="card-body" id="card-body2">
                <div id="history" class="tab-content d-none">
                    <h5 class="text-primary">Application Timeline</h5>
                    <ul class="list-group">
                        <%  
                        function formatDate(dateTime) {
                            if (!dateTime) return ''; 
                            const date = new Date(dateTime);
                            const options = { year: 'numeric', month: '2-digit', day: '2-digit' };
                            const formattedDate = date.toLocaleDateString('en-GB', options); // Format: DD/MM/YYYY
                            const formattedTime = date.toLocaleTimeString('en-US'); // Format: HH:MM:SS AM/PM
                            return { date: formattedDate, time: formattedTime };
                        }
                    
                        const inviteSentFormatted = formatDate(distributor.invitesend);
                    %>    
                    
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-primary" onclick="toggleDetails('inviteSent')">
                            Invite Sent
                        </span>
                        <span><%= inviteSentFormatted.date %> &nbsp; <%= inviteSentFormatted.time %></span>
                    </li>
                    <div id="inviteSent" class="details d-none">
                        <table class="table table-bordered mt-2">
                            <tr>
                                <th>Action</th>
                                <th>Date</th>
                                <th>Details</th>
                            </tr>
                            <tr>
                                <td>Invite Sent</td>
                                <td><%= inviteSentFormatted.date %></td>
                                <td><%= inviteSentFormatted.time %></td>
                            </tr>
                        </table>
                    </div>
                    
                        
            
                        <!-- <li class="list-group-item text-primary" onclick="toggleDetails('documentCapture')">Document Capture</li>
                        <div id="documentCapture" class="details d-none">
                            <table class="table table-bordered mt-2">
                                <thead>
                                    <tr>
                                        <th>S.No.</th>
                                        <th>From</th>
                                        <th>Action</th>
                                        <th>Date</th>
                                        <th>To</th>
                                        <th>Remarks/Comments</th>
                                    </tr>
                                </thead>
                                <tbody>
                                   
                                </tbody>
                            </table>
                        </div> -->
            
                        <li class="list-group-item text-primary" onclick="toggleDetails('underReview')">Under Review</li>
                        <div id="underReview" class="details d-none">
                            <table class="table table-bordered mt-2">
                                <thead>
                                    <tr>
                                        <th>S.No.</th>
                                        <th>From</th>
                                        <th>Action</th>
                                        <th>Date</th>
                                        <th>To</th>
                                        <th>Remarks/Comments</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (applicationHistory.length > 0) { %>
                                        <% applicationHistory.forEach((history, index) => { %>
                                            <tr>
                                                <td><%= index + 1 %></td>
                                                <td><%= history.action_by_role %></td>
                                                <td><%= history.remarks %></td>
                                                <td>
                                                <%= history.action_time 
                                                    ? new Date(history.action_time).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) 
                                                    : "N/A" %>
                                                </td>
                                                <td><%= history.actionForRole %></td>
                                                <td><%= history.user_remark || "" %></td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center">No history found</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                            
                        </div>
            
                        <!-- <li class="list-group-item text-primary" onclick="toggleDetails('inviteExpired')">Invite Expired</li>
                        <div id="inviteExpired" class="details d-none">
                            <table class="table table-bordered mt-2">
                                <thead>
                                    <tr>
                                        <th>S.No.</th>
                                        <th>From</th>
                                        <th>Action</th>
                                        <th>Date</th>
                                        <th>To</th>
                                        <th>Remarks/Comments</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>1</td>
                                        <td>Lorem Ipsum</td>
                                        <td>Send Invite</td>
                                        <td>11/02/2025 1:53:53 PM</td>
                                        <td>Amit Kumar Mahawar</td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td>2</td>
                                        <td>Lorem Ipsum</td>
                                        <td>Accepted</td>
                                        <td>11/02/2025 1:57:27 PM</td>
                                        <td>Amit Kumar Mahawar</td>
                                        <td></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div> -->
                    </ul>
                </div>
            </div>
            
            

            <div class="card-body" id="card-body3">
                <div id="documents" class="tab-content d-none">
                    <!-- Basic Details Section -->
                  <ul class="list-group">
                    <li class="list-group-item text-primary" onclick="toggleDetails('basicDetails')">Basic Details</li>
                    <div id="basicDetails" class="details d-none">
                        <form id="basicDetailsForm">
                            <table class="table table-bordered mt-2">
                                <thead>
                                    <tr>
                                        <th>Field Name</th>
                                        <th>User Input</th>
                                        <th>Remarks</th>
                                        <th>Verified</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Application Type</td>
                                        <td><input type="text" class="form-control" id="applicationType" value="<%= distributor?.applicationType %>" readonly></td>
                                        <td><input type="text" class="form-control" id="applicationTypeRemark" placeholder="Enter remark"></td>
                                        <td></td>
                                    </tr>                                   
                                    <tr>
                                        <td>DB Channel</td>
                                        <td><input type="text" class="form-control" id="dbType" value="<%= distributor?.dbType %>" readonly></td>
                                        <td><input type="text" class="form-control" id="dbTypeRemark" placeholder="Enter remark"></td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td>SO Territory</td>
                                        <td><input type="text" class="form-control" id="SO_Terr" value="<%= distributor?.so_territory_name %>" readonly></td>
                                        <td><input type="text" class="form-control" id="SO_TerrRemark" placeholder="Enter remark"></td>
                                    </tr> 
                                    <tr>
                                        <td>SO Name</td>
                                        <td><input type="text" class="form-control" id="SO_Name" value="<%= distributor?.SO_Name %>" readonly></td>
                                        <td><input type="text" class="form-control" id="SO_NameRemark" placeholder="Enter remark"></td>
                                    </tr>
                                    <tr>
                                        <td>Firm Name</td>
                                        <td><input type="text" class="form-control" id="firmName" value="<%= distributor?.firmName %>" readonly></td>
                                        <td><input type="text" class="form-control" id="firmNameRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="firmNameCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Distributor Name</td>
                                        <td><input type="text" class="form-control" id="distributorName" value="<%= distributor?.distributorName %>" readonly></td>
                                        <td><input type="text" class="form-control" id="distributorNameRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="distributorNameCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Email</td>
                                        <td><input type="email" class="form-control" id="email" value="<%= distributor?.email %>" readonly></td>
                                        <td><input type="text" class="form-control" id="emailRemark" placeholder="Enter remark" readonly></td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td>Contact Number</td>
                                        <td><input type="text" class="form-control" id="contactNumber" value="<%= distributor?.contactNumber %>" readonly></td>
                                        <td><input type="text" class="form-control" id="contactNumberRemark" placeholder="Enter remark"></td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td>Experience in Distribution</td>
                                        <td><input type="text" class="form-control" id="experienceDistribution" value="<%= distributor?.experienceDistribution %>" readonly></td>
                                        <td><input type="text" class="form-control" id="experienceDistributionRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="experienceDistributionCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Experience in FMCG</td>
                                        <td><input type="text" class="form-control" id="experienceFMCG" value="<%= distributor?.experienceFMCG %>" readonly></td>
                                        <td><input type="text" class="form-control" id="experienceFMCGRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="experienceFMCGCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Outlets Covered</td>
                                        <td><input type="text" class="form-control" id="outletsCovered" value="<%= distributor?.outletsCovered %>" readonly></td>
                                        <td><input type="text" class="form-control" id="outletsCoveredRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="outletsCoveredCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Monthly Turnover</td>
                                        <td><input type="text" class="form-control" id="monthlyTurnover" value="<%= distributor?.monthlyTurnover %>" readonly></td>
                                        <td><input type="text" class="form-control" id="monthlyTurnoverRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="monthlyTurnoverCheck"></td>
                                    </tr>

                                    <tr>
                                        <td>Monthly Turnover</td>
                                        <td><input type="text" class="form-control" id="monthlyTurnover" value="<%= distributor?.monthlyTurnover %>" readonly></td>
                                        <td><input type="text" class="form-control" id="monthlyTurnoverRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="monthlyTurnoverCheck"></td>
                                    </tr>

                                     <tr>
                                        <td>Freight Expenses %</td>
                                        <td><input type="text" class="form-control" id="FreightExpenses" value="<%= distributor?.FreightExpenses %>" readonly></td>
                                        <td><input type="text" class="form-control" id="FreightExpensesRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="FreightExpensesCheck"></td>
                                    </tr>

                                </tbody>
                            </table>
                        </form>
                    </div>
                    
                    
            
                    <!-- Additional Details Section -->
                    <li class="list-group-item text-primary" onclick="toggleDetails('additionalDetails')">Additional Details</li>
                    <div id="additionalDetails" class="details d-none">
                        <form id="additionalDetailsForm">
                            <table class="table table-bordered mt-2">
                                <thead>
                                    <tr>
                                        <th class="fixed-width">Field Name</th>
                                        <th>User Input</th>
                                        <th>Remarks</th>
                                        <th>Verified</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>How many stores does the DTR cover? (Mars Wrigley stores and non-Mars Wrigley stores)</td>
                                        <td><input type="text" class="form-control" id="stores_covered" placeholder="Enter number" value="<%=distributor?.stores_covered %>" readonly></td>
                                        <td><input type="text" class="form-control" id="stores_coveredRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="stores_coveredCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>What is the Annual Return of Investment (ROI %)?</td>
                                        <td><input type="text" class="form-control" id="roi" placeholder="Enter ROI" value="<%=distributor?.roi %>" readonly></td>
                                        <td><input type="text" class="form-control" id="roiRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="roiCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Does the distributor work with other FMCG companies?</td>
                                        <td><input type="text" class="form-control" id="fmcg_companies" value="<%= distributor?.fmcg_companies %>" readonly></td>
                                        <td><input type="text" class="form-control" id="fmcg_companiesRemark" placeholder="Enter remarks"></td>
                                        <td><input type="checkbox" id="fmcg_companiesCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>How many years of FMCG experience does the distributor have?</td>
                                        <td><input type="text" class="form-control" id="fmcg_experience" value="<%= distributor?.fmcg_experience %>" readonly></td>
                                        <td><input type="text" class="form-control" id="fmcg_experienceRemark" placeholder="Enter remarks"></td>
                                        <td><input type="checkbox" id="fmcg_experienceCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>How many stores does the DB cover with Mars Wrigley?</td>
                                        <td><input type="text" class="form-control" id="stores_mars" value="<%= distributor?.stores_mars %>" readonly></td>
                                        <td><input type="text" class="form-control" id="stores_marsRemark" placeholder="Enter remarks"></td>
                                        <td><input type="checkbox" id="stores_marsCheck"></td>
                                    </tr>


                                    <tr>
                                        <td>What selling model does the distributor operate with?</td>
                                        <td><input type="text" class="form-control" id="selling_model" placeholder="Enter model" value="<%= distributor?.selling_model %>" readonly></td>
                                        <td><input type="text" class="form-control" id="selling_modelRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="selling_modelCheck"></td>
                                    </tr>
                                                                        
                                    <tr>
                                        <td>How many sales reps (DSR, KAE, ISR etc combined) does the distributor have?</td>
                                        <td><input type="text" class="form-control" id="sales_reps" value="<%= distributor?.sales_reps %>" readonly></td>
                                        <td><input type="text" class="form-control" id="sales_repsRemark" placeholder="Enter remarks"></td>
                                        <td><input type="checkbox" id="sales_repsCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Is the distributor compliant with MW standards?</td>
                                        <td><input type="text" class="form-control" id="mw_compliance" placeholder="Enter compliance details" value="<%= distributor?.mw_compliance %>" readonly></td>
                                        <td><input type="text" class="form-control" id="mw_complianceRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="mw_complianceCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Does the distributor provide visibility on cost structure?</td>
                                        <td><input type="text" class="form-control" id="cost_structure" placeholder="Enter percentage"  value="<%= distributor?.cost_structure %>" readonly></td>
                                        <td><input type="text" class="form-control" id="cost_structureRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="cost_structureCheck"></td>
                                    </tr>

                                    <tr>
                                        <td>Does the DB have a data operator for DMS?</td>
                                        <td><input type="text" class="form-control" id="data_operator" placeholder="Enter Yes or No" value="<%= distributor?.data_operator %>" readonly></td>
                                        <td><input type="text" class="form-control" id="data_operatorRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="data_operatorCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Does the DB have an internet connection for computer?</td>
                                        <td><input type="text" class="form-control" id="internet_access" placeholder="Enter Yes or No" value="<%= distributor?.internet_access %>" readonly></td>
                                        <td><input type="text" class="form-control" id="internet_accessRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="internet_accessCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Does the DB use a printer?</td>
                                        <td><input type="text" class="form-control" id="printer_use" placeholder="Enter Yes or No" value="<%= distributor?.printer_use %>" readonly></td>
                                        <td><input type="text" class="form-control" id="printer_useRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="printer_useCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>How many DMS systems does the DB use?</td>
                                        <td><input type="text" class="form-control" id="dms_count" placeholder="Enter number of DMS" value="<%= distributor?.dms_count %>" readonly></td>
                                        <td><input type="text" class="form-control" id="dms_countRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="dms_countCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Which system is used to print final in-market bill?</td>
                                        <td><input type="text" class="form-control" id="print_system" name= "print_system" placeholder="Enter number of DMS" value="<%= distributor?.print_system %>" readonly></td>   
                                        <td><input type="text" class="form-control" id="print_systemRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="print_systemCheck"></td>
                                    </tr>


                                    <!-- Logistics -->
                                    <tr>
                                        <td>If DB is not using Ivy DMS, is DB ok to integrate <br> their system with Mars DMS for final in-market bill?
                                        </td>
                                        <td><input type="text" class="form-control" id="mars_integration" placeholder="Enter number of DMS" value="<%= distributor?.mars_integration %>" readonly></td>
                                        <td><input type="text" class="form-control" id="mars_integrationRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="mars_integrationCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>Does the distributor have controlled temperature storage and transportation?</td>
                                        <td><input type="text" class="form-control" id="temp_storage" name="temp_storage" value="<%= distributor?.temp_storage %>" readonly></td>
                                        <td><input type="text" class="form-control" id="temp_storageRemark" placeholder="Enter remarks"></td>
                                        <td><input type="checkbox" id="temp_storageCheck"></td>
                                    </tr>
                                    
                                    <tr>
                                        <td>What is the average delivery time for the distributor?</td>
                                        <td><input type="text" class="form-control" id="delivery_time" placeholder="Enter delivery time in days" value="<%= distributor?.delivery_time %>" readonly></td>
                                        <td><input type="text" class="form-control" id="delivery_timeRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="delivery_timeCheck"></td>
                                    </tr>
                                    <tr>
                                        <td>What is the average returns rate on total sales for the distributor? (in percentage)</td>
                                        <td><input type="text" class="form-control" id="returns_rate" placeholder="Enter returns percentage" value="<%= distributor?.returns_rate %>" readonly></td>
                                        <td><input type="text" class="form-control" id="returns_rateRemark" placeholder="Enter remark"></td>
                                        <td><input type="checkbox" id="returns_rateCheck"></td>
                                    </tr>

                                        <tr>
                                            <td>What is the share of MW sales on total confectionery sales for the distributor?</td>
                                            <td><input type="text" class="form-control" id="mw_sales_share" name="mw_sales_share" min="0" max="100" value="<%= distributor?.mw_sales_share %>" readonly></td>
                                            <td><input type="text" class="form-control" id="mw_sales_shareRemark" placeholder="Enter remark"></td>
                                            <td><input type="checkbox" id="mw_sales_shareCheck"></td>
                                        </tr>
                                    
                                        <tr>
                                            <td>What is the openness to change of the distributor?</td>
                                            <td><input type="text" class="form-control" id="openness_change" placeholder="Enter returns percentage" value="<%= distributor?.openness_change %>" readonly></td>
                                            <td><input type="text" class="form-control" id="openness_changeRemark" placeholder="Enter remark"></td>
                                            <td><input type="checkbox" id="openness_changeCheck"></td>
                                        </tr>
                                    
                                        <tr>
                                            <td>What is the share of confectionery on total distributors' sales?</td>
                                            <td><input type="text" class="form-control" id="confectionery_sales_share" name="confectionery_sales_share" min="0" max="100" value="<%= distributor?.confectionery_sales_share %>" readonly></td>
