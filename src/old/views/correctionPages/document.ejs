<script>
  document.addEventListener("DOMContentLoaded", function () {
    let fields = '<%- JSON.stringify(fields) %>';

    try {
        if (fields && typeof fields === "string") {
            fields = JSON.parse(fields);
        }
    } catch (error) {
        console.error("Error parsing documents:", error);
        fields = [];
    }




    document.querySelectorAll("#documentTable tbody tr").forEach(row => {
        row.style.display = "none";
    });

 let remarksMap = {};
    fields.forEach(doc => {
        remarksMap[doc.fieldName] = doc.remark || "";
    });

    document.querySelectorAll("input[type='file']").forEach(fileInput => {
        let inputName = fileInput.getAttribute("name"); 
        let row = fileInput.closest("tr"); 

        if (inputName && remarksMap.hasOwnProperty(inputName)) { 
            row.style.display = "table-row";

            const remarksInput = row.querySelector("td:last-child input[type='text']");  
            if (remarksInput) {
                remarksInput.value = remarksMap[inputName]; 
            }
        }
    });

    document.getElementById("documentForm").addEventListener("submit", function (event) {
    let missingDocs = [];

    document.querySelectorAll("#documentTable tbody tr").forEach(row => {
        if (row.style.display !== "none") {
            const fileInput = row.querySelector("input[type='file']");
            const docNameElement = row.querySelector("td:first-child"); // Adjusted for clarity
            const docName = docNameElement ? docNameElement.textContent.trim() : "Unknown Document";


            if (docName === "Bank Statement") {
                return;
            }

            if (fileInput && fileInput.files.length === 0) {
                missingDocs.push(docName);
            }
        }
    });

    if (missingDocs.length > 0) {
        event.preventDefault();

        Swal.fire({
            icon: "error",
            title: "Missing Documents!",
            html: `<strong>Please upload all required documents:</strong><br><ul>${missingDocs.map(doc => `<li>${doc}</li>`).join("")}</ul>`,
            confirmButtonText: "OK",
        });
    }
});

});

</script>


