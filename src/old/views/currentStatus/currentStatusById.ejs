<%- include("../shared/header.ejs") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Bootstrap 5 JS (needed for Modal, Dropdown, etc.) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- DataTables -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>

<style>
    .hidden { display: none; }

    .scroll-section {
        max-height: 300px;
        overflow-y: auto;
        border: 1px solid #ccc;
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 5px;
        background: #f8f9fa;
    }

    .modal-backdrop { display: none !important; }

    .modal-body { max-height: 440px; overflow-y: auto; }

    .modal-dialog { width: 75%; }

    table { width: 100%; border-collapse: collapse; margin-top: 20px; }

    th, td {
        border: 1px solid #ccc;
        padding: 10px;
        text-align: center;
    }

    .view-icon { cursor: pointer; font-size: 20px; }

    .table-dark th {
        color: #0000A0 !important;
        background-color: #E0E0FC;
        border: 1px solid rgb(224, 203, 203);
    }

    #distributorTable tbody tr:nth-child(odd) td {
        background: #FFFFFF !important;
    }

    #distributorTable tbody tr:nth-child(even) td {
        background: #EFEFFF !important;
    }
</style>

<div class="container mt-4">
    <div class="table-responsive">
        <table id="distributorTable" class="table table-striped table-bordered display nowrap" style="width:100%">
        <thead class="table-dark">
            <tr>
            <th>Unique Application Code</th>
            <th>Firm Name</th>
            <th>Email</th>
            <th>Action</th>
            <th>Remark</th>
            <th>Action By Role</th>
            <th>Fields</th>
            <th>Start Date</th>
            </tr>
        </thead>
        <tbody id="distributorBody">
            <% if (distributors?.length > 0) { %>
            <% distributors.forEach((distributor) => { %>
                <tr>
                    <td><%= distributor?.mars_code %></td>
                    <td><%= distributor?.firmName ?? 'N/A' %></td>
                    <td><%= distributor?.email %></td>
                    <td><%= distributor?.remarks ?? 'N/A' %></td>
                    <td><%= distributor?.user_remark ?? 'N/A' %></td>
                    <td><%= distributor?.action_by_role ?? 'N/A' %></td>
                    <td>
                        <% if (distributor?.fields) { %>
                            <button type="button" 
                                    class="btn btn-primary view-fields" 
                                    data-fields='<%- distributor.fields %>'>
                                View Fields
                            </button>
                        <% } %>
                    </td>
                    <td><%= distributor?.action_time ? new Date(distributor?.action_time).toLocaleDateString('en-CA') : 'N/A' %></td>
                </tr>
            <% }) %>
            <% } else { %>
            <tr>
                <td colspan="7" class="text-center">No distributors found.</td>
            </tr>
            <% } %>
        </tbody>
        </table>

        <div class="modal fade" id="fieldsModal" tabindex="-1" aria-labelledby="fieldsModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="fieldsModalLabel">Application History</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered">
                    <thead>
                        <tr id="fieldsTableHeader"></tr>
                    </thead>
                    <tbody id="fieldsModalBody"></tbody>
                    </table>
                </div>
                </div>
            </div>
        </div>

        <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".view-fields").forEach(link => {
            link.addEventListener("click", function (e) {
                e.preventDefault();

                let fieldsData;
                try {
                fieldsData = JSON.parse(this.getAttribute("data-fields"));
                } catch (err) {
                console.error("Invalid fields data:", err);
                fieldsData = [];
                }

                const tableHeader = document.getElementById("fieldsTableHeader");
                const modalBody = document.getElementById("fieldsModalBody");
                modalBody.innerHTML = "";

                if (Array.isArray(fieldsData) && fieldsData.length > 0) {

                    if (fieldsData[0].fieldName) {

                    tableHeader.innerHTML = `
                    <th>Field Name</th>
                    <th>Remark</th>
                    `;

                    fieldsData.forEach(field => {
                    modalBody.innerHTML += `
                        <tr>
                        <td>${field.fieldName || "N/A"}</td>
                        <td>${field.remark || "N/A"}</td>
                        </tr>
                    `;
                    });

                } else if (fieldsData[0].doc_name) {

                    tableHeader.innerHTML = `
                    <th>Document Name</th>
                    <th>Remarks</th>
                    `;

                    fieldsData.forEach(field => {
                    modalBody.innerHTML += `
                        <tr>
                        <td>${field.doc_name || "N/A"}</td>
                        <td>${field.remarks || "N/A"}</td>
                        </tr>
                    `;
                    });
                }

                } else {
                tableHeader.innerHTML = "";
                modalBody.innerHTML = `<tr><td colspan="3" class="text-center">No field details available</td></tr>`;
                }

                const fieldsModal = new bootstrap.Modal(document.getElementById("fieldsModal"));
                fieldsModal.show();
            });
            });
        });
        </script>

    </div>
</div>

<script>
    $(document).ready(function () {
        $('#distributorTable').DataTable({
            paging: true,
            searching: true, 
            ordering: true,
            info: true,
            lengthMenu: [5, 10, 25, 50],
            pageLength: 10
        });
    });
</script>

<%- include("../shared/footer.ejs") %>
