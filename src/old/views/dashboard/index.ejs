<%- include("../shared/header"); %>

<style>
  .container {
    min-height: 90%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .offboard-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 25px;
  }

  .row-wrapper {
    display: flex;
    justify-content: center;
    gap: 25px;
  }

  .offboard-card {
    width: 380px;
    height: 230px;
    background: #001e8a;
    color: white;
    border-radius: 50px;
    padding: 25px;
    text-align: center;
    box-shadow: 0px 4px 14px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .offboard-card h3 {
    font-size: 28px;
    margin-top: 15px;
    color: white !important;
  }

  .card-icon {
    width: 85px;
    margin: 0 auto;
  }
  .card-link {
    text-decoration: none;
    color: inherit;
}

.card-link:hover .offboard-card {
    transform: scale(1.03);
    transition: 0.2s ease-in-out;
    cursor: pointer;
}

</style>

<div class="container mt-4">
  <div class="offboard-grid">
    <div class="row-wrapper">
      <a href="/dashboard/onboard" class="card-link">
        <div class="offboard-card">
          <img src="../../public/images/Onboarding.png" class="card-icon" />
          <h3>Onboarding</h3>
        </div>
      </a>

      <a href="/dashboard/offboard" class="card-link">
        <div class="offboard-card">
          <img src="../../public/images/Offboarding.png" class="card-icon" />
          <h3>Offboarding</h3>
        </div>
      </a>
    </div>
  </div>
</div>

<%- include("../shared/footer"); %>
