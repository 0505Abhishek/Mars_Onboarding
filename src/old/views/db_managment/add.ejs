<%- include("../shared/super_header.ejs") %>
    <div class="main-panel distributors-details">
        <div class="content-wrapper">
            <div class="row">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card p-3 table-responsive">
                        <div class="d-flex justify-content-between my-4">
                            <div class="business-hading d-flex justify-content-between">
                                <h4>Add DB</h4>

                            </div>
                        </div>
                        <div class="card-body">
                            <form action="/db_managment/add-user" method="post">
                                <div class="form-group">
                                    <label for="distributorName">DB Name</label>
                                    <input type="text" class="form-control" id="distributorName" name="distributorName" required>
                                </div>
                                <div class="form-group">
                                    <label for="firmName">Firm Name</label>
                                    <input type="text" class="form-control" id="firmName" name="firmName" required>
                                </div>
                                <div class="form-group">
                                    <label for="email">DB Email</label>
                                    <input type="email" class="form-control" id="email" name="email_id" required>
                                </div>
                                <div class="form-group">
                                    <label for="contactNumber">Contact Number</label>
                                    <input type="tel" class="form-control" minlength="10" maxlength="10" id="contactNumber" name="contactNumber" required>
                                </div>
                                <div class="form-group">
                                    <label for="dbId">DB Id</label>
                                    <input type="text" class="form-control" id="dbId" name="dbId" required>
                                </div>
                                <button type="submit" class="btn btn-primary">Add DB</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>