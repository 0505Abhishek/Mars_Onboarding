<%- include("../shared/header.ejs") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<style>
    .modal-backdrop {
        display: none !important;
    }

    .modal-body {
        max-height: 440px;
        overflow-y: auto;
    }
    .modal-dialog{
        width:75%;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th, td {
        border: 1px solid #ccc;
        padding: 10px;
        text-align: center;
    }

    .view-icon {
        cursor: pointer;
        font-size: 20px;
    }

    .table-dark th {
        color: #0000A0 !important;
        background-color: #E0E0FC;
        border: 1px solid rgb(224, 203, 203);
    }

    #documentTable tbody tr:nth-child(odd) td {
        background: #FFFFFF !important;
    }

    #documentTable tbody tr:nth-child(even) td {
        background: #EFEFFF !important;
    }

    .action-buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }
    .custom-blue {
        background-color: #007BFF !important;
        color: white !important;
        border: none !important;
    }
    .is-invalid {
    border-color: red;
 }
</style>

<style>
    .back-link {
        font-size: 1.5rem;
        font-weight: 500;
        text-decoration: none;
        color: #1a1a1a; /* Adjust color as per your design */
        display: flex;
        align-items: center;
        margin-bottom:20px;
    }

    .back-link i {
        font-size: 20px;
        margin-right: 8px;
    }
</style>


<div class="container mt-4 mb-4">

    <div class="d-flex justify-content-between align-items-center">
        <a href="/distributorList" class="back-link">
            <i class="fa fa-angle-left"></i> Document Verification
        </a>
    </div>
    <div class="table-responsive">
        <table id="documentTable">
            <thead>
                <tr>
                    <th>S. No.</th>
                    <th>Document Name</th>
                    <th>View</th>
                    <th>✔</th>
                    <th>❌</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                <% 
                const documentMappings = [
                    { key: "crf_form", name: "CRF Form", mandatory: true },
                    { key: "gst_certificate", name: "GST Certificate", mandatory: true },
                    { key: "fssai_certificate", name: "FSSAI Certificate", mandatory: true },
                    { key: "pan_card", name: "PAN Card", mandatory: true },
                    { key: "cancelled_cheque", name: "Cancelled Cheque", mandatory: true },
                    { key: "db_agreement", name: "DB Agreement", mandatory: true },
                    { key: "godown_insurance", name: "Godown Insurance", mandatory: true },
                    { key: "replacement_noc", name: "Replacement NOC", mandatory: distributor.applicationType === "replacement" },
                    { key: "fssai_amendment_copy", name: "FSSAI Amendment Copy", mandatory: true },
                    { key: "freight_sheet", name: "Freight Sheet", mandatory: distributor.dbType == "Hub" },
                    { key: "bank_statement", name: "Bank Statement", mandatory: distributor.dbType == "Credit" },
                    { key: "rsm_document", name: "RSM Document", mandatory: !!distributor.rsm_document },
                    { key: "Resignation_DB", name: "Resignation of Replacement DB", mandatory: !!distributor.Resignation_DB},
                    { key: "noc_document", name: "NOC Document", mandatory: !!distributor.noc_document },

                    // New custom-named documents
                    { key: "other_doc_1_file", name: distributor.other_doc_1_name || "Other Document 1", mandatory: !!distributor.other_doc_1_file },
                    { key: "other_doc_2_file", name: distributor.other_doc_2_name || "Other Document 2", mandatory: !!distributor.other_doc_2_file },
                    { key: "other_doc_3_file", name: distributor.other_doc_3_name || "Other Document 3", mandatory: !!distributor.other_doc_3_file },
                ];

                let serial = 1;
                documentMappings.forEach((doc) => { 
                    if (!doc.mandatory) return;

                    const file = distributor[doc.key]; 
                    let remarks = "";
                %>
                    <tr>
                        <td><%= serial++ %></td>
                        <td><%= doc.name %></td>
                        <td>
                            <% if (file) { 
                                const fileExtension = file.split('.').pop().toLowerCase();
                                let fileType = "other";
                                if (["jpg", "jpeg", "png"].includes(fileExtension)) {
                                    fileType = "image";
                                } else if (fileExtension === "pdf") {
                                    fileType = "pdf";
                                } else if (["xls", "xlsx", "csv"].includes(fileExtension)) {
                                    fileType = "excel";
                                }
                            %>
                                <a href="#" class="view-icon" data-url="/uploads/<%= file %>" data-type="<%= fileType %>" style="text-decoration:none;">
                                    👁
                                </a>
                            <% } else { %>
                                <span style="color: red;">Not Uploaded</span>
                            <% } %>
                        </td>
                        <td>
                            <input type="radio" name="doc_<%= doc.key %>" value="tick">
                        </td>
                        <td>
                            <input type="radio" name="doc_<%= doc.key %>" value="cross">
                        </td>
                        <td>
                            <input type="text" placeholder="Enter remarks" value="<%= remarks %>">
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

    </div>
    

    <div class="action-buttons">
        <button class="btn btn-primary" id="correctionBtn">Correction</button>
        <button class="btn btn-primary" id="approveBtn">Verify</button>
    </div>
    
</div>

<!-- Modal for File Preview -->
<div class="modal" id="fileModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Document Preview</h5>
                <button type="button" class="close" data-bs-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body text-center">
                <div id="filePreview"></div>
            </div>
            <div class="modal-footer">
                <a href="#" id="downloadFile" class="btn btn-primary" download target="_blank">Download</a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const viewIcons = document.querySelectorAll(".view-icon");
    const modalElement = document.getElementById("fileModal");
    const modalBody = document.getElementById("filePreview");
    const downloadLink = document.getElementById("downloadFile");
    const modalInstance = new bootstrap.Modal(modalElement);

    viewIcons.forEach((icon) => {
        icon.addEventListener("click", function (event) {
            event.preventDefault(); // Prevent default link action

            const fileUrl = this.getAttribute("data-url");
            const fileType = this.getAttribute("data-type");

            if (fileUrl && fileType) {
                downloadLink.href = fileUrl; // Set download link
                const fileName = fileUrl.split("/").pop();
                downloadLink.setAttribute("download", fileName);

                if (fileType === "image") {
                    modalBody.innerHTML = `<img src="${fileUrl}" style="width: 100%; height: auto;">`;
                } else if (fileType === "pdf") {
                    modalBody.innerHTML = `<embed src="${fileUrl}" type="application/pdf" width="100%" height="500px" />`;
                } else if (fileType === "excel") {
                    fetch(fileUrl)
                        .then(res => res.arrayBuffer())
                        .then(buffer => {
                            const data = new Uint8Array(buffer);
                            const workbook = XLSX.read(data, { type: "array" });
                            const sheetName = workbook.SheetNames[0];
                            const jsonData = XLSX.utils.sheet_to_json(workbook.Sheets[sheetName], { header: 1 });

                            let tableHtml = `<table class="table table-bordered table-sm table-striped"><thead><tr>`;

                            jsonData[0].forEach(cell => {
                                tableHtml += `<th>${cell || ''}</th>`;
                            });
                            tableHtml += `</tr></thead><tbody>`;

                            jsonData.slice(1).forEach(row => {
                                tableHtml += `<tr>`;
                                row.forEach(cell => {
                                    tableHtml += `<td>${cell !== undefined ? cell : ''}</td>`;
                                });
                                tableHtml += `</tr>`;
                            });

                            tableHtml += `</tbody></table>`;

                            modalBody.innerHTML = `
                                <div style="max-height: 500px; overflow:auto;">${tableHtml}</div>
                            `;
                        });
                }
                else {
                    modalBody.innerHTML = `<p>Preview not available for this file type.</p>`;
                }

                modalInstance.show();
            }
        });
    });
});
</script>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const approveBtn = document.getElementById("approveBtn");
    const correctionBtn = document.getElementById("correctionBtn");

    let isSubmitted = false;  // Prevent multiple submissions

    function collectFormData() {
        let documents = [];
        document.querySelectorAll("#documentTable tbody tr").forEach(row => {
            const radioSelected = row.querySelector('input[type="radio"]:checked');
            const remarks = row.querySelector('input[type="text"]').value.trim();
            const docNameCell = row.querySelector("td:nth-child(2)");
            const documentName = docNameCell ? docNameCell.innerText.trim() : null;

            if (radioSelected) {
                documents.push({
                    doc_key: radioSelected.name.replace("doc_", ""),
                    doc_name: documentName, 
                    status: radioSelected.value, 
                    remarks: remarks || null
                });
            }
        });
        return documents;
    }

    function isAnyCrossChecked() {
        return document.querySelectorAll('input[type="radio"][value="cross"]:checked').length > 0;
    }


    function isAllTickedWithRemarks() {
    let valid = true;

    document.querySelectorAll("tbody tr").forEach(row => {
        const ticked = row.querySelector('input[type="radio"][value="cross"]:checked');
        const remarkInput = row.querySelector('input[type="text"]');

        if (ticked) {
            if (!remarkInput || remarkInput.value.trim() === "") {
                valid = false;
                remarkInput.classList.add("is-invalid");
            } else {
                remarkInput.classList.remove("is-invalid");
            }
        }

        console.log("Radio buttons in this row:", row.querySelectorAll('input[type="radio"]'));
        console.log("Ticked in this row:", ticked);

    });

    return valid;
}


   function sendDataToAPI(actionType) {
        if (isSubmitted) return;

        isSubmitted = true;
        approveBtn.disabled = true;
        correctionBtn.disabled = true;

        const documentsData = collectFormData();

        fetch("/distributorList/<%=application_id%>", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                action: actionType,
                documents: documentsData
            })
        })
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                Swal.fire({
                    icon: data.type === "warning" ? "warning" : "error",
                    title: "Action Not Allowed",
                    text: data.message
                }).then(() => {
                    window.location.href = "/distributorList"; // redirect after OK
                });

                return;
            }

            Swal.fire({
                icon: "success",
                title: actionType === "approve" ? "Approved" : "Correction Requested",
                text: `The documents have been ${actionType === "approve" ? "approved" : "sent for correction"}.`
            }).then(() => {
                window.location.href = "/distributorList"; // redirect after OK
            });
        })
        .catch(error => {
            console.log(error);
            Swal.fire({
                icon: "error",
                title: "Error",
                text: "Something went wrong while submitting."
            }).then(() => {
                window.location.href = "/distributorList"; // redirect after OK
            });
        });
    }

    correctionBtn.addEventListener("click", function () {
        if (!isAnyCrossChecked()) {
            Swal.fire({
                icon: "warning",
                title: "Correction Not Allowed",
                text: "Nothing is marked for correction."
            });
            return;
        }

        if (!isAllTickedWithRemarks()) {
            Swal.fire({
                icon: "warning",
                title: "Missing Remark",
                text: "Please enter remarks for all checked items."
            });
            return;
        }

        sendDataToAPI("correction");
    });


    approveBtn.addEventListener("click", function () {
        if (isAnyCrossChecked()) {   
            Swal.fire({
                icon: "warning",
                title: "Approval Not Allowed",
                text: "Some documents have been marked for correction."
            });
            return; 
        }
        sendDataToAPI("approve");
    });
});

</script>

