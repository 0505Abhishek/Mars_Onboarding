<%- include("../shared/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
    .hidden { display: none; }
</style>
<style>
    .scroll-section {
      max-height: 600px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
  </style>

    <style>
    .dropdown-menu.show {
        display: block;
        max-height: 200px;
        overflow-y: auto;
    }
    </style>

   
<div class="container mt-5">
    <div class="card">
        <div class="card-body">
            <form id="multiStepForm" method="post" action="/edit_distributor?id=<%= distributorData.id %>">
                
                <div class="step" id="step1">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 style="color: #41378d;">Distributor</h2>
                        <a href="/distributor_draft_list" class="btn btn-primary">Draft List</a>
                    </div>
                
                    <div class="mb-3">
                        <label class="form-label fw-bold">Application Type</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="new" value="New" 
                                    <% if(distributorData.applicationType === 'New') { %> checked <% } %> required>
                                <label class="form-check-label" for="new">New</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="replacement" value="Replacement"
                                    <% if(distributorData.applicationType === 'Replacement') { %> checked <% } %> required>
                                <label class="form-check-label" for="replacement">Replacement</label>
                            </div>
                        </div>
                    </div>
                
                    <div class="mb-3" id="replacement-options-container" style="display: none;">
                        <label for="replacementOption" class="form-label fw-bold">Choose Replacement Option</label>
                        <select id="replacementOption" name="replacedFirmName" class="form-select">
                            <option value="">-- Select --</option>
                            <% replacementOptions?.forEach(function(option) { %>
                                <option 
                                    value="<%= option?.id %>" 
                                    <%= distributorData?.replacedFirmName == option?.id ? 'selected' : '' %>>
                                    <%= option?.firmName %> (<%= option?.distributor_code || option?.cdCode %>)
                                </option>
                            <% }) %>
                        </select>
                        <div class="text-danger error-message" id="replacementOptionError"></div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="dbType" class="form-label fw-bold">DB Channel</label>
                            <select class="form-select" id="dbType" name="dbType" required>
                                <option value="" disabled <%= !distributorData?.dbType ? "selected" : "" %>>Select DB Channel</option>
                                <% ['Hub', 'TT', 'MT', 'OOH', 'DCOM', 'Railway'].forEach(type => { %>
                                    <option value="<%= type %>" <%= distributorData?.dbType === type ? "selected" : "" %>><%= type %></option>
                                <% }) %>
                            </select>
                            <div class="text-danger error-message" id="dbTypeError"></div>
                        </div>
                    
                        <!-- Region -->
                        <div class="col-md-6 mb-3">
                            <label for="region_id" class="form-label fw-bold">Region</label>
                            <select class="form-select" name="region_id" id="region_id"
                                required
                                <%= distributorData?.isFlagstatus == 1 || distributorData?.invite_send_flag == 1 ? "disabled" : "" %>>
                                
                                <% if (distributorData?.region_id && distributorData?.region_name ) { %>
                                    <option value="<%= distributorData.region_id %>" selected>
                                        <%= distributorData.region_name %>
                                    </option>
                                <% } else { %>
                                    <option value="" selected disabled>Select Region</option>
                                <% } %>
                        
                                <% regions.forEach(region => { 
                                    if (region.id != distributorData?.region_id) { %>
                                        <option value="<%= region.id %>"><%= region.region_name %></option>
                                <%  } }) %>
                            </select>
                            <div class="text-danger error-message" id="RegionError"></div>
                        </div>
                        
                        
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3 position-relative">
                            <label for="territory_id" class="form-label fw-bold">Territory</label>
                        
                            <select 
                                class="form-select" 
                                id="territory_id" 
                                name="territory_id" 
                                required 
                                <%= distributorData?.invite_send_flag == 1 ? "disabled" : "" %>>
                                <option value="" disabled <%= !distributorData?.territory_id ? "selected" : "" %>>Select Territory</option>
                            </select>
                        
                            <% if (distributorData?.invite_send_flag == 1) { %>
                                <div class="territory-overlay" onclick="territoryBlockedAlert()" style="position:absolute; top:0; left:0; right:0; bottom:0; z-index:5; cursor:not-allowed;"></div>
                                <input type="hidden" name="territory_id" value="<%= distributorData.territory_id %>">
                            <% } %>
                        
                            <div class="text-danger error-message" id="TerritoryError"></div>
                        </div>
                                                               

                        <div class="col-md-6 mb-3 position-relative">
                            <label for="cityInput" class="form-label fw-bold">City</label>
                            <input type="text" class="form-control" id="cityInput" name="city" placeholder="Search city..." value="<%= distributorData.city %>" autocomplete="off" required>
                            <div class="dropdown-menu w-100" id="cityDropdown"></div>
                            <div class="text-danger error-message" id="cityError"></div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="SO_Terr" class="form-label fw-bold">SO Territory</label>
                            <select class="form-select" id="SO_Terr" name="SO_Terr" value="<%= distributorData.so_territory_name %>" required>
                                <option value="" selected disabled>Select SO Territory</option>
                            </select>
                            <div class="text-danger error-message" id="SO_TerrError"></div>
                        </div>    
                        <div class="col-md-6 mb-3">
                            <label for="SO_Name" class="form-label fw-bold">SO Name</label>
                            <input type="text" class="form-control" id="SO_Name" name="SO_Name" placeholder="Enter So's Name" value="<%= distributorData.so_name %>" required readonly>
                            <div class="text-danger error-message" id="SO_NameError"></div>
                        </div>
                    </div>
                
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="firmName" class="form-label fw-bold">Firm's Name</label>
                            <input type="text" class="form-control" id="firmName" name="firmName" value="<%= distributorData.firmName %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="distributorName" class="form-label fw-bold">Distributor's Name</label>
                            <input type="text" class="form-control" id="distributorName" name="distributorName" value="<%= distributorData.distributorName %>" required>
                        </div>
                    </div>
                
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label fw-bold">Email ID</label>
                            <input type="email" class="form-control" id="email" name="email" value="<%= distributorData.email %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="contactNumber" class="form-label fw-bold">Contact Number</label>
                            <input type="text" class="form-control" id="contactNumber" name="contactNumber" value="<%= distributorData.contactNumber %>" required>
                        </div>
                    </div>
                
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="experienceDistribution" class="form-label fw-bold">Years of Experience in Distribution Business</label>
                            <input 
                                type="number" 
                                class="form-control" 
                                id="experienceDistribution" 
                                name="experienceDistribution" 
                                value="<%= distributorData.experienceDistribution %>" 
                                required
                            >
                        </div>
                    
                        <div class="col-md-6 mb-3">
                            <label for="experienceFMCG" class="form-label fw-bold">Years of Experience in FMCG Distribution Business</label>
                            <input 
                                type="number" 
                                class="form-control" 
                                id="experienceFMCG" 
                                name="experienceFMCG" 
                                value="<%= distributorData.experienceFMCG %>" 
                                required
                            >
                        </div>
                    </div>
                    
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="outletsCovered" class="form-label fw-bold">Number of Outlets Covered</label>
                            <input 
                                type="number" 
                                class="form-control" 
                                id="outletsCovered" 
                                name="outletsCovered" 
                                value="<%= distributorData.outletsCovered %>" 
                                required
                            >
                        </div>
                        
                    
                        <div class="col-md-6 mb-3">
                            <label for="monthlyTurnover" class="form-label fw-bold">Total Monthly Turnover</label>
                            <input type="text" class="form-control" id="monthlyTurnover" name="monthlyTurnover" placeholder="Enter Monthly Turnover" required inputmode="decimal" value="<%= distributorData.monthlyTurnover || '' %>" />
                            <div class="text-danger error-message" id="monthlyTurnoverError"></div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                        <label for="FreightExpenses" class="form-label fw-bold">Freight Expenses %</label>
                        <input 
                            type="text" 
                            class="form-control" 
                            id="FreightExpenses" 
                            name="FreightExpenses" 
                            placeholder="Enter Freight Expenses %" 
                            value="<%= distributorData.FreightExpenses %>"
                            required
                        >
                        <div class="text-danger error-message" id="FreightExpensesError"></div>
                        </div>

                        
                        <div class="col-md-6 mb-3">
                            
                        </div>
                    </div>
                    
                
                    <div class="d-flex justify-content-between w-100">
                        <button style="width:150px" type="button" class="btn btn-primary" id="saveDraft">Save Draft</button>
                        <button style="width:150px" type="button" class="btn btn-primary next">Next</button>
                    </div>
                </div>
                
                
                <div class="step hidden" id="step2">
                    <div class="container mt-4">
                        <h2>Distributor Evaluation Form</h2>
                
                        <div class="scroll-section">
                            <h4>Commercial Structure</h4>
                        
                             <div class="mb-3">
                                <label class="form-label" for="stores_covered">How many stores does the DTR cover? (Mars Wrigley stores and non-Mars Wrigley stores)</label>
                                <input type="number" id="stores_covered" name="stores_covered" class="form-control" placeholder="Enter number of stores" min="0" value="<%= distributorData.stores_covered %>">
                             </div>

                            <div class="mb-3">
                                <label class="form-label" for="roi">What is the Annual Return of Investement (ROI %) of the Distributor?</label>
                                <input type="number" id="roi" name="roi" class="form-control" placeholder="Enter ROI percentage" value="<%= distributorData.roi || '' %>">
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="fmcg_companies">Does the distributor work with other FMCG companies?</label>
                                <select class="form-select" name="fmcg_companies" id="fmcg_companies">
                                    <option value="">Select</option>

                                    <option value="Yes" <%= distributorData.fmcg_companies === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.fmcg_companies === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>



                            <div class="mb-3">
                                <label class="form-label" for="fmcg_experience">How many years of FMCG experience does the distributor have?</label>
                                <input type="number" id="fmcg_experience" name="fmcg_experience" class="form-control" placeholder="Enter number of years" value="<%= distributorData.fmcg_experience %>" min="0">
                            </div>

                                                    
                            <div class="mb-3">
                                <label class="form-label" for="stores_mars">How many stores does the DB cover with Mars Wrigley?</label>
                                <input type="number" id="stores_mars" name="stores_mars" class="form-control" placeholder="Enter number of stores" value="<%= distributorData.stores_mars %>" min="0">
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="sales_reps">How many sales reps (DSR, KAE, ISR etc combined) does the distributor have?</label>
                                <input type="number" id="sales_reps" name="sales_reps" class="form-control" placeholder="Enter number of sales reps" value="<%= distributorData.sales_reps %>" min="0">    
                            </div>

                            <h4>Commercial WoW</h4></br>
                            <div class="mb-3">
                                <label class="form-label" for="selling_model">What selling model does the distributor operate with?</label>
                                <select id="selling_model" name="selling_model" class="form-control">
                                    <option value="">Select</option>
                                    <option value="Ready Stock Model" <%= distributorData.selling_model === 'Ready Stock Model' ? 'selected' : '' %>>Ready Stock Model</option>
                                    <option value="Order Fillment Model" <%= distributorData.selling_model === 'Order Fillment Model' ? 'selected' : '' %>>Order Fillment Model</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="mw_compliance">Is the distributor compliant with MW standards?</label>
                                <select class="form-select" id="mw_compliance" name="mw_compliance">
                                    <option value="">-- Select --</option>
                                    <option value="Yes" <%= distributorData.mw_compliance === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.mw_compliance === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>



                
                            <h4>Data Sharing</h4></br>

                            <div class="mb-3">
                                <label class="form-label" for="cost_structure">Does the distributor provide visibility on distributor cost structure to MW?</label>
                                <select class="form-select" id="cost_structure" name="cost_structure">
                                    <option value="">Select</option>
                                    <option value="Yes" <%= distributorData.cost_structure === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.cost_structure === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>

                                                    
                            <h4>Digital Readiness</h4></br>
                        
                            <div class="mb-3">
                            <label class="form-label">Does the DB have a data operator for DMS?</label>
                            <select class="form-select" name="data_operator" id="data_operator">
                                <option value="">-- Select an option --</option>
                                <option value="Yes" <%= distributorData.data_operator === "Yes" ? "selected" : "" %>>Yes</option>
                                <option value="No" <%= distributorData.data_operator === "No" ? "selected" : "" %>>No</option>
                            </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Does the DB have an internet connection for computer?</label>
                                <select class="form-select" name="internet_access" id="internet_access">
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.internet_access === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.internet_access === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Does the DB use a printer?</label>
                                <select class="form-select" name="printer_use" id="printer_use">
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.printer_use === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.printer_use === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>
                                    
                            <div class="mb-3">
                                <label class="form-label" for="dms_count">How many DMS for other companies including does the DB use?</label>
                                <input type="number" id="dms_count" name="dms_count" class="form-control" placeholder="Enter number of dms count" value="<%= distributorData.dms_count %>" min="0">    
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Which system is used to print final in-market bill?</label>
                                <select class="form-select" name="print_system" id="print_system">
                                    <option value="">-- Select an option --</option>
                                    <option value="Ivy DMS" <%= distributorData.print_system === "Ivy DMS" ? "selected" : "" %>>Ivy DMS</option>
                                    <option value="Tally" <%= distributorData.print_system === "Tally" ? "selected" : "" %>>Tally</option>
                                    <option value="Others" <%= distributorData.print_system === "Others" ? "selected" : "" %>>Others</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">If DB is not using Ivy DMS, is DB ok to integrate their system with Mars DMS for final in-market bill?</label>
                                <select class="form-select" name="mars_integration" id="mars_integration">
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.mars_integration === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.mars_integration === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>
                                                           
                            <h4>Logistics</h4></br>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the distributor have controlled temperature storage and transportation?</label>
                                <select class="form-select" name="temp_storage" id="temp_storage" required>
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes" <%= distributorData.temp_storage === "Yes" ? "selected" : "" %>>Yes</option>
                                    <option value="No" <%= distributorData.temp_storage === "No" ? "selected" : "" %>>No</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="delivery_time">What is the average delivery time for the distributor?</label>
                                <input type="text" id="delivery_time" name="delivery_time" class="form-control" placeholder="Enter delivery time in days" value="<%= distributorData.delivery_time %>" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="returns_rate">What is the average returns rate on total sales for the distributor? (in percentage)</label>
                                <input
                                    type="text"
                                    inputmode="decimal"
                                    id="returns_rate"
                                    name="returns_rate"
                                    class="form-control"
                                    placeholder="Enter returns percentage"
                                    value="<%= distributorData.returns_rate %>"
                                    pattern="^\d+(\.\d{1,2})?$"
                                    required
                                >
                            </div>


                
                            <h4>Partnership</h4></br>
                        
                            <div class="mb-3">
                                <label class="form-label" for="mw_sales_share">What is the share of MW sales on total confectionery sales for the distributor?</label>
                                <input type="number" id="mw_sales_share" name="mw_sales_share" class="form-control" placeholder="Enter percentage" value="<%= distributorData.mw_sales_share %>">
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="openness_change">What is the openness to change of the distributor?</label>
                                <select id="openness_change" name="openness_change" class="form-control">
                                    <option value="" >Select an option</option>
                                    <option value="Open" <%= distributorData.openness_change === "Open" ? "selected" : "" %>>Open</option>
                                    <option value="Somwehat Open" <%= distributorData.openness_change === "Somwehat Open" ? "selected" : "" %>>Somwehat Open</option>
                                    <option value="Not Open" <%= distributorData.openness_change === "Not Open" ? "selected" : "" %>>Not Open</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="confectionery_sales_share">What is the share of confectionery on total distributors' sales?</label>
                                <input type="number" id="confectionery_sales_share" name="confectionery_sales_share" class="form-control" placeholder="Enter percentage" value="<%= distributorData.confectionery_sales_share %>">
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="fte_dedicated">How many of distributors' FTEs are dedicated to MW?</label>
                                <input type="number" id="fte_dedicated" name="fte_dedicated" class="form-control" placeholder="Enter distributors' FTEs are dedicated to MW?" value="<%= distributorData.fte_dedicated %>">
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="mw_influence">What is the level of MW influence / sharing in the distributor's business planning process?</label>
                                <select id="mw_influence" name="mw_influence" class="form-control">
                                    <option value="" >Select an option</option>
                                    <option value="High" <%= distributorData.mw_influence === "High" ? "selected" : "" %>>High</option>
                                    <option value="Medium" <%= distributorData.mw_influence === "Medium" ? "selected" : "" %>>Medium</option>
                                    <option value="Low" <%= distributorData.mw_influence === "Low" ? "selected" : "" %>>Low</option>
                                </select>
                            </div>
                        

                            <h4>Platform to scale up</h4></br>
                        
                            <div class="mb-3">
                                <label class="form-label" for="capital_infrastructure">
                                    Does the distributor have sufficient capital and / or infrastructures to increase coverage?
                                </label>
                                <select id="capital_infrastructure" name="capital_infrastructure" class="form-control">
                                    <option value="">Select an option</option>
                                    <option value="Yes" <%= distributorData.capital_infrastructure === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.capital_infrastructure === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="dtr_nps_score">
                                    What is the DTR NPS score from their customers (stores)?
                                </label>
                                <input type="text" id="dtr_nps_score" name="dtr_nps_score" class="form-control" 
                                    placeholder="Enter numeric score" value="<%= distributorData.dtr_nps_score %>">
                            </div>
                        
                
                        </div>
                    
                    <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap">
                        <div class="d-flex gap-2 flex-wrap">
                            <button style="width: 160px;" type="button" class="btn btn-primary prev">Back</button>
                            <button style="width: 160px;" type="button" class="btn btn-primary" id="saveDraft">Save Draft</button>
                        </div>
                    
                        <% if (distributorData?.invite_send_flag !== 1) { %>
                            <div>
                                <button style="width: 160px;" type="submit" class="btn btn-primary">Send to RSEM</button>
                            </div>
                        <% } %>
                    </div>
                    
                                                     
                </div>                               
            </form>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  


<script>
    document.addEventListener("DOMContentLoaded", function () {
    
        function showToast(message) {
            Swal.fire({
                toast: true,
                position: "top-end", 
                icon: "warning",
                title: message,
                showConfirmButton: false,
                timer: 2000 
            });
        }
    
        document.querySelectorAll("#monthlyTurnover").forEach(input => {
            input.addEventListener("input", function () {
                this.value = this.value.replace(/[^0-9.]/g, "");

                let parts = this.value.split(".");

                if (parts.length > 2) {
                    showToast("Only one decimal point is allowed!");
                    this.value = parts[0] + "." + parts[1];
                }

                this.value = this.value.replace(/^0+(?!\.)/, "");

                if (this.value.startsWith(".")) {
                    showToast("Number cannot start with a dot!");
                    this.value = "";
                }

                let totalLength = this.value.replace(".", "").length;
                if (totalLength > 20) {
                    showToast("Maximum 20 digits allowed!");
                    this.value = this.value.slice(0, 21);
                }
            });
        });
                

       
        document.getElementById("contactNumber").addEventListener("input", function () {
            this.value = this.value.replace(/\D/g, "");
            // Prevent numbers starting with 0
            if (this.value.startsWith("0")) {
                showToast("Mobile number cannot start with 0!");
                this.value = "";
                return;
            }

            // Restrict length to 10 digits
            if (this.value.length > 10) {
                showToast("Contact Number cannot exceed 10 digits!");
                this.value = this.value.slice(0, 10);
            }
        });

    
    
        document.getElementById("email").addEventListener("blur", function () {
