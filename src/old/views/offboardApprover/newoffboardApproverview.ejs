<%- include("../shared/header.ejs") %>

<link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"
/>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link
  rel="stylesheet"
  href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css"
/>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<style>
  .hidden {
    display: none;
  }
</style>

<style>
  .scroll-section {
    max-height: 300px;
    overflow-y: auto;
    border: 1px solid #ccc;
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 5px;
    background: #f8f9fa;
  }
</style>

<style>
  .table-dark th {
    color: #0000a0 !important;
    background-color: #e0e0fc;
    border: 1px solid rgb(224, 203, 203);
  }

  #distributorTable tbody tr:nth-child(odd) td {
    background: #ffffff !important;
  }

  #distributorTable tbody tr:nth-child(even) td {
    background: #efefff !important;
  }
</style>

<style>
  /* Fullscreen overlay */
  .overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Modal box styling */
  .modal-box {
    background: white;
    border: 3px solid #0000a0;
    border-radius: 25px;
    padding: 30px;
    width: 500px;
    text-align: center;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
  }

  .toggle-group {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin: 10px 0 20px 0;
  }

  .toggle-group label {
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  input[type="checkbox"] {
    width: 40px;
    height: 20px;
    appearance: none;
    background: #ccc;
    border-radius: 20px;
    position: relative;
    outline: none;
    cursor: pointer;
    transition: background 0.3s;
  }

  input[type="checkbox"]::before {
    content: "";
    width: 18px;
    height: 18px;
    background: white;
    border-radius: 50%;
    position: absolute;
    top: 1px;
    left: 1px;
    transition: transform 0.3s;
  }

  input[type="checkbox"]:checked {
    background: #14e651;
  }

  input[type="checkbox"]:checked::before {
    transform: translateX(20px);
  }

  /* Submit Button */
  .submit-btn {
    background-color: #007bff;
    color: white;
    padding: 12px 25px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-weight: bold;
  }

  .submit-btn:hover {
    background-color: #0056b3;
  }
</style>

<style>
  .distributor-field {
    margin-top: 20px;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
  }

  .distributor-field label {
    font-weight: bold;
    margin-bottom: 6px;
    font-size: 14px;
  }

  .distributor-field input[type="text"] {
    padding: 8px 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .distributor-field input[type="text"]:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
  }

  .hidden-col {
    display: none;
  }

  .close {
    float: right;
    font-size: 14px;
    cursor: pointer;
    color: #888;
    padding-top: 5px;
  }

  .resignation-header {
    background: #0d2bb3;
    padding: 25px;
    color: #fff;
    text-align: center;
    font-weight: bold;
    border-radius: 8px 8px 0 0;
  }

  .resignation-body {
    padding: 30px;
  }

  .reason-box {
    border: 1px solid #0d2bb3;
    padding: 10px 15px;
    border-radius: 4px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .btn-primary-custom {
    background: #0d2bb3;
    border: none;
    padding: 8px 25px;
    color: #fff;
    border-radius: 4px;
  }

  .btn-outline-custom {
    border: 1px solid #0d2bb3;
    padding: 8px 25px;
    border-radius: 4px;
    background: #fff;
    color: #0d2bb3;
  }

  .resignationModal {
    width: 687px !important;
    padding: 1px !important;
  }

  .back-btn{
    width: 15%;
    margin-bottom: 12px;
    
  }

  .back-btn a button{
    background: #0000A0;
    color: #ffff;
    border-radius: 10px;
  }
</style>

<div class="container mt-4">
   <div class="back-btn">
      <a href="/newoffboardApprover">
        <button>BACK</button>
      </a>
    </div>
  <div class="table-responsive">
   
    <div class="mb-3 d-flex justify-content-end d-none">
      <div>
        <label for="statusFilter" class="form-label">Filter by Status:</label>
        <select
          id="statusFilter"
          class="form-select"
          onchange="filterTableByStatus()"
        >
          <option value="All">All</option>
          <option value="Pending">Pending</option>
          <option value="Approved">Approved</option>
          <option value="Rejected">Rejected</option>
        </select>
      </div>
    </div>

    <table id="distributorTable" class="table table-hover table-bordered">
      <thead class="table-dark">
        <tr>
          <th>Unique Application Code</th>
          <th>Firm Name</th>
          <th>Email</th>
          <th>Action</th>
          <th>Remark</th>
          <th>Action By Role</th>
          <th>Start Date</th>
        </tr>
      </thead>

      <tbody>
        <% if (data && data.length > 0) { %> <% data.forEach(row => { %>

        <tr>
          <td><%= row.mars_code %></td>
          <td><%= row.firmName %></td>
          <td><%= row.email %></td>

          <td><%= row.action ? row.action : '-' %></td>

          <td><%= row.remarks ? row.remarks : '-' %></td>

          <td><%= row.approver_role ? row.approver_role : '-' %></td>

          <td>
            <%= row.action_date ? new
            Date(row.action_date).toISOString().slice(0, 10) : '-' %>
          </td>
        </tr>

        <% }) %> <% } else { %>

        <tr>
          <td colspan="7" class="text-center">No record found.</td>
        </tr>

        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  $(document).ready(function () {
    if ($("#distributorTable tbody tr").length > 1) {
      $("#distributorTable").DataTable({
        paging: true,
        searching: true,
        ordering: true,
        info: true,
        lengthMenu: [5, 10, 25, 50],
        pageLength: 10,
      });
    }
  });
</script>

<script>
  function confirmDelete(id) {
    Swal.fire({
      title: "Are you sure?",
      text: "You won't be able to revert this!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#d33",
      cancelButtonColor: "#3085d6",
      confirmButtonText: "Yes, delete it!",
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = `/edit_distributor/delete_distributor?id=${id}`;
      }
    });
  }
</script>


<script>
  function filterTableByStatus() {
    const selectedStatus = document.getElementById("statusFilter").value;
    const rows = document.querySelectorAll("#distributorTable tbody tr");

    rows.forEach((row) => {
      const rowStatus = row.getAttribute("data-status");
      if (selectedStatus === "All" || rowStatus === selectedStatus) {
        row.style.display = "";
      } else {
        row.style.display = "none";
      }
    });
  }
</script>

