<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Distributor Resignation Form</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
      body {
        background-color: #f8f9fa;
        font-family: "Segoe UI", sans-serif;
      }

      .header {
        background-color: #0000a8;
        color: white;
        padding: 20px 0;
        text-align: center;
        font-size: 2rem;
        font-weight: bold;
        letter-spacing: 2px;
      }

      .form-container {
        background-color: #f6f7fb;
        padding: 30px;
        border-radius: 15px;
        max-width: 700px;
        margin: 40px auto;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      }

      .form-heading {
        font-weight: 600;
        text-align: center;
        color: #2b2b8f;
        margin-bottom: 10px;
      }

      .form-subtext {
        text-align: center;
        color: #5a5a89;
        margin-bottom: 30px;
        font-size: 1rem;
      }

      .form-check-input {
        appearance: none;
        -webkit-appearance: none;
        border: 2px solid #0000a8;
        width: 1.5em;
        height: 1.5em;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        position: relative;
        background-color: #fff;
      }

      .form-check-input:checked {
        background-color: #0000a8;
        border-color: #0000a8;
      }

      .form-check-input:checked::after {
        content: "✓";
        color: white;
        font-weight: bold;
        font-size: 1.2em;
        position: absolute;
        top: -4px;
        left: 3px;
      }

      .form-label {
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class="header">MARS WRIGLEY</div>

    <div class="container mt-5">
      <!-- Notification / Error Message -->
      <% if (notification) { %>
      <div class="text-center">
        <div
          class="alert alert-<%= notification.type === 'success' ? 'success' : 'danger' %> alert-dismissible fade show"
          role="alert"
          style="max-width: 700px; margin: 0 auto"
        >
          <strong>
            <%= notification.type === 'success' ? 'Success!' : 'Error!' %>
          </strong>
          <%= notification.message %>
          <button
            type="button"
            class="btn-close"
            data-bs-dismiss="alert"
            aria-label="Close"
          ></button>
        </div>

        <% if (notification.type === 'success') { %>
        <div class="text-center mt-4">
          <div
            class="alert alert-success"
            style="max-width: 700px; margin: 0 auto"
          >
            <h4>Thank you!</h4>
            <p>Your resignation has been submitted successfully.</p>
          
          </div>
        </div>
        <% } %>
      </div>
      <% } else { %>
      <!-- Valid Case - Show Form -->
      <div class="form-container">
        <h2 class="form-heading">Distributor Resignation Form</h2>
        <p class="form-subtext">
          We’re sorry to see you go, and thank you for being a valued part of
          Mars Wrigley.<br />
          Kindly fill in the following details so we can begin processing your
          resignation smoothly.
        </p>

        <form
          id="resignationForm"
          method="POST"
          action="/newoffboardApprover/saveResignation"
          enctype="multipart/form-data"
        >
          <input
            type="hidden"
            name="applicationId"
            value="<%= applicationId %>"
          />
          <input type="hidden" name="token" value="<%= token %>" />

          <div
            class="p-4 mb-4 rounded"
            style="border: 1px solid #ccc; background-color: #f9f9f9"
          >
            <div class="mb-3">
              <label for="firmName" class="form-label">Firm's Name</label>
              <input
                type="text"
                class="form-control"
                id="firmName"
                name="firmName"
                readonly
                value="<%= distributor ? distributor.firmName : '' %>"
              />
            </div>

            <div class="mb-3">
              <label for="distributorName" class="form-label"
                >Distributor's Name</label
              >
              <input
                type="text"
                class="form-control"
                id="distributorName"
                name="distributorName"
                value="<%= distributor ? distributor.distributorName : '' %>"
                readonly
              />
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Email ID</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                value="<%= distributor ? distributor.email : '' %>"
                readonly
              />
            </div>

            <div class="mb-3">
              <label for="contact_no" class="form-label">Contact No.</label>
              <input
                type="tel" pattern="[6-9]{1}[0-9]{9}" minlength="10" maxlength="10"
                class="form-control"
                id="contact_no"
                name="contact_no"
                value="<%= distributor ? distributor.contactNumber : '' %>"
                readonly
              />
            </div>

            <div class="mb-3">
              <label class="fw-bold mt-2 mb-1"
                >Please upload the No Objection Certificate (NOC)</label
              >
              <input
                type="file"
                class="form-control mb-3"
                accept=".pdf"
                name="nocFile"
              />
            </div>

            <div class="mb-3">
              <label class="fw-bold mt-2 mb-1"
                >Please upload the Resignation Letter</label
              >
              <input
                type="file"
                class="form-control mb-3"
                accept=".pdf"
                name="regionFile"
              />
            </div>
          </div>

          <div
            class="p-4 mb-4 rounded"
            style="border: 1px solid #ccc; background-color: #f9f9f9"
          >
            <div class="mb-4">
              <label for="gsvAverage" class="form-label">
                A. Average Business Value in GSV Per Period (L3P Average)
              </label>
              <input
                type="text"
                class="form-control"
                id="gsvAverage"
                name="gsvAverage"
                placeholder="Ex. 3 Lakh"
                required
              />
             <p class="form-text text-muted">
              Note: Enter amount in this format, e.g., 3,12,000 (3 Lakh)
             </p>

            </div>

            <label class="form-label">
              B. Please select Reason to exit
              <span class="text-muted">(Multiple can be selected)</span>
            </label>

            <!-- Tera poora checkbox section same -->
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span>1. Low turnover</span>
              <input
                class="form-check-input"
                type="checkbox"
                value="Low turnover"
                name="low_turnover"
              />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <span>2. Low ROI%</span>
              <input
                class="form-check-input"
                type="checkbox"
                value="Low ROI%"
                name="low_roi"
              />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <span>3. Limitation in Investment</span>
              <input
                class="form-check-input"
                type="checkbox"
                value="Limitation in Investment"
                name="limitation_in_investment"
              />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <span>4. DB going out of business</span>
              <input
                class="form-check-input"
                type="checkbox"
                value="DB going out of business"
                name="db_going_out_of_business"
              />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <span>5. Increasing Cost</span>
              <input
                class="form-check-input"
                type="checkbox"
                value="Increasing Cost"
                name="increasing_cost"
              />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <span>
                6. Not ready for additional infrastructure needed
                (warehouse/delivery vehicle, etc)
              </span>
              <input
                class="form-check-input"
                type="checkbox"
                value="Not ready for additional infrastructure needed (warehouse/delivery vehicle, etc)"
                name="not_ready_for_additional_infrastructure"
              />
            </div>

            <div class="d-flex justify-content-center mt-3">
              <button
                type="submit"
                class="btn btn-primary"
                style="width: 150px"
              >
                Submit
              </button>
            </div>
          </div>
        </form>
      </div>
      <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Character Limit Warning -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const fieldLimits = {
          gsvAverage: 20,
        };

        const inputFields = document.querySelectorAll("input[type='text']");

        inputFields.forEach((input) => {
          input.addEventListener("input", function () {
            const fieldId = input.id;
            const fieldValue = input.value;

            if (
              fieldLimits[fieldId] &&
              fieldValue.length > fieldLimits[fieldId]
            ) {
              input.value = fieldValue.slice(0, fieldLimits[fieldId]);

              Swal.fire({
                icon: "warning",
                title: "Input Limit Exceeded",
                text: `The maximum length for this field is ${fieldLimits[fieldId]} characters.`,
                position: "top-end",
                toast: true,
                showConfirmButton: false,
                timer: 3000,
              });
            }
          });
        });
      });
    </script>

    <!-- At least one reason validation -->
    <script>
      document
        .getElementById("resignationForm")
        ?.addEventListener("submit", function (e) {
          const checkboxes = document.querySelectorAll(
            'input[name="low_turnover"], input[name="low_roi"], input[name="limitation_in_investment"], input[name="db_going_out_of_business"], input[name="increasing_cost"], input[name="not_ready_for_additional_infrastructure"]'
          );

          const atLeastOneChecked = Array.from(checkboxes).some(
            (cb) => cb.checked
          );

          if (!atLeastOneChecked) {
            e.preventDefault();
            Swal.fire({
              icon: "warning",
              title: "Required!",
              text: "Please select at least one reason for exit before submitting.",
              confirmButtonColor: "#3085d6",
            });
          }
        });
    </script>
  </body>
</html>
