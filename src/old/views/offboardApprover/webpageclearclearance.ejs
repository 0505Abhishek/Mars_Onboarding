<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Distributor Resignation Form</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        background-color: #f8f9fa;
        font-family: "Segoe UI", sans-serif;
      }

      .header {
        background-color: #0000a8;
        color: white;
        padding: 20px 0;
        text-align: center;
        font-size: 2rem;
        font-weight: bold;
        letter-spacing: 2px;
      }

      .form-container {
        background-color: #f6f7fb;
        padding: 30px;
        border-radius: 15px;
        max-width: 700px;
        margin: 40px auto;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      }

      .form-heading {
        font-weight: 600;
        text-align: center;
        color: #2b2b8f;
        margin-bottom: 10px;
      }

      .form-subtext {
        text-align: center;
        color: #5a5a89;
        margin-bottom: 30px;
        font-size: 1rem;
      }
      .form-check-input {
        appearance: none;
        -webkit-appearance: none;
        border: 2px solid #0000a8;
        width: 1.5em;
        height: 1.5em;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        position: relative;
        background-color: #fff;
      }

      .form-check-input:checked {
        background-color: #0000a8;
        border-color: #0000a8;
      }

      .form-check-input:checked::after {
        color: white;
        font-size: 1em;
        position: absolute;
        top: 0;
        left: 3px;
      }

      .form-label {
        font-weight: 500;
      }

      header.cc-header {
        background: #1a73e8;
        color: #fff;
        padding: 15px 20px;
        font-size: 20px;
        font-weight: bold;
      }

      .cc-container {
        max-width: 900px;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }

      .cc-section-title {
        font-size: 18px;
        margin-bottom: 10px;
        font-weight: bold;
      }

      .cc-box {
        border: 1px solid #ddd;
        padding: 15px;
        border-radius: 6px;
        background: #fafafa;
        margin-bottom: 20px;
      }

      .cc-input,
      .cc-select,
      .cc-textarea {
        border-radius: 5px;
        border: 1px solid #ccc;
        padding: 10px;
        width: 100%;
      }

      .cc-btn-primary {
        background: #007bff;
        color: #fff;
        padding: 10px 18px;
        border: none;
        border-radius: 5px;
      }
    </style>
  </head>
  <body>
    <div class="header">MARS WRIGLEY</div>
    <% if(!get_application_status || (get_application_status.status !== 'APPROVED' && get_application_status.status !== 'REJECTED')) { %>
    <div class="form-container">
      <h2 class="form-heading">Claim Clearance</h2>

      <div class="cc-container">
        <h3 class="cc-section-title">DB Claim Summary</h3>
        <div class="cc-box">
          <p class="d-none"><strong>Claim Raised By:</strong> XYZ Distributor</p>
          <p><strong>Claim Type:</strong> <%= get_data?.type %></p>
          <p><strong>Claim Amount:</strong>  <%= get_data?.amount %></p>
        </div>

        <h3 class="cc-section-title">DB Response</h3>
        <form action="">
          <div class="cc-box">
            <label class="fw-bold">Do You Approve This Claim?</label>
            <select id="dbApproval" class="cc-select mb-3">
              <option value="">Select</option>
              <option value="approve">Approve</option>
              <option value="decline">Decline</option>
            </select>

            <div id="declineSection" style="display: none">
              <label class="fw-bold">Enter Amount</label>

              <div class="row">
                <div class="col">
                  <input
                    type="number"
                    id="counterAmount"
                    class="cc-input"
                    placeholder="Enter amount"
                  />
                </div>
                <div class="col">
                  <select id="counterUnit" class="cc-select">
                    <option value="Thousand">Thousand</option>
                    <option value="Lakh">Lakh</option>
                    <option value="Crore">Crore</option>
                  </select>
                </div>
              </div>

              <label class="fw-bold mt-2">Enter Reason</label>
              <textarea
                id="counterReason"
                class="cc-textarea"
                rows="3"
                placeholder="Enter reason"
              ></textarea>
            </div>

            <button class="cc-btn-primary mt-3" onclick="submitDbResponse()">
              Submit
            </button>
          </div>
        </form>

        <div id="forwardSection" style="display: none">
          <h3 class="cc-section-title">Forwarded to ASM / DT Team</h3>
          <div class="cc-box">
            <p><strong>Distributor declined the claim.</strong></p>
            <p><strong>Counter Amount:</strong> <span id="fwdAmount"></span></p>
            <p><strong>Reason:</strong> <span id="fwdReason"></span></p>
            <p>This has been forwarded for verification.</p>
          </div>
        </div>
      </div>
    </div>
    <% } else { %>
      <div class="form-container">
        <div class="alert alert-info text-center">
          <h4>Application Status: <strong><%= get_application_status.status %></strong></h4>
          <p>This application has already been processed and cannot be cleared again.</p>
        </div>
      </div>
    <% } %>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      const approval = document.getElementById("dbApproval");
      const declineSection = document.getElementById("declineSection");
      const forwardSection = document.getElementById("forwardSection");

      approval.addEventListener("change", function () {
        declineSection.style.display =
          this.value === "decline" ? "block" : "none";
      });

      function submitDbResponse() {
        if (approval.value === "") {
          alert("Please select approval status.");
          return;
        }

        const application_id = "<%= get_data.application_id %>";
        const data = {
          approval: approval.value,
          application_id: application_id
        };

        if (approval.value === "decline") {
          let amount = document.getElementById("counterAmount").value.trim();
          let reason = document.getElementById("counterReason").value.trim();
          let unit = document.getElementById("counterUnit").value;

          if (!amount || !reason) {
            alert("Please enter both amount and reason.");
            return;
          }

          data.amount = amount;
          data.reason = reason;
          data.unit = unit;
        }

        fetch('/newoffboardApprover/submitDbResponse', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
          if (result.type === 'success') {
            alert(result.message);
            // Reload the page to show updated status
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            alert(result.message || 'Something went wrong');
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('Something went wrong. Please try again.');
        });
      }
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const fieldLimits = {
          gsvAverage: 20,
        };

        const inputFields = document.querySelectorAll("input");

        inputFields.forEach((input) => {
          input.addEventListener("input", function () {
            const fieldId = input.id;
            const fieldValue = input.value;

            if (
              fieldLimits[fieldId] &&
              fieldValue.length > fieldLimits[fieldId]
            ) {
              input.value = fieldValue.slice(0, fieldLimits[fieldId]);

              Swal.fire({
                icon: "warning",
                title: "Input Limit Exceeded",
                text: `The maximum length for '${
                  input.labels?.[0]?.textContent || fieldId
                }' is ${fieldLimits[fieldId]} characters.`,
                position: "top-end",
                toast: true,
                showConfirmButton: false,
                timer: 3000,
              });
            }
          });
        });
      });
    </script>

    <script>
      document
        .getElementById("resignationForm")
        .addEventListener("submit", function (e) {
          const checkboxes = document.querySelectorAll(
            'input[name="low_turnover"], input[name="low_roi"], input[name="limitation_in_investment"], input[name="db_going_out_of_business"], input[name="increasing_cost"], input[name="not_ready_for_additional_infrastructure"]'
          );

          const atLeastOneChecked = Array.from(checkboxes).some(
            (checkbox) => checkbox.checked
          );

          if (!atLeastOneChecked) {
            e.preventDefault();

            Swal.fire({
              icon: "warning",
              title: "Oops!",
              text: "Please select at least one reason for exit before submitting.",
              confirmButtonColor: "#3085d6",
            });
          } else {
       
            const submitBtn = document.querySelector(
              "#resignationForm button[type='submit']"
            );
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.innerText = "Submitting..."; 
            }
          }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
