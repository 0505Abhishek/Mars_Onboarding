<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Distributor Resignation Form</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        background-color: #f8f9fa;
        font-family: "Segoe UI", sans-serif;
      }

      .header {
        background-color: #0000a8;
        color: white;
        padding: 20px 0;
        text-align: center;
        font-size: 2rem;
        font-weight: bold;
        letter-spacing: 2px;
      }

      .form-container {
        background-color: #f6f7fb;
        padding: 30px;
        border-radius: 15px;
        max-width: 700px;
        margin: 40px auto;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      }

      .form-heading {
        font-weight: 600;
        text-align: center;
        color: #2b2b8f;
        margin-bottom: 10px;
      }

      .form-subtext {
        text-align: center;
        color: #5a5a89;
        margin-bottom: 30px;
        font-size: 1rem;
      }
      .form-check-input {
        appearance: none;
        -webkit-appearance: none;
        border: 2px solid #0000a8;
        width: 1.5em;
        height: 1.5em;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        position: relative;
        background-color: #fff;
      }

      .form-check-input:checked {
        background-color: #0000a8;
        border-color: #0000a8;
      }

      .form-check-input:checked::after {
        color: white;
        font-size: 1em;
        position: absolute;
        top: 0;
        left: 3px;
      }

      .form-label {
        font-weight: 500;
      }

      header.cc-header {
        background: #1a73e8;
        color: #fff;
        padding: 15px 20px;
        font-size: 20px;
        font-weight: bold;
      }

      .cc-container {
        max-width: 900px;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }

      .cc-section-title {
        font-size: 18px;
        margin-bottom: 10px;
        font-weight: bold;
      }

      .cc-box {
        border: 1px solid #ddd;
        padding: 15px;
        border-radius: 6px;
        background: #fafafa;
        margin-bottom: 20px;
      }

      .cc-input,
      .cc-select,
      .cc-textarea {
        border-radius: 5px;
        border: 1px solid #ccc;
        padding: 10px;
        width: 100%;
      }

      .cc-btn-primary {
        background: #007bff;
        color: #fff;
        padding: 10px 18px;
        border: none;
        border-radius: 5px;
      }

      .section-title {
        font-weight: 600;
        margin-bottom: 10px;
      }
      .file-box {
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: #fafafa;
      }
    </style>
  </head>
  <body>
    <div class="header">MARS WRIGLEY</div>

   <% if (!get_file || get_file.status !== 'Approved') { %>

<div class="form-container">
  <h2 class="form-heading">F&F Acceptance</h2>

  <div
    class="page-card"
    data-application-id="<%= get_file && get_file.application_id ? get_file.application_id : '' %>"
  >
    <div class="mb-4">
      <h5 class="section-title">Download F&F</h5>
      <div class="file-box">
        <% if (get_file && get_file.fnf_file_path) { %>
          <% const filename = get_file.fnf_file_path.split('/').pop(); %>
          <a
            href="/newoffboardApprover/download-fnf/<%= filename %>"
            class="btn btn-outline-primary btn-sm"
            download
          >
            Download F&F Letter
          </a>
        <% } else { %>
          <p class="text-muted">No F&F file available</p>
        <% } %>
      </div>
    </div>

    <div class="mb-4">
      <h5 class="section-title">Upload Signed F&F Letter</h5>
      <input type="file" id="signedFnf" class="form-control" />
    </div>

    <div class="mb-4">
      <h5 class="section-title">Upload Cheque</h5>
      <input type="file" id="chequeUpload" class="form-control" />
    </div>

    <div class="text-center mt-4">
      <button class="btn btn-success px-4 w-100" id="submitFNF">
        Submit
      </button>
    </div>
  </div>
</div>

<% } else { %>

<div class="alert alert-success text-center mt-4">
  <strong>F&F Already Approved</strong>
</div>

<% } %>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("submitFNF").addEventListener("click", async function() {
        const signedFnf = document.getElementById("signedFnf").files[0];
        const chequeUpload = document.getElementById("chequeUpload").files[0];
        
        if (!signedFnf) {
          Swal.fire({
            icon: "warning",
            title: "Missing File",
            text: "Please upload the signed F&F letter",
          });
          return;
        }
        
        const formData = new FormData();
        formData.append("signedFnf", signedFnf);
        if (chequeUpload) {
          formData.append("chequeUpload", chequeUpload);
        }
        
        // Add application_id if available from get_file
        const pageCard = document.querySelector('.page-card');
        const applicationId = pageCard ? pageCard.dataset.applicationId : null;
        if (applicationId) {
          formData.append("application_id", applicationId);
        } else {
        
          const urlParams = new URLSearchParams(window.location.search);
          const urlApplicationId = urlParams.get('application_id') || urlParams.get('id');
          if (urlApplicationId) {
            formData.append("application_id", urlApplicationId);
          }
        }
        
        try {
          const response = await fetch("/newoffboardApprover/submitFnfForm", {
            method: "POST",
            body: formData
          });
          
          const result = await response.json();
          
          if (result.type === "success") {
            Swal.fire({
              icon: "success",
              title: "Success!",
              text: result.message,
            }).then(() => {
              // Optionally redirect or clear form
              document.getElementById("signedFnf").value = "";
              document.getElementById("chequeUpload").value = "";
            });
          } else {
            Swal.fire({
              icon: "error",
              title: "Error!",
              text: result.message,
            });
          }
        } catch (error) {
          console.error("Submit error:", error);
          Swal.fire({
            icon: "error",
            title: "Error!",
            text: "Something went wrong. Please try again.",
          });
        }
      });
    </script>
    <script>
      const approval = document.getElementById("dbApproval");
      const declineSection = document.getElementById("declineSection");
      const forwardSection = document.getElementById("forwardSection");

      approval.addEventListener("change", function () {
        declineSection.style.display =
          this.value === "decline" ? "block" : "none";
      });

      function submitDbResponse() {
        if (approval.value === "") {
          alert("Please select approval status.");
          return;
        }

        if (approval.value === "approve") {
          alert("Claim Approved Successfully!");
          return;
        }

        let amount = document.getElementById("counterAmount").value.trim();
        let reason = document.getElementById("counterReason").value.trim();
        let unit = document.getElementById("counterUnit").value;

        if (!amount || !reason) {
          alert("Please enter amount.");
          return;
        }

        document.getElementById("fwdAmount").textContent = amount + " " + unit;
        document.getElementById("fwdReason").textContent = reason;

        forwardSection.style.display = "block";

        alert("Declined. Forwarded to ASM/DT Team.");
      }
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const fieldLimits = {
          gsvAverage: 20,
        };

        const inputFields = document.querySelectorAll("input");

        inputFields.forEach((input) => {
          input.addEventListener("input", function () {
            const fieldId = input.id;
            const fieldValue = input.value;

            if (
              fieldLimits[fieldId] &&
              fieldValue.length > fieldLimits[fieldId]
            ) {
              input.value = fieldValue.slice(0, fieldLimits[fieldId]);

              Swal.fire({
                icon: "warning",
                title: "Input Limit Exceeded",
                text: `The maximum length for '${
                  input.labels?.[0]?.textContent || fieldId
                }' is ${fieldLimits[fieldId]} characters.`,
                position: "top-end",
                toast: true,
                showConfirmButton: false,
                timer: 3000,
              });
            }
          });
        });
      });
    </script>

    <script>
      document
        .getElementById("resignationForm")
        .addEventListener("submit", function (e) {
          const checkboxes = document.querySelectorAll(
            'input[name="low_turnover"], input[name="low_roi"], input[name="limitation_in_investment"], input[name="db_going_out_of_business"], input[name="increasing_cost"], input[name="not_ready_for_additional_infrastructure"]'
          );

          const atLeastOneChecked = Array.from(checkboxes).some(
            (checkbox) => checkbox.checked
          );

          if (!atLeastOneChecked) {
            e.preventDefault();

            Swal.fire({
              icon: "warning",
              title: "Oops!",
              text: "Please select at least one reason for exit before submitting.",
              confirmButtonColor: "#3085d6",
            });
          } else {
            // Disable the submit button after valid submission
            const submitBtn = document.querySelector(
              "#resignationForm button[type='submit']"
            );
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.innerText = "Submitting..."; // Optional: change text
            }
          }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
