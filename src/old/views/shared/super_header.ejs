<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta http-equiv="Content-Language" content="en">
    <title>Admin-MARS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="../images/ficon (1).png">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@mdi/font/css/materialdesignicons.min.css">  

    <link rel="stylesheet" href="/css/style.css"> 
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@mdi/font/css/materialdesignicons.min.css">  
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
   
   

    <style>
    .menu-icon {
        font-size: 24px; 
    }

    .logo-src1{
    font-family: Arial, sans-serif;
    font-size: 50px;
    font-weight: bold;
    color: white;
    padding: 10px 20px;
    display: inline-block;
    border-radius: 5px;
    }
    .app-header__content{
    background-color: #0000A0; 
    }
    .app-header__content {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: 20px;
    }

    .app-header__content i {
        font-size: 24px;
        color: white;
        cursor: pointer;
    }

    </style>

    <style>
    .nav-link {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: white;
        padding: 10px;
        white-space: nowrap;
        transition: 0.3s;
    }

    .nav-link.active {
        background-color: white;
        color: #0000A0 !important;
        border-radius: 5px;
    }

    .icon-container {
        display: flex;
        align-items: center;
    }

    .nav-icon {
        width: 24px;
        height: 24px;
        display: block;
    }

    .active-icon {
        display: none;
    }

    .nav-link.active .default-icon {
        display: none;
    }

    .nav-link.active .active-icon {
        display: block;
    }

    .icon-container .menu-title{
      padding-left:10px;
    }
    
    .nav-link:hover .default-icon {
    display: none;
    }

    .nav-link:hover .active-icon {
        display: block;
    }


    </style>
    
    <style>
        .user-info {
            display: none;
            position: absolute;
            top: 50px;
            right: 10px;
            background: white;
            color: black;
            padding: 10px;
            border-radius: 5px;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
            width: 200px;
            z-index: 9;
        }

        .user-container {
            position: relative;
            text-align: center;
            cursor: pointer;
        }

        .user-name {
            color: white;
            font-size: 14px;
            margin-top: 5px;
        }
    </style> 
   
<body id="element">

    <div class="app-container app-theme-white body-tabs-shadow fixed-sidebar fixed-header">
      <div class="app-header header-shadow">
        <!-- Logo and Sidebar Toggle -->
        <div class="app-header__logo text-center">
            <div class="logo-src1">MARS</div>
            <!-- <div class="header__pane ml-auto">
                <button type="button" class="hamburger close-sidebar-btn hamburger--elastic" data-class="closed-sidebar">
                    <span class="hamburger-box">
                        <span class="hamburger-inner"></span>
                    </span>
                </button>
            </div> -->
        </div>
    
        <!-- Mobile Menu Toggle -->
        <div class="app-header__mobile-menu">
            <button type="button" class="hamburger hamburger--elastic mobile-toggle-nav">
                <span class="hamburger-box">
                    <span class="hamburger-inner"></span>
                </span>
            </button>
        </div>
    
        <!-- Header Menu Toggle -->
        <div class="app-header__menu">
            <button type="button" class="btn-icon btn-icon-only btn btn-primary custom-btn btn-sm mobile-toggle-header-nav">
                <span class="btn-icon-wrapper">
                    <i class="fa fa-ellipsis-v"></i>
                </span>
            </button>
        </div>
    
        <!-- Header Content -->
        <div class="app-header__content">
            <div class="user-container" onclick="toggleUserInfo()">
                <i class="fa-regular fa-circle-user" style="font-size: 24px; color: white;"></i>
                <div class="user-name" id="userName">
                    <%= token && token[0] ? token[0].employeename : 'Admin' %>
                </div>
            </div>
            
            <div class="user-info" id="userInfo">
                <p><strong>Name:</strong> <%= token && token[0] ? token[0].employeename : 'Admin' %></p>
                <p><strong>Role:</strong> <%= token && token[0] ? token[0].role : 'N/A' %></p>
            </div>
        </div>
      
      </div>
    
        <div class="app-main">
            <div class="app-sidebar sidebar-shadow">
                <div class="app-header__logo">
                    <div class="logo-src"></div>
                    <div class="header__pane ml-auto">
                        <div>
                            <button type="button" class="hamburger close-sidebar-btn hamburger--elastic"
                                data-class="closed-sidebar">
                                <span class="hamburger-box">
                                    <span class="hamburger-inner"></span>
                                </span>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="app-header__mobile-menu">
                    <div>
                        <button type="button" class="hamburger hamburger--elastic mobile-toggle-nav">
                            <span class="hamburger-box">
                                <span class="hamburger-inner"></span>
                            </span>
                        </button>
                    </div>
                </div>
                <div class="app-header__menu">
                    <span>
                        <button type="button"
                            class="btn-icon btn-icon-only btn btn-primary custom-btnbtn-sm mobile-toggle-header-nav">
                            <span class="btn-icon-wrapper">
                                <i class="fa fa-ellipsis-v fa-w-6"></i>
                            </span>
                        </button>
                    </span>
                </div>
                <div class="scrollbar-sidebar">
                  <div class="app-sidebar__inner">
                    <ul class="vertical-nav-menu">
                        <% token.forEach(function(item) { %>
                            <% if (item.view === 1) { %>
                                <li class="nav-item">
                                    <% if (item.module_name === 'DASHBOARD') { %>
                                        <a class="nav-link" href="/SuperDashboard">
                                            <div class="icon-container">
                                            <img class="nav-icon default-icon" src="../../public/images/Group -1.png" alt="Dashboard Icon">
                                            <img class="nav-icon active-icon" src="../../public/images/Group 1336.png" alt="Dashboard Icon">
                                            <span class="menu-title">DASHBOARD</span>
                                            </div>
                                        </a>
                                        
                                    <% }  else if (item.module_name === 'REPORT') { %>

                                        <% } else if (item.module_name === 'USER_MANAGEMENT') { %>

                                        <% } else if (item.module_name === 'DB_MANAGEMENT') { %>
                                            <a class="nav-link" href="/db_managment">
                                                <i class="fa-solid fa-database menu-icon"></i>
                                                <span class="menu-title">DB Management</span>
                                            </a>
                                        <% }
                                        else if (item.module_name === 'OFF_DB_MANAGEMENT') { %>
                                            <a class="nav-link" href="/off_db_managment">
                                                <i class="fa-solid fa-database menu-icon"></i>
                                                <span class="menu-title">Offboarding DB Management</span>
                                            </a>
                                        <% }
                                         else if (item.module_name === 'SUPERDBREPORT') { %>
                                            <a class="nav-link" href="/superdbReport">
                                                <i class="fa-solid fa-database menu-icon"></i>
                                                <span class="menu-title">DB Report</span>
                                            </a>    
                                        <% }  else if (item.module_name === 'REGION') { %>
                                            <a class="nav-link" href="/region">
                                                <i class="fa-solid fa-map menu-icon"></i>
                                                <span class="menu-title">Hierarchy Management</span>
                                            </a>
                                        <% }
                                        else if (item.module_name === 'ROLE_MANAGEMENT') { %>
                                        <% } %>
                                </li>
                            <% } %>
                        <% }); %>
                
                        <!-- Logout Button -->
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="fa-solid fa-right-from-bracket"></i>
                                <span class="menu-title">LOGOUT</span>
                            </a>
                        </li>
                    </ul>
                </div>
                
                </div>
            </div>
            <div class="app-main__outer">
                <div class="app-main__inner">