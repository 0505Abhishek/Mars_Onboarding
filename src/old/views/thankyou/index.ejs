<!-- thankyou.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank You</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #6e7dff, #85c7ff);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            color: #fff;
        }

        .thankyou-container {
            text-align: center;
            background-color: #fff;
            color: #333;
            border-radius: 10px;
            padding: 40px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            max-width: 500px;
            width: 100%;
        }

        .thankyou-container h1 {
            font-size: 36px;
            margin-bottom: 20px;
            color: #0077cc;
        }

        .thankyou-container p {
            font-size: 18px;
            margin-bottom: 30px;
        }

        .button-home {
            background-color: #0077cc;
            color: #fff;
            padding: 15px 30px;
            font-size: 18px;
            border: none;
            border-radius: 30px;
            text-decoration: none;
            transition: background-color 0.3s;
        }

        .button-home:hover {
            background-color: #005fa3;
        }

        @media (max-width: 600px) {
            .thankyou-container {
                padding: 30px;
                max-width: 90%;
            }

            .thankyou-container h1 {
                font-size: 30px;
            }

            .thankyou-container p {
                font-size: 16px;
            }

            .button-home {
                font-size: 16px;
                padding: 12px 25px;
            }
        }
    </style>
</head>
<body>
    <div class="thankyou-container">
        <h1>Thank you. Your Response is Recorded!</h1>
    </div>
</body>
</html>
