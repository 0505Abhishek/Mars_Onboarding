        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
  
        <div class="modal-body text-center">
          <div id="filePreview"></div>
        </div>
  
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      
      </div>
    </div>
  </div>
 
  

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("documentForm"); 
        const submitBtn = document.getElementById("submitBtn");

        form.addEventListener("submit", function (event) {
            let isValid = true;
            let missingFiles = [];

            const applicationType = "<%= distributor.applicationType %>";

            if (applicationType === 'Replacement') {
                const selectedDoc = document.querySelector('input[name="doc_upload"]:checked');
                if (!selectedDoc) {
                    isValid = false;
                    missingFiles.push("Document Type (NOC or Sales Director Email Approval)");
                } else {
                    const docType = selectedDoc.value; 
                    const fileInput = document.querySelector(`input[name="${docType}_document"]`);
                    if (!fileInput || fileInput.files.length === 0) {
                        isValid = false;
                        missingFiles.push(selectedDoc.nextSibling.textContent.trim() + " File");
                    }
                }
            }

            document.querySelectorAll("input[type='file']").forEach(input => {
                
                if (input.name.startsWith("other_doc_file_")) {
                    return;
                }

                let fileLabel = input.closest("tr")?.querySelector("td:nth-child(2)")?.innerText || "";

                if (fileLabel==='Bank Statement' ||  fileLabel.toLowerCase().includes('fssai amendment') || fileLabel === 'Godown Insurance') {
                    return; 
                }

                if (input.files.length === 0) {
                    isValid = false;
                    if (!missingFiles.includes(fileLabel)) missingFiles.push(fileLabel);
                }
            });
                      
            // if (!isValid) {
            //     event.preventDefault(); 
            //     Swal.fire({
            //         icon: "error",
            //         title: "Missing Documents!",
            //         html: `<strong>Please upload or select the following required items:</strong><br><br> 
            //             <ul style="text-align:left;">
            //                 ${missingFiles.map(doc => `<li>❌ ${doc}</li>`).join('')}
            //             </ul>`,
            //         confirmButtonColor: "#d33",
            //         confirmButtonText: "OK"
            //     });
            //     return;
            // }

            submitBtn.disabled = true;
            submitBtn.innerText = "Submitting...";
        });
    }); 
</script>  


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const fileInputs = document.querySelectorAll(".file-upload input[type='file']");
    const viewIcons = document.querySelectorAll(".view-icon");
    const modalElement = document.getElementById("fileModal");
    const modalBody = document.getElementById("filePreview");
    const closeModalBtn = modalElement.querySelector("[data-bs-dismiss='modal']");
    let modalInstance = new bootstrap.Modal(modalElement);

    const allowedTypes = [
      "image/jpeg",
      "image/png",
      "image/jpg",
      "application/pdf",
      "application/vnd.ms-excel",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "text/csv"
    ];

    const DEFAULT_MAX_FILE_SIZE_MB = 3;
    const DEFAULT_MAX_FILE_SIZE = DEFAULT_MAX_FILE_SIZE_MB * 1024 * 1024;

    const RESIGNATION_MAX_FILE_SIZE_MB = 15;
    const RESIGNATION_MAX_FILE_SIZE = RESIGNATION_MAX_FILE_SIZE_MB * 1024 * 1024;

    fileInputs.forEach((input) => {
      input.addEventListener("change", function () {
        const file = this.files[0];
        const viewId = this.dataset.view;
        const fileNameId = this.dataset.filename;
        const label = this.closest(".file-upload");


        if (fileNameId) {
          document.getElementById(fileNameId).textContent = 'No file selected';
        }
        if (label) {
          label.classList.remove('uploaded');
        }

        if (file) {
          // Type check
          if (!allowedTypes.includes(file.type)) {
            alert("❌ Only PDF, DOC, XLS, XLSX, CSV, and image files (JPG, JPEG, PNG) are allowed.");
            this.value = "";
            return;
          }

          // Size check
            let maxSize = (this.name === "db_agreement") 
                    ? RESIGNATION_MAX_FILE_SIZE 
                    : DEFAULT_MAX_FILE_SIZE;

            let maxSizeMB = (this.name === "db_agreement") 
                ? RESIGNATION_MAX_FILE_SIZE_MB 
                : DEFAULT_MAX_FILE_SIZE_MB;

            if (file.size > maxSize) {
                alert(`❌ "${file.name}" exceeds ${maxSizeMB}MB. Please upload a smaller file.`);
                this.value = "";
                return;
            }

          // Valid file
          const fileUrl = URL.createObjectURL(file);
          const viewIcon = document.getElementById(viewId);

          if (fileNameId) {
            document.getElementById(fileNameId).textContent = file.name;
          }

          if (label) {
            label.classList.add('uploaded');
          }

          if (viewIcon) {
            viewIcon.dataset.file = fileUrl;
            viewIcon.dataset.type = file.type;
            viewIcon.style.display = "inline";
          }
        }
      });
    });

    viewIcons.forEach((icon) => {
      icon.addEventListener("click", function () {
        const fileUrl = this.dataset.file;
        const fileType = this.dataset.type;

        if (fileUrl && fileType) {
          if (fileType.startsWith("image")) {
            modalBody.innerHTML = `<img src="${fileUrl}" style="width: 80%; height: auto;">`;
          } else if (fileType === "application/pdf") {
            modalBody.innerHTML = `<embed src="${fileUrl}" type="application/pdf" width="80%" height="500px" />`;
          } else if (
            fileType === "application/vnd.ms-excel" ||
            fileType === "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" ||
            fileType === "text/csv"
          ) {
            modalBody.innerHTML = `<p>✅ File "${fileUrl.split('/').pop()}" is selected (Excel/CSV file)</p>`;
          } else {
            modalBody.innerHTML = `<p>❌ Unsupported file type</p>`;
          }

          modalInstance.show();
        }
      });
    });

    closeModalBtn.addEventListener("click", function () {
      modalInstance.hide();
    });


    <% if (notification) { %>
      Swal.fire({
        icon: '<%= notification.type %>',
        title: '<%= notification.message %>',
        showConfirmButton: false,
        timer: 2000
      });
    <% } %>
  });
</script>


<script>
    document.querySelectorAll('.doc-selector').forEach(radio => {
        radio.addEventListener('change', function () {
            const uploadRowContainer = document.getElementById('uploadRowContainer');

            // Generate dynamic IDs
            const selectedLabel = this.value === 'noc' ? 'NOC Document' : 'Sales Director Email Approval';
            const inputName = `${this.value}_document`;
            const viewId = `view13_${this.value}`;
            const fileNameId = `fileName13_${this.value}`;

            // Replace the dynamic row
            uploadRowContainer.innerHTML = `
                <td>13</td>
                <td>Upload ${selectedLabel}</td>
                <td>
                    <label class="file-upload">
                        <input type="file" name="${inputName}" hidden data-view="${viewId}" data-filename="${fileNameId}">
                        <i class="fa fa-upload"></i>
                    </label>
                </td>
                <td><span id="${fileNameId}" class="file-name">No file selected</span></td>
                <td><span id="${viewId}" class="view-icon" style="display: none;">👁</span></td>
            `;

            // Get new elements
            const fileInput = uploadRowContainer.querySelector('input[type="file"]');
            const viewIcon = document.getElementById(viewId);
            const fileNameSpan = document.getElementById(fileNameId);
            const label = fileInput.closest(".file-upload");

            // File input change handler
            fileInput.addEventListener("change", function () {
                const file = this.files[0];
                const allowedTypes = ["image/jpeg", "image/png", "image/jpg", "application/pdf"];

                // Reset
                fileNameSpan.textContent = 'No file selected';
                label.classList.remove('uploaded');
                viewIcon.style.display = 'none';

                if (file) {
                    if (!allowedTypes.includes(file.type)) {
                        alert("❌ Only PDF and image files (JPG, JPEG, PNG) are allowed.");
                        this.value = "";
                        return;
                    }

                    const fileUrl = URL.createObjectURL(file);
                    viewIcon.dataset.file = fileUrl;
                    viewIcon.dataset.type = file.type;
                    viewIcon.style.display = 'inline';
                    fileNameSpan.textContent = file.name;
                    label.classList.add('uploaded');
                }
            });


            viewIcon.addEventListener("click", function () {
                const fileUrl = this.dataset.file;
                const fileType = this.dataset.type;
                const modalBody = document.getElementById("filePreview");
                const modalInstance = new bootstrap.Modal(document.getElementById("fileModal"));

                if (fileUrl && fileType) {
                    if (fileType.startsWith("image")) {
                        modalBody.innerHTML = `<img src="${fileUrl}" style="width: 80%; height: auto;">`;
                    } else if (fileType === "application/pdf") {
                        modalBody.innerHTML = `<embed src="${fileUrl}" type="application/pdf" width="80%" height="500px" />`;
                    } else {
                        modalBody.innerHTML = `<p>Unsupported file type</p>`;
                    }

                    modalInstance.show();
                }
            });
        });
    });
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const downloadBtn = document.getElementById("downloadBtn");
    const originalHTML = downloadBtn.innerHTML;

    downloadBtn.addEventListener("click", function () {

      downloadBtn.style.pointerEvents = "none";
      downloadBtn.style.opacity = "0.6";
      downloadBtn.innerHTML = `<i class="fa fa-clock-o"></i> Wait 10s`;

      setTimeout(() => {
        downloadBtn.style.pointerEvents = "auto";
        downloadBtn.style.opacity = "1";
        downloadBtn.innerHTML = originalHTML;
      }, 10000); 
    });
  });
</script>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const DEFAULT_MAX_FILE_SIZE_MB = 3;
    const DEFAULT_MAX_FILE_SIZE = DEFAULT_MAX_FILE_SIZE_MB * 1024 * 1024;

    const fileInputs = document.querySelectorAll('input[type="file"]');

    fileInputs.forEach(input => {
      input.addEventListener("change", function () {
        const file = this.files[0];
        const fileNameSpanId = this.getAttribute("data-filename");
        const viewIconId = this.getAttribute("data-view");

        if (file && file.size > MAX_FILE_SIZE) {
          alert(`"${file.name}" exceeds ${MAX_FILE_SIZE_MB}MB limit. Please upload a smaller file.`);
          
          // Clear the file input
          this.value = "";

          // Reset filename display
          if (fileNameSpanId) {
            const nameSpan = document.getElementById(fileNameSpanId);
            if (nameSpan) {
              nameSpan.textContent = "No file selected";
            }
          }

          // Hide the preview/view icon
          if (viewIconId) {
            const viewIcon = document.getElementById(viewIconId);
            if (viewIcon) {
              viewIcon.style.display = "none";
            }
          }
        }
      });
    });
  });
</script>



