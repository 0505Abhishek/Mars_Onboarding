<%- include("../shared/super_header.ejs") %>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <div class="main-panel distributors-details">
    <div class="content-wrapper">
      <div class="row">
        <div class="col-12 grid-margin stretch-card">
          <div class="card p-3 table-responsive">
            <div class="d-flex justify-content-between my-4">
              <div class="business-hading d-flex justify-content-between">
                <h4>User Managment</h4>

              </div>
              <div>
                <a href="/user_management/mapping" class="text-white">
                  <button class="btn btn-primary  btn-sm mr-2">
                    Mapping
                  </button>
              </a>
                <a href="/user_management/user-transfer" class="btn btn-primary btn-sm">
                  <i class="mdi mdi-upload"></i> User Transfer
                </a>
                <button type="button" class="btn btn-primary btn-sm" id="openModalBtnUpdate">
                  <i class="mdi mdi-upload"></i> Update Users
                </button>
                <button type="button" class="btn btn-primary btn-sm" id="openModalBtn">
                  <i class="mdi mdi-upload"></i> Import Users
                </button>
                
              </div>
            </div>
            <div class="card-body">
              <table id="userManagementTable"
                class="display table invite table-bordered mt-3 table-hover responsive nowrap" style="width: 100%">
                <thead>
                  <tr>
                    <th>User Id</th>
                    <th>Employee Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Parent</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% user.forEach(function(user) { %>
                    <tr>
                      <td>CB<%= user.id %>
                      </td>
                      <td>
                        <%= user.employee_name %>
                      </td>
                      <td>
                        <%= user.email_id %>
                      </td>
                      <td>
                        <%= user.role %>
                      </td>
                      <td>
                        <% if(user.parent_id> 0) { %>
                          CB<%= user.parent_id %>
                            <% } %>
                      </td>
                      <td>
                        <a href="/user_management/edit/<%= user.id %>" class="btn btn-primary btn-sm">Edit</a>
                      </td>
                    </tr>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>






  <div class="custom-modal-backdrop" id="modalBackdrop"></div>

  <!-- Modal -->
  <div class="custom-modal" id="customModal">
    <div class="modal-header">
      <h5>Import File</h5>
      <button class="btn-close" id="closeModalBtn"></button>
    </div>
    <div class="modal-body">
      <div>
        <a id="downloadCsv" class="btn mb-3">Download
          Template<span class="p-1 ms-2 rounded-circle border border-primary"><i
              class="mdi mdi-format-vertical-align-bottom"></i></span></a>

      </div>
      <div class="text-center mb-4">
        <i class="mdi mdi-file-upload-outline fs-1 text-primary"></i>
        <h6 class="mt-3">Upload CSV File</h6>
        <p class="text-muted">Please upload a CSV file with user data</p>
      </div>

      <form action="/user_management/upload-user" method="POST" enctype="multipart/form-data" class="text-center">
        <div class="file-upload mb-4">
          <label class="btn btn-outline-primary btn-sm w-100">
            <i class="mdi mdi-file-upload"></i> Choose File
            <input type="file" class="d-none" name="file" id="fileInput" accept=".csv" required
              onchange="document.getElementById('fileName').textContent = this.files[0].name">
          </label>
          <small class="text-muted d-block mt-2">Only .csv files are allowed</small>
          <p class="text-muted mt-2" id="fileName">No file chosen</p>
        </div>
        <button type="submit" class="btn btn-primary btn-sm w-100">
          <i class="mdi mdi-upload"></i> Upload
        </button>
      </form>
    </div>
  </div>
  <div class="custom-modal" id="customModalupdate">
    <div class="modal-header">
      <h5>Update User</h5>
      <button class="btn-close" id="closeModalBtnUpdate"></button>
    </div>
    <div class="modal-body">
      <div>
        <a id="downloadCsvupdate" class="btn mb-3">Download
          Template<span class="p-1 ms-2 rounded-circle border border-primary"><i
              class="mdi mdi-format-vertical-align-bottom"></i></span></a>

      </div>
      <div class="text-center mb-4">
        <i class="mdi mdi-file-upload-outline fs-1 text-primary"></i>
        <h6 class="mt-3">Upload CSV File</h6>
        <p class="text-muted">Please upload a CSV file with user data</p>
      </div>

      <form action="/user_management/update-user" method="POST" enctype="multipart/form-data" class="text-center">
        <div class="file-upload mb-4">
          <label class="btn btn-outline-primary btn-sm w-100">
            <i class="mdi mdi-file-upload"></i> Choose File
            <input type="file" class="d-none" name="file" id="fileInput" accept=".csv" required
              onchange="document.getElementById('fileName').textContent = this.files[0].name">
          </label>
          <small class="text-muted d-block mt-2">Only .csv files are allowed</small>
          <p class="text-muted mt-2" id="fileName">No file chosen</p>
        </div>
        <button type="submit" class="btn btn-primary btn-sm w-100">
          <i class="mdi mdi-upload"></i> Upload
        </button>
      </form>
    </div>
  </div>

  <script>
    const openBtnupdate = document.getElementById('openModalBtnUpdate');
    const closeBtnupdate = document.getElementById('closeModalBtnUpdate');
    const modalupdate = document.getElementById('customModalupdate');
    const backdropupdate = document.getElementById('modalBackdrop');

    openBtnupdate.addEventListener('click', () => {
      modalupdate.classList.add('show');
      backdropupdate.classList.add('show');
    });

    closeBtnupdate.addEventListener('click', () => {
      modalupdate.classList.remove('show');
      backdropupdate.classList.remove('show');
    });
    backdropupdate.addEventListener('click', () => {
      modalupdate.classList.remove('show');
      backdrop.classList.remove('show');
    });
  </script>
  <script>
    const openBtn = document.getElementById('openModalBtn');
    const closeBtn = document.getElementById('closeModalBtn');
    const modal = document.getElementById('customModal');
    const backdrop = document.getElementById('modalBackdrop');

    openBtn.addEventListener('click', () => {
      modal.classList.add('show');
      backdrop.classList.add('show');
    });

    closeBtn.addEventListener('click', () => {
      modal.classList.remove('show');
      backdrop.classList.remove('show');
    });
    backdrop.addEventListener('click', () => {
      modal.classList.remove('show');
      backdrop.classList.remove('show');
    });
  </script>


  <script>

    document.getElementById('downloadCsvupdate').addEventListener('click', function () {
      const headers = [
        "parent_id",
        "user_id",
        "role_id",
        "role",
        "employee_code",
        "employee_name",
        "email_id",
        "mobile_no",
        "designation",
        "city",
        "Zone",
        "channels"
      ];

      let csvContent = "data:text/csv;charset=utf-8," + headers.join(',') + '\n';

      // Create a CSV string
      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);

      link.setAttribute("download", "user_management(" + new Date().toISOString() + ").csv");
      document.body.appendChild(link); // Required for Firefox

      link.click();
    });
  </script>
  <script>

    document.getElementById('downloadCsv').addEventListener('click', function () {
      const headers = [
        "parent_id",
        "role_id",
        "role",
        "employee_code",
        "employee_name",
        "email_id",
        "mobile_no",
        "designation",
        "city",
        "region",
        "channels",
        "Territory"
      ];

      let csvContent = "data:text/csv;charset=utf-8," + headers.join(',') + '\n';

      // Create a CSV string
      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);

      link.setAttribute("download", "user_management(" + new Date().toISOString() + ").csv");
      document.body.appendChild(link); // Required for Firefox

      link.click();
    });
  </script>

  <script>
    const Toast = Swal.mixin({
      toast: true,
      position: "top-end",
      showConfirmButton: false,
      timer: 3000,
      timerProgressBar: true,
      didOpen: (toast) => {
        toast.onmouseenter = Swal.stopTimer;
        toast.onmouseleave = Swal.resumeTimer;
      }
    });

    function showToast(icon, title) {
      Toast.fire({
        icon: icon,
        title: title
      });
    }
    "  <% if (error) { %>"
    showToast("error", "<%= error %>");
    "<% } else if (success) { %>"
    showToast("success", "<%= success %>");

    "  <% } %>"

  </script>
  <script>
    $(document).ready(function() {
        $('#userManagementTable').DataTable({
            responsive: true,
            pageLength: 10,
            lengthMenu: [[10, 25, 50, -1], [10, 25, 50, "All"]],
            columns: [
                { width: '10%' },
                { width: '25%' },
                { width: '20%' },
                { width: '15%' },
                { width: '15%' },
                { width: '15%' }
            ],
            language: {
                search: "_INPUT_",
                searchPlaceholder: "Search users...",
                lengthMenu: "Show _MENU_ entries",
                paginate: {
                    first: '<i class="mdi mdi-chevron-double-left"></i>',
                    last: '<i class="mdi mdi-chevron-double-right"></i>',
                    next: '<i class="mdi mdi-chevron-right"></i>',
                    previous: '<i class="mdi mdi-chevron-left"></i>'
                }
            },
            initComplete: function () {
                this.api().columns().every(function () {
                    var column = this;
                    var select = $('<select class="form-control"><option value=""></option></select>')
                        .appendTo($(column.footer()).empty())
                        .on('change', function () {
                            var val = $.fn.dataTable.util.escapeRegex(
                                $(this).val()
                            );
    
                            column
                                .search(val ? '^' + val + '$' : '', true, false)
                                .draw();
                        });
    
                    column.data().unique().sort().each(function (d, j) {
                        select.append('<option value="' + d + '">' + d + '</option>')
                    });
                });
            }
        });
    });
    
   
    </script>
  <%- include("../shared/super_footer.ejs") %>