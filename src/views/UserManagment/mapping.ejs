<%- include("../shared/super_header.ejs") %>
<style>
    /* Enhanced Select2 Styling */
    .select2-container {
        width: 100% !important;
    }
    .select2-container--default .select2-selection--multiple {
        background-color: #f8f9fa;
        border: 1px solid #ced4da;
        border-radius: 4px;
        min-height: 38px;
    }
    .select2-container--default .select2-selection--multiple .select2-selection__choice {
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 2px;
        margin-top: 5px;
        padding: 2px 5px;
    }
    .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
        color: white;
        margin-right: 5px;
    }
    .select2-container--default .select2-selection--multiple .select2-selection__rendered {
        padding: 0 5px;
    }
    .select2-dropdown {
        border-radius: 4px;
    }
    .select2-results__option {
        padding: 6px 12px;
    }
    .select2-results__option--selected {
        background-color: #007bff !important;
        color: white !important;
    }
</style>

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Mapping </h4>
                        
                        <form id="userTransferForm" action="#" method="POST">
                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <label>Regions</label>
                                    <select name="regions" class="select2-dropdown" multiple="multiple" required>
                                        <% regions.forEach(function(region) { %>
                                            <option value="<%= region.id %>" 
                                                data-email="<%= region.email_id %>" 
                                                data-territory="<%= region.territory %>"
                                                data-region="<%= region.region %>"
                                                data-channel="<%= region.channel %>">
                                                <%= region.region_name %>
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <label>Territories</label>
                                    <select name="territories" class="select2-dropdown" multiple="multiple" id="territoriesSelect" required>
                                        <option value="">Select territories</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <label>Channels</label>
                                    <select name="channels" class="form-select"  required>
                                        <option value="">Select channels</option>
                                        <% channels.forEach(function(channel) { %>
                                            <option value="<%= channel.id %>"><%= channel.channel_name %></option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <label>RSEM</label>
                                    <input type="text" name="rsem" class="form-control" required>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <label>DT Team</label>
                                    <input type="email" name="dt_team" class="form-control" required>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary">submit</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../shared/super_footer.ejs") %>

<!-- Ensure jQuery is loaded -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
$(document).ready(function() {
    // Initialize Select2 for regions and territories with enhanced options
    $('.select2-dropdown').select2({
        placeholder: "Select options",
        allowClear: true,
        templateResult: function(state) {
            if (!state.id) { 
                return state.text; 
            }
            
            // Custom formatting for options
            var $state = $(
                '<span>' + 
                    '<strong>' + state.text + '</strong>' + 
                    (state.element.getAttribute('data-email') ? 
                        '<br><small class="text-muted">' + state.element.getAttribute('data-email') + '</small>' : 
                        ''
                    ) + 
                '</span>'
            );
            return $state;
        },
        templateSelection: function(state) {
            // Customize how selected items look
            return state.text;
        },
        matcher: function(params, data) {
            // Custom matching for search
            if ($.trim(params.term) === '') {
                return data;
            }
            
            // Case-insensitive search across text and data attributes
            var searchTerm = params.term.toLowerCase();
            var text = data.text.toLowerCase();
            var email = data.element.getAttribute('data-email') ? 
                        data.element.getAttribute('data-email').toLowerCase() : '';
            
            if (text.indexOf(searchTerm) > -1 || email.indexOf(searchTerm) > -1) {
                return data;
            }
            
            return null;
        }
    });

    // Function to fetch territories based on selected regions
    function fetchTerritories() {
        // Get selected region IDs
        var selectedRegionIds = $('select[name="regions"]').val();

        // Clear existing territories
        $('#territoriesSelect').empty().append('<option value="">Select territories</option>');

        if (selectedRegionIds && selectedRegionIds.length > 0) {
            // AJAX call to fetch territories
            $.ajax({
                url: '/tab/get-territories',
                method: 'POST',
                data: { regionIds: selectedRegionIds },
                success: function(territories) {
                    // Populate territories dropdown
                    territories.forEach(function(territory) {
                        $('#territoriesSelect').append(
                            `<option value="${territory.id}" 
                                data-region="${territory.region}" 
                                data-channel="${territory.channel}">
                                ${territory.territory_name}
                            </option>`
                        );
                    });

                    // Reinitialize Select2 for territories
                    $('#territoriesSelect').select2({
                        placeholder: "Select territories",
                        allowClear: true
                    });
                },
                error: function(xhr, status, error) {
                    console.error("Error fetching territories:", error);
                    alert("Failed to fetch territories. Please try again.");
                }
            });
        }
    }

    // Bind change event to regions select
    $('select[name="regions"]').on('change', fetchTerritories);
});
</script>