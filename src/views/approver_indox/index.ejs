<%- include("../shared/header.ejs") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<style>
    .hidden { display: none; }
</style>
<style>
    .scroll-section {
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
    .modal-backdrop {
        display: none !important;
    }

    .modal-body {
        max-height: 440px;
        overflow-y: auto;
    }
    .modal-dialog{
        width:75%;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th, td {
        border: 1px solid #ccc;
        padding: 10px;
        text-align: center;
    }

    .view-icon {
        cursor: pointer;
        font-size: 20px;
    }
  </style>

  <style>
    .table-dark th {
        color: #0000A0 !important; 
        background-color: #E0E0FC;
        border: 1px solid rgb(224, 203, 203);
    }
    #distributorTable tbody tr:nth-child(odd) td {
        background: #FFFFFF !important; 
    }
    #distributorTable tbody tr:nth-child(even) td {
        background: #EFEFFF !important; 
    }
    .dt-buttons .btn, .buttons-copy, .buttons-csv {
        background-color: #007bff !important;
        color: white !important; 
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
    }
  </style>


   
<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-end align-items-center mb-3 gap-3">

        <script>
            const distributorsData = <%- JSON.stringify(distributors) %>;
        </script>

        <!-- Status Filter -->
        <div class="d-flex flex-column">
            <label for="statusFilter" class="form-label mb-1">Status</label>
            <select id="statusFilter" class="form-select">
            <option value="">ALL</option>
            <option value="Pending">Pending</option>
            <option value="approved">Approved</option>
            <option value="Completed">Completed</option>
            <option value="Correction">Correction</option>
            <option value="Rejected">Rejected</option>
            </select>
        </div>

        <!-- Type Filter -->
        <div class="d-flex flex-column">
            <label for="typeFilter" class="form-label mb-1">Type</label>
            <select id="typeFilter" class="form-select">
            <option value="default" selected>All</option>
            <option value="0">Pending at ASM</option>
            <% if (token[0]?.role_id !== 4) { %>
                <option value="4">Pending at RSM</option>
            <% } %>
            <% if (token[0]?.role_id !== 5) { %>
                <option value="5">Pending at CE</option>
            <% } %>
            <% if (token[0]?.role_id !== 6) { %>
                <option value="6">Pending at O2C</option>
            <% } %>
            <% if (token[0]?.role_id !== 7) { %>
                <option value="7">Pending at SNF</option>
            <% } %>
            <% if (token[0]?.role_id !== 8) { %>
                <option value="8">Pending at MDM</option>
            <% } %>
            <% if (token[0]?.role_id !== 10) { %>
                <option value="9">Pending at DT Team</option>
            <% } %>
            </select>
        </div>

        <!-- Region Filter -->
        <div class="d-flex flex-column" style="min-width: 200px;">
            <label for="regionFilter" class="form-label mb-1">Filter by Region</label>
            <select id="regionFilter" class="form-select">
            <option value="">All</option>
            <% regions.forEach(region => { %>
                <option value="<%= region.id %>" data-name="<%= region.region_name %>">
                <%= region.region_name %>
                </option>
            <% }) %>
            </select>
        </div>

        <!-- Territory Filter -->
        <div class="d-flex flex-column" style="min-width: 200px;">
            <label for="territoryFilter" class="form-label mb-1">Filter by Territory</label>
            <select id="territoryFilter" class="form-select">
            <option value="">All</option>
            <% territory.forEach(t => { %>
                <option value="<%= t.territory_name %>" data-name="<%= t.territory_name %>">
                <%= t.territory_name %>
                </option>
            <% }) %>
            </select>
        </div>

        </div>


    <div class="table-responsive">
        <table id="distributorTable" class="table table-striped table-bordered display nowrap" style="width:100%">
            <thead class="table-dark">
                <tr>
                    <th>Unique Application code</th>
                    <th>Firm Name</th>
                    <th>DB Channel</th>
                    <th>Application Type</th>
                    <th>Distributor Name</th>
                    <th>email</th>
                    <th>contactNumber</th>
                    <th>Region</th>
                    <th>Territory</th>
                    <th>City</th>
                    <th>Freight Expenses % </th>
                    <th>Start Date</th>
                    <th>Initiator Email</th>
                    <th>Approved By</th>
                    <th>Status</th>
                    <th>Pending Level</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="distributorBody">
                <% if (distributors?.length > 0) { %>
                    <% distributors.forEach((distributor) => { %>
                        <tr>
                            <td><%= distributor?.mars_code ?? 'N/A' %></td>
                            <td><%= distributor?.firmName ?? 'N/A' %></td>
                            <td><%= distributor?.dbType ?? 'N/A' %></td>
                            <td><%= distributor?.applicationType ?? 'N/A' %></td>
                            <td><%= distributor?.distributorName ?? 'N/A' %></td>
                            <td><%= distributor?.email ?? 'N/A' %></td>
                            <td><%= distributor?.contactNumber ?? 'N/A' %></td>
                            <td><%= distributor?.region_name %></td>
                            <td><%= distributor?.territory_name %></td>
                            <td><%= distributor?.city %></td>
                            <td><%= distributor?.FreightExpenses %></td>
                            <td>
                            <%= distributor.applicationStartDate ? new Date(distributor.applicationStartDate).toLocaleDateString('en-CA') : 'N/A' %>
                            </td>

                            <td><%= distributor?.aseemail ?? 'N/A' %></td>
                            <td><%= distributor?.aprover_employee_name ?? ''%></td>
                            <td>
                                <% if ((distributor.lower_pending == 1 || distributor.lower_pending == 0) && distributor.is_final_approver == 0 && distributor.flag == 0 && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-primary text-white">Pending</span>
                                <% } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 1 && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-success">approved</span>
                                <% } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 0 && distributor.flag == 3 && distributor.applicationStatus == 'Correction' && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-warning text-dark">Correction</span>
                                <% } else if (distributor.flag === 2 && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-danger text-white">Rejected</span>
                                <% } else if(distributor?.final_flag == 1){ %>
                                    <span class="badge bg-success">Completed</span>    
                                <% } else{ %>
                                    <span class="badge bg-primary text-white">Pending</span>      
                                <% } %>
                            </td>
                            <td>
                                <%= distributor?.flag === 2 
                                    ? 'Rejected' 
                                    : distributor?.flag === 3 && distributor?.applicationStatus === 'Correction'
                                        ? 'Pending at ASM'
                                        : distributor?.current_pending_approver_role 
                                            ? `Pending On ${distributor.current_pending_role_name}` 
                                            : 'Onboarded' %>
                            </td>

                             <td>
                                <% if (distributor.lower_pending == 0 && distributor.is_final_approver == 0 && distributor.flag == 0) { %>
                                    <a href="/approver_indox/<%= distributor.id %>">
                                        <button class="btn btn-primary">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                    </a>
                                <% } else if(distributor.lower_pending == 0 && distributor.is_final_approver == 1){ %>
                                    <a href="/approver_indox/<%= distributor.id %>">
                                        <button class="btn btn-primary">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                    </a>
                                <% } else if(distributor.lower_pending == 0 && distributor?.flag == 2 ){ %>
                                    <a href="/approver_indox/<%= distributor.id %>">
                                        <button class="btn btn-primary">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="14" class="text-center">No distributors found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    $(document).ready(function () {
    let table = $('#distributorTable').DataTable({
        paging: true,
        searching: true,
        info: true,
        ordering: false,
        lengthMenu: [5, 10, 25, 50],
        pageLength: 10
    });

    $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
        const regionFilter = $('#regionFilter option:selected').text().toLowerCase().trim();
        const territoryFilter = $('#territoryFilter option:selected').text().toLowerCase().trim();
        const statusFilter = $('#statusFilter').val().toLowerCase().trim();

        const statusText = data[14].toLowerCase().trim();     
        const regionText = data[7].toLowerCase().trim();      
        const territoryText = data[8].toLowerCase().trim();   


        if (statusFilter && !statusText.includes(statusFilter)) {
            return false;
        }
        
        if (regionFilter && regionFilter !== "all" && regionText !== regionFilter) {
            return false;
        }
        if (territoryFilter && territoryFilter !== "all" && !territoryText.includes(territoryFilter)) {
            return false;
        }

        return true;
    });

    $('#statusFilter, #regionFilter, #territoryFilter').on('change', function () {
        table.draw();
    });

$('#typeFilter').on('change', function () {
    const forwardedTo = $(this).val();
    const forwardedToText = $('#typeFilter option:selected').text();

    if (forwardedTo === 'default') {
        $.ajax({
            url: '/approver_indox',
            method: 'GET',
            success: function () {
                location.reload();
            },
            error: function (error) {
                console.error('Error calling /approver_indox:', error);
            }
        });
    } else {
        fetch(`/approver_indox/hierarchyRole/distributors?forwardedTo=${encodeURIComponent(forwardedTo)}`)
            .then(res => res.json())
            .then(response => {
                const distributors = Array.isArray(response?.data) ? response.data : [];

                if ($.fn.DataTable.isDataTable('#distributorTable')) {
                    $('#distributorTable').DataTable().clear().destroy();
                }

                $('#distributorBody').empty();


                    distributors.forEach(distributor => {
                        const startDate = distributor.applicationStartDate
                            ? new Date(distributor.applicationStartDate).toLocaleDateString('en-CA')
                            : 'N/A';

                        let statusBadge = `<span class="badge bg-primary text-white">Pending</span>`;
                        if ((distributor.lower_pending == 1 || distributor.lower_pending == 0) && distributor.is_final_approver == 0 && distributor.flag == 0 && distributor.final_flag != 1) {
                            statusBadge = `<span class="badge bg-primary text-white">Pending</span>`;
                        } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 1 && distributor.final_flag != 1) {
                            statusBadge = `<span class="badge bg-success">Approved</span>`;
                        } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 0 && distributor.flag == 3 && distributor.applicationStatus == 'Correction' && distributor.final_flag != 1) {
                            statusBadge = `<span class="badge bg-warning text-dark">Correction</span>`;
                        } else if (distributor.flag === 2 && distributor.final_flag != 1) {
                            statusBadge = `<span class="badge bg-danger text-white">Rejected</span>`;
                        } else if (distributor.final_flag == 1) {
                            statusBadge = `<span class="badge bg-success">Completed</span>`;
                        }


let pendingLevel = '';

if (distributor.flag == 2) {
    pendingLevel = 'Rejected';
} else if (distributor.flag == 3 && distributor.applicationStatus == 'Correction') {
    pendingLevel = 'Pending at ASM';
} else if (distributor.final_flag == 1) {
    pendingLevel = 'Onboarded';
} else {

    pendingLevel = distributor.current_pending_role_name 
                   ? `Pending On ${distributor.current_pending_role_name}` 
                   : forwardedToText; 
}

                        let actionBtn = '';
                        if (
                            (distributor.lower_pending == 0 && distributor?.is_final_approver == 0 && distributor?.flag == 0) ||
                            (distributor.lower_pending == 0 && distributor?.is_final_approver == 1) ||
                            (distributor.lower_pending == 0 && distributor?.flag == 2)
                        ) {
                            actionBtn = `
                                <a href="/approver_indox/${distributor?.id}">
                                    <button class="btn btn-primary"><i class="fa fa-eye"></i></button>
                                </a>`;
                        }

                        const row = `
                            <tr>
                                <td>${distributor?.mars_code || 'N/A'}</td>
                                <td>${distributor?.firmName || 'N/A'}</td>
                                <td>${distributor?.dbType || 'N/A'}</td>
                                <td>${distributor?.applicationType || 'N/A'}</td>
                                <td>${distributor?.distributorName || 'N/A'}</td>
                                <td>${distributor?.email || 'N/A'}</td>
                                <td>${distributor?.contactNumber || 'N/A'}</td>
                                <td>${distributor?.region_name || 'N/A'}</td>
                                <td>${distributor?.territory_name || 'N/A'}</td>
                                <td>${distributor?.city || 'N/A'}</td>
                                <td>${distributor?.FreightExpenses || 'N/A'}</td>
                                <td data-order="${distributor?.applicationStartDate ? new Date(distributor?.applicationStartDate).toISOString() : ''}">${startDate}</td>
                                <td>${distributor?.aseemail || 'N/A'}</td>
                                <td>${distributor?.aprover_employee_name || ''}</td>
                                <td>${statusBadge}</td>
                                <td>${pendingLevel}</td>
                                <td>${actionBtn}</td>
                            </tr>`;
                        $('#distributorBody').append(row);
                    });
              

                $('#distributorTable').DataTable({
                    paging: true,
                    searching: true,
                    info: true,
                    lengthMenu: [5, 10, 25, 50],
                    pageLength: 10,
                    responsive: true,
                });
            })
            .catch(err => {
                console.error('Error fetching filtered data:', err);
            });
    }
});

});

</script>




<script>
    function confirmDelete(id) {
    Swal.fire({
        title: "Are you sure?",
        text: "You won't be able to revert this!",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Yes, delete it!"
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/edit_distributor/delete_distributor?id=${id}`;
        }
    });
}
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        <% if (notification) { %>
            Swal.fire({
                icon: '<%= notification.type %>', 
                title: '<%= notification.message %>',
                showConfirmButton: false,
                timer: 2000
            });
        <% } %>
    });
</script>

<script>
  const regionFilter = document.getElementById('regionFilter');
  const territoryFilter = document.getElementById('territoryFilter');

  regionFilter.addEventListener('change', () => {
    const selectedRegion = regionFilter.value;

    territoryFilter.innerHTML = '<option value="">All</option>';

    if (!selectedRegion) return; 

    fetch(`/approver_indox/territories?region=${encodeURIComponent(selectedRegion)}`)
      .then(response => response.json())
      .then(data => {
        data.territories.forEach(territory => {
          const option = document.createElement('option');
          option.value = territory.territory_id;
          option.textContent = territory.territory_name;
          territoryFilter.appendChild(option);
        });
      })
      .catch(err => {
        console.error('Error fetching territories:', err);
      });
  });
</script>

<%- include("../shared/footer.ejs") %>
