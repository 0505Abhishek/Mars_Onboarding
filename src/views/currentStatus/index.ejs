<%- include("../shared/header.ejs") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- DataTables -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>

<style>
    .hidden { display: none; }

    .scroll-section {
        max-height: 300px;
        overflow-y: auto;
        border: 1px solid #ccc;
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 5px;
        background: #f8f9fa;
    }

    .modal-backdrop { display: none !important; }

    .modal-body { max-height: 440px; overflow-y: auto; }

    .modal-dialog { width: 75%; }

    table { width: 100%; border-collapse: collapse; margin-top: 20px; }

    th, td {
        border: 1px solid #ccc;
        padding: 10px;
        text-align: center;
    }

    .view-icon { cursor: pointer; font-size: 20px; }

    .table-dark th {
        color: #0000A0 !important;
        background-color: #E0E0FC;
        border: 1px solid rgb(224, 203, 203);
    }

    #distributorTable tbody tr:nth-child(odd) td {
        background: #FFFFFF !important;
    }

    #distributorTable tbody tr:nth-child(even) td {
        background: #EFEFFF !important;
    }
</style>

<div class="container mt-4">
    <div class="table-responsive">
        <table id="distributorTable" class="table table-striped table-bordered display nowrap" style="width:100%">
            <thead class="table-dark">
                <tr>
                    <th>Unique Application code</th>
                    <th>Firm Name</th>
                    <th>Distributor Name</th>
                    <th>Email</th>
                    <th>Start Date</th>
                    <th>Initiator Email</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="distributorBody">
                <% if (distributors?.length > 0) { %>
                    <% distributors.forEach((distributor) => { %>
                        <tr>
                            <td><%= distributor?.mars_code%></td> 
                            <td><%= distributor?.firmName ?? 'N/A' %></td>
                            <td><%= distributor?.distributorName ?? 'N/A' %></td>
                            <td><%= distributor?.email ?? 'N/A' %></td>
                            <td><%= distributor?.applicationStartDate ? new Date(distributor?.applicationStartDate).toLocaleDateString('en-CA') : 'N/A' %></td>
                            <td><%= distributor?.aseemail ?? 'N/A' %></td>
                            <td>
                                <% if (distributor.applicationStatus == 'Pending' && distributor.flag == 0 && distributor.flag !== 3 && distributor.applicationStatus !== 'Correction' && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-primary text-white">Pending at <%= distributor.role_name %></span>
                                <% } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 1 && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-success">Completed</span>
                                <% } else if (distributor.flag == 3 && distributor.applicationStatus == 'Correction' && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-warning text-dark">Correction sent by <%= distributor.role_name %></span>
                                <% } else if (distributor.flag === 2 && distributor?.final_flag !== 1) { %>
                                    <span class="badge bg-danger text-white">Rejected by <%= distributor.role_name %></span>
                                <% } else if (distributor?.final_flag === 1) { %>
                                    <span class="badge bg-success">Onboarding Completed</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/CURRENT_STATUS/<%= distributor?.id %>">
                                    <button class="btn btn-primary">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="text-center">No distributors found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#distributorTable').DataTable({
            paging: true,
            searching: true, 
            ordering: false,
            info: true,
            lengthMenu: [5, 10, 25, 50],
            pageLength: 10
        });
    });
</script>

<%- include("../shared/footer.ejs") %>
