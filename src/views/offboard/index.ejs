<%- include("../shared/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
    .hidden { display: none; }
</style>
<style>
    .scroll-section {
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
  </style>

    <style>

        .table-dark th {
            color: #0000A0 !important; 
            background-color: #E0E0FC;
            border: 1px solid rgb(224, 203, 203);
        }

        #distributorTable tbody tr:nth-child(odd) td {
            background: #FFFFFF !important; 
        }

        #distributorTable tbody tr:nth-child(even) td {
            background: #EFEFFF !important; 
        }

    </style>

<style>
    /* Fullscreen overlay */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Modal box styling */
.modal-box {
  background: white;
  border: 3px solid #0000A0;
  border-radius: 25px;
  padding: 30px;
  width: 500px;
  text-align: center;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
}

.toggle-group {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin: 10px 0 20px 0;
}

.toggle-group label {
  font-weight: bold;
  display: flex;
  align-items: center;
  gap: 5px;
}

input[type="checkbox"] {
  width: 40px;
  height: 20px;
  appearance: none;
  background: #ccc;
  border-radius: 20px;
  position: relative;
  outline: none;
  cursor: pointer;
  transition: background 0.3s;
}

input[type="checkbox"]::before {
  content: '';
  width: 18px;
  height: 18px;
  background: white;
  border-radius: 50%;
  position: absolute;
  top: 1px;
  left: 1px;
  transition: transform 0.3s;
}

input[type="checkbox"]:checked {
  background: #14e651;
}

input[type="checkbox"]:checked::before {
  transform: translateX(20px);
}

/* Submit Button */
.submit-btn {
  background-color: #007bff;
  color: white;
  padding: 12px 25px;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  font-weight: bold;
}

.submit-btn:hover {
  background-color: #0056b3;
}
</style>
 

<style>
  .distributor-field {
  margin-top: 20px;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
}

.distributor-field label {
  font-weight: bold;
  margin-bottom: 6px;
  font-size: 14px;
}

.distributor-field input[type="text"] {
  padding: 8px 10px;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 14px;
  outline: none;
  transition: border-color 0.3s ease;
}

.distributor-field input[type="text"]:focus {
  border-color: #007BFF;
  box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
}

</style>


<div class="container mt-4">

    <div class="mb-3 d-flex justify-content-end">
      <div>
        <label for="statusFilter" class="form-label mb-0">Filter by Status:</label>
        <select id="statusFilter" class="form-select" style="width: 200px;">
          <option value="">All</option>
          <option value="Offboarding Started">Offboarding Started</option>
          <option value="Pending on Rsem">Pending on Rsem</option>
          <option value="Approved by Rsem">Approved by Rsem</option>
          <option value="Rejected by Rsem">Rejected by Rsem</option>
        </select>
      </div>
    </div>  


    <div class="table-responsive">

      <table id="distributorTable" class="table table-hover table-bordered">
          <thead class="table-dark">
              <tr>
                  <th>Unique Application code</th>
                  <th>DB Channel</th>
                  <th>Firm's Name</th>
                  <th>DB Code by(MDM)</th>
                  <th>Distributor's Name</th>
                  <th>Email ID</th>
                  <th>Mobile Number</th>
                  <th>Freight Expenses %</th>
                  <th>Start Date</th>
                  <th>Status</th>
                  <th>Created By</th>
                  <th style="display: none;">Has Action</th>
                  <th>Action</th>
              </tr>
          </thead>
          <tbody>
              <% if (data.length > 0) { %>
                  <% data.forEach((distributor, index) => { 
                      const updatedDate = new Date(distributor?.lastupdated_date);
                      const now = new Date();
                      const diffInHours = Math.abs(now - updatedDate) / 36e5;
                      const hasAction = (distributor.offboarding_flag === 0 || distributor?.offboard_flag === 2) ? 1 : 0;
                  %>
                      <tr>
                          <td><%= distributor?.mars_code%></td> 
                          <td><%= distributor.dbType%></td> 
                          <td><%= distributor.firmName %></td>
                          <td><%= distributor.cdCode %></td>
                          <td><%= distributor.distributorName %></td>
                          <td><%= distributor.email %></td>
                          <td><%= distributor.contactNumber %></td>
                          <td><%= distributor?.FreightExpenses %></td>
                          <td><%= new Date(distributor.create_date).toLocaleDateString('en-CA') %></td>
                          <td>
                              <% if(distributor.offboarding_flag == 0 && distributor?.present_stage == 1) { %>
                                  <span class="badge bg-primary text-white"></span>
                              <% } else if(distributor.offboarding_flag == 1  && distributor?.present_stage == 1){ %>
                                  <span class="badge text-dark" style="background-color: #FFC107;">Offboarding Started</span>
                              <% } else if(distributor?.present_stage == 2 && distributor?.offboard_flag !== 2){ %>
                                  <span class="badge bg-primary text-white" style="background-color: #FFC107;">Pending on Rsem</span>
                              <% } else if(distributor?.present_stage == 3){ %>
                                  <span class="badge bg-success">Approved by Rsem</span>
                              <% } else if (diffInHours <= 48 && distributor?.offboard_flag == 2) { %>
                                  <span class="badge bg-danger text-white">Rejected by Rsem</span>
                              <% } %>
                          </td>
                          <td><%= distributor.aseemail %></td>
                          
                          <td style="display: none;"><%= hasAction %></td>

                          <td>
                              <% if(hasAction === 1) { %>
                                  <button class="btn btn-primary open-modal-btn" data-application-id="<%= distributor.id %>">
                                      Offboard
                                  </button>
                              <% } %>
                          </td>
                      </tr>
                  <% }) %>
              <% } else { %>
                  <tr>
                      <td colspan="12" class="text-center">No distributors found.</td>
                  </tr>
              <% } %>
          </tbody>
      </table>


      <div class="overlay" id="modalOverlay" style="display: none;">
              <div class="modal-box">
                <!-- FORM -->
                <form id="dbForm" method="POST" action="/offboardPage/submit-offboarding">
                  <input type="hidden" name="application_id" id="applicationIdField" value="">
            
                  <div id="formContent">
                    <p>1. Replacement DB is Available or Not?</p>
                    <div class="toggle-group">
                      <label>
                        YES
                        <input type="checkbox" name="replacement_db" value="yes" onclick="handleToggle('replacement_db', this)">
                      </label>
                      <label>
                        NO
                        <input type="checkbox" name="replacement_db" value="no" onclick="handleToggle('replacement_db', this)">
                      </label>
                    </div>
            
                    <div id="distributorNameField" class="distributor-field" style="display: none;">
                      <label for="distributorNameInput">Replacement DB Name</label>
                      <input type="text" name="distributor_name" id="distributorNameInput" placeholder="Enter Distributor Name">
                    </div>

                    <div id="distributorCodeeField" class="distributor-field" style="display: none;">
                      <label for="distributorCodeInput">Replacement DB Code</label>
                        <input
                          type="text"
                          name="distributor_Code"
                          id="distributorCDCodeInput"
                          placeholder="Enter 10-digit DB Code"
                          maxlength="10"
                          pattern="\d{10}"
                          oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                        />
                    </div>

                    <p>2. The average L3P DB sale is less than 5 lakhs?</p>
                    <div class="toggle-group">
                      <label>
                        YES
                        <input type="checkbox" name="avg_sale" value="yes" onclick="handleToggle('avg_sale', this)">
                      </label>
                      <label>
                        NO
                        <input type="checkbox" name="avg_sale" value="no" onclick="handleToggle('avg_sale', this)">
                      </label>
                    </div>

                    <p>3. Asset Reconciliation?</p>
                    <div class="toggle-group">

                      <label>
                        YES
                        <input type="checkbox" name="Asset_Reconciliation" value="yes" onclick="handleToggle('Asset_Reconciliation', this)">
                      </label>
                      <label>
                        NO
                        <input type="checkbox" name="Asset_Reconciliation" value="no" onclick="handleToggle('Asset_Reconciliation', this)">
                      </label>

                    </div>
            
                    <button type="submit" class="submit-btn">Submit</button>
                  </div>
                </form>
            
                <div id="thankYouMessage" style="display: none; text-align: center; padding: 30px;">
                  <h2 style="color: #0000A0 !important">Thank you !</h2>
                  <p>Your response has been sucessfully submitted.</p>
                </div>
              </div>
      </div>
            
      <script>
          function handleToggle(groupName, clickedCheckbox) {
            const checkboxes = document.querySelectorAll(`input[name="${groupName}"]`);
            checkboxes.forEach(cb => {
              if (cb !== clickedCheckbox) cb.checked = false;
            });
        
            if (groupName === 'replacement_db') {
              const distField = document.getElementById('distributorNameField');
              const codeField = document.getElementById('distributorCodeeField');
              if (clickedCheckbox.value === 'yes' && clickedCheckbox.checked) {
                distField.style.display = 'block';
                codeField.style.display = 'block';
              } else {
                distField.style.display = 'none';
                codeField.style.display = 'none';
                document.getElementById('distributorNameInput').value = '';
              }
            }
          }
        
          document.getElementById('dbForm').addEventListener('submit', function (e) {
            e.preventDefault(); 

            const replacementChecked = document.querySelector('input[name="replacement_db"]:checked');
            const avgSaleChecked = document.querySelector('input[name="avg_sale"]:checked');
            const distributorInput = document.getElementById('distributorNameInput');
            const codeField = document.getElementById('distributorCDCodeInput');
            const AssetReconciliation = document.querySelector('input[name="Asset_Reconciliation"]:checked');

            if (!replacementChecked) {
              alert("Please select YES or NO for 'Replacement DB is Available'.");
              return;
            }

            if (!AssetReconciliation) {
              alert("Please select YES or NO for 'Asset Reconciliation'.");
              return;
            }

            if (replacementChecked.value === 'yes' && distributorInput.value.trim() === '') {
              alert("Please enter Distributor Name.");
              return;
            }

            if (replacementChecked.value === 'yes' && codeField.value.trim() === '') {
              alert("Please enter CD Code Name.");
              return;
            }

            if (!avgSaleChecked) {
              alert("Please select YES or NO for 'Average L3P DB sale'.");
              return;
            }

            document.getElementById('formContent').style.display = 'none';
            document.getElementById('thankYouMessage').style.display = 'block';

            setTimeout(() => {
              e.target.submit(); 
            }, 1000); 
          });

      </script>    

  </div>
</div>
     

<script>
  const codeInput = document.getElementById('distributorCDCodeInput');

  codeInput.addEventListener('keypress', function (e) {
    const char = String.fromCharCode(e.which);
    if (!/^\d$/.test(char)) {
      e.preventDefault(); 
    }
  });

  codeInput.addEventListener('paste', function (e) {
    const pasted = (e.clipboardData || window.clipboardData).getData('text');
    if (!/^\d+$/.test(pasted)) {
      e.preventDefault(); 
    }
  });
</script>


<script>
  $(document).ready(function () {
      if ($('#distributorTable tbody tr').length > 1) {
          $('#distributorTable').DataTable({
              "paging": true,
              "searching": true,
              "ordering": true,
              "info": true,
              "lengthMenu": [5, 10, 25, 50],
              "pageLength": 10,
              "columnDefs": [
                  {
                      "targets": [10],  
                      "visible": false,
                      "searchable": false
                  },
                  {
                      "targets": [7],  
                      "type": "date"
                  }
              ],
              "order": [
                  [10, 'desc'],  
                  [7, 'desc']    
              ]
          });
      }
  });
</script>


<script>
    function confirmDelete(id) {
    Swal.fire({
        title: "Are you sure?",
        text: "You won't be able to revert this!",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Yes, delete it!"
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/edit_distributor/delete_distributor?id=${id}`;
        }
    });
}
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    <% if (notification) { %>
      Swal.fire({
        icon: '<%= notification.type.toLowerCase() %>',
        title: '<%= notification.message %>',
        showConfirmButton: false,
        timer: 2500
      });
    <% } %>
  });
</script>



<script>
  document.querySelectorAll('.toggle-group').forEach(group => {
    const checkboxes = group.querySelectorAll('input[type="checkbox"]');
    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        checkboxes.forEach(other => {
          if (other !== cb) other.checked = false;
        });
      });
    });
  });

  document.querySelectorAll('.open-modal-btn').forEach(button => {
    button.addEventListener('click', () => {
      const applicationId = button.getAttribute('data-application-id');
      document.getElementById('applicationIdField').value = applicationId;
      document.getElementById('modalOverlay').style.display = 'flex';
      // Reset view
      document.getElementById('formContent').style.display = 'block';
      document.getElementById('thankYouMessage').style.display = 'none';
    });
  });

  document.getElementById('modalOverlay').addEventListener('click', (e) => {
    if (e.target.id === 'modalOverlay') {
      document.getElementById('modalOverlay').style.display = 'none';
    }
  });

  // After submission, show thank-you message
  function validateForm() {
    // Do your own validations here if needed

    // Use AJAX instead of regular form submission to stay on the modal
    const form = document.getElementById('dbForm');
    const formData = new FormData(form);

    fetch(form.action, {
      method: form.method,
      body: formData
    })
    .then(res => res.json()) // or .text() based on your backend
    .then(data => {
      document.getElementById('formContent').style.display = 'none';
      document.getElementById('thankYouMessage').style.display = 'block';
    })
    .catch(err => {
      console.error("Error submitting form", err);
      alert("Something went wrong!");
    });

    return false; // prevent default form submission
  }
</script>

<script>
  function filterTableByStatus() {
      const selectedStatus = document.getElementById("statusFilter").value;
      const rows = document.querySelectorAll("#distributorTable tbody tr");
  
      rows.forEach(row => {
          const rowStatus = row.getAttribute("data-status");
          if (selectedStatus === "All" || rowStatus === selectedStatus) {
              row.style.display = "";
          } else {
              row.style.display = "none";
          }
      });
  }
</script> 

<script>
  document.getElementById('statusFilter').addEventListener('change', function () {
    const selectedStatus = this.value.toLowerCase();
    const table = document.getElementById('distributorTable');
    const rows = table.querySelectorAll('tbody tr');

    rows.forEach(row => {
      const statusCell = row.querySelector('td:nth-child(9)'); 
      if (!statusCell) return;

      const statusText = statusCell.textContent.trim().toLowerCase();

      if (selectedStatus === '' || statusText.includes(selectedStatus)) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  });
</script>

