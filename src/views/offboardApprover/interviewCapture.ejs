<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Distributor Resignation Form</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        background-color: #f8f9fa;
        font-family: "Segoe UI", sans-serif;
      }

      .header {
        background-color: #0000a8;
        color: white;
        padding: 20px 0;
        text-align: center;
        font-size: 2rem;
        font-weight: bold;
        letter-spacing: 2px;
      }

      .form-container {
        background-color: #f6f7fb;
        padding: 30px;
        border-radius: 15px;
        max-width: 700px;
        margin: 40px auto;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      }

      .form-heading {
        font-weight: 600;
        text-align: center;
        color: #2b2b8f;
        margin-bottom: 10px;
      }

      .form-subtext {
        text-align: center;
        color: #5a5a89;
        margin-bottom: 30px;
        font-size: 1rem;
      }
      .form-check-input {
        appearance: none;
        -webkit-appearance: none;
        border: 2px solid #0000a8;
        width: 1.5em;
        height: 1.5em;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        position: relative;
        background-color: #fff;
      }

      .form-check-input:checked {
        background-color: #0000a8;
        border-color: #0000a8;
      }

      .form-check-input:checked::after {
        color: white;
        font-size: 1em;
        position: absolute;
        top: 0;
        left: 3px;
      }

      .form-label {
        font-weight: 500;
      }

      .question-card {
        border-radius: 10px;
      }
      textarea {
        resize: none;
      }
    </style>
  </head>
  <body>
    <div class="header">MARS WRIGLEY</div>

    <div class="container py-4">
      <div class="row justify-content-center">
        <div class="col-lg-6">
          <div class="shadow question-card">
            <div class="card-header bg-primary text-white">
              <h4 class="mb-0 p-2 text-center">Mark Exit Interview Details (1 - 10)</h4>
            </div>

            <div class="p-4">
          
              <div class="mb-4">
                <label class="form-label fw-bold"
                  >1. What is your understanding of the onboarding
                  process?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

             
              <div class="mb-4">
                <label class="form-label fw-bold"
                  >2. What challenges did you face during the workflow?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >3. How would you rate the DB support process?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >4. What improvements would you recommend?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >5. Did you face any system-related issues?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >6. Were you able to complete tasks on time?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >7. What feedback do you have for your reporting
                  manager?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >8. Were the guidelines clear & easy to follow?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >9. Rate your overall experience.</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold"
                  >10. Any additional comments?</label
                >
                <textarea
                  class="form-control"
                  rows="3"
                  placeholder="Write your answer..."
                ></textarea>
              </div>

              <button class="btn btn-primary btn-lg w-100">
                Submit Answers
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      const approval = document.getElementById("dbApproval");
      const declineSection = document.getElementById("declineSection");
      const forwardSection = document.getElementById("forwardSection");

      approval.addEventListener("change", function () {
        declineSection.style.display =
          this.value === "decline" ? "block" : "none";
      });

      function submitDbResponse() {
        if (approval.value === "") {
          alert("Please select approval status.");
          return;
        }

        if (approval.value === "approve") {
          alert("Claim Approved Successfully!");
          return;
        }

        let amount = document.getElementById("counterAmount").value.trim();
        let reason = document.getElementById("counterReason").value.trim();
        let unit = document.getElementById("counterUnit").value;

        if (!amount || !reason) {
          alert("Please enter amount.");
          return;
        }

        document.getElementById("fwdAmount").textContent = amount + " " + unit;
        document.getElementById("fwdReason").textContent = reason;

        forwardSection.style.display = "block";

        alert("Declined. Forwarded to ASM/DT Team.");
      }
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const fieldLimits = {
          gsvAverage: 20,
        };

        const inputFields = document.querySelectorAll("input");

        inputFields.forEach((input) => {
          input.addEventListener("input", function () {
            const fieldId = input.id;
            const fieldValue = input.value;

            if (
              fieldLimits[fieldId] &&
              fieldValue.length > fieldLimits[fieldId]
            ) {
              input.value = fieldValue.slice(0, fieldLimits[fieldId]);

              Swal.fire({
                icon: "warning",
                title: "Input Limit Exceeded",
                text: `The maximum length for '${
                  input.labels?.[0]?.textContent || fieldId
                }' is ${fieldLimits[fieldId]} characters.`,
                position: "top-end",
                toast: true,
                showConfirmButton: false,
                timer: 3000,
              });
            }
          });
        });
      });
    </script>

    <script>
      document
        .getElementById("resignationForm")
        .addEventListener("submit", function (e) {
          const checkboxes = document.querySelectorAll(
            'input[name="low_turnover"], input[name="low_roi"], input[name="limitation_in_investment"], input[name="db_going_out_of_business"], input[name="increasing_cost"], input[name="not_ready_for_additional_infrastructure"]'
          );

          const atLeastOneChecked = Array.from(checkboxes).some(
            (checkbox) => checkbox.checked
          );

          if (!atLeastOneChecked) {
            e.preventDefault();

            Swal.fire({
              icon: "warning",
              title: "Oops!",
              text: "Please select at least one reason for exit before submitting.",
              confirmButtonColor: "#3085d6",
            });
          } else {
            const submitBtn = document.querySelector(
              "#resignationForm button[type='submit']"
            );
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.innerText = "Submitting..."; 
            }
          }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
