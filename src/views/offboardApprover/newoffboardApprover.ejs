<script>
  function openGSTModal(element) {
    selected = element.dataset.applicationId;
    total_complete_approval_level = element.dataset.total_complete_approval_level;
    document.getElementById("gstModalBackdrop").classList.add("show");
    document.getElementById("gstModal").classList.add("show");
  }

  function closeGSTModal() {
    document.getElementById("gstModalBackdrop").classList.remove("show");
    document.getElementById("gstModal").classList.remove("show");
  }

  document.addEventListener("change", function () {
    if (document.getElementById("gstNo").checked) {
      document.getElementById("gstRemarkSection").classList.remove("d-none");
    } else {
      document.getElementById("gstRemarkSection").classList.add("d-none");
    }
  });
 document.getElementById("gstSubmitBtn").onclick = async () => {
  const submitBtn = document.getElementById("gstSubmitBtn");

  // Disable button immediately
  submitBtn.disabled = true;

  const gstYes = document.getElementById("gstYes");
  const gstNo = document.getElementById("gstNo");
  const gstRemark = document.getElementById("gstRemark");
  const gstNumber = document.getElementById("gstNumber");

  if (!gstNumber.value.trim()) {
    submitBtn.disabled = false; // re-enable
    Swal.fire({
      toast: true,
      position: "top-end",
      icon: "error",
      title: "Please enter GST Number",
      showConfirmButton: false,
      timer: 2000,
    });
    return;
  }

  if (!gstYes.checked && !gstNo.checked) {
    submitBtn.disabled = false;
    Swal.fire({
      toast: true,
      position: "top-end",
      icon: "error",
      title: "Please select GST matching status",
      showConfirmButton: false,
      timer: 2000,
    });
    return;
  }

  if (gstNo.checked && !gstRemark.value.trim()) {
    submitBtn.disabled = false;
    Swal.fire({
      toast: true,
      position: "top-end",
      icon: "error",
      title: "Please enter remark for GST mismatch",
      showConfirmButton: false,
      timer: 2000,
    });
    return;
  }

  try {
    const response = await fetch("/newoffboardApprover/gstsubmit", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        application_id: selected,
        gstNumber: gstNumber.value,
        gstYes: gstYes.checked ? "yes" : "no",
        gstRemark: gstRemark.value,
        total_complete_approval_level: total_complete_approval_level
      }),
    });

    const result = await response.json();

    Swal.fire({
      toast: true,
      position: "top-end",
      icon: result.type === "success" ? "success" : "info",
      title: result.message,
      showConfirmButton: false,
      timer: 3000,
      timerProgressBar: true,
      didClose: () => {
        if (result.type === "success") {
          closeModal("optionModal");
          location.reload();
        } else {
          submitBtn.disabled = false;
        }
      },
    });
  } catch (err) {
    submitBtn.disabled = false;
    console.error("Error:", err);
    Swal.fire({
      toast: true,
      position: "top-end",
      icon: "error",
      title: "Failed to send request. Please try again.",
      showConfirmButton: false,
      timer: 3000,
    });
  }
};

</script>

<script>
  function openBlockDbModal(element) {
    selected = element.dataset.applicationId;
     total_complete_approval_level = element.dataset.total_complete_approval_level;
    document.getElementById("blockDbBackdrop").classList.add("show");
    document.getElementById("blockDbModal").classList.add("show");
  }
  function closeBlockDbModal() {
    document.getElementById("blockDbBackdrop").classList.remove("show");
    document.getElementById("blockDbModal").classList.remove("show");
  }
  document.getElementById("blockDbSubmit").onclick = async function () {

  const btn = this;
  btn.disabled = true;
  btn.innerText = "Submitting...";

  const blockDbSelect = document.getElementById("blockDbSelect").value;
  const blockDbRemarks = document.getElementById("blockDbRemarks").value.trim();

  if (!blockDbSelect) {
    Swal.fire({
      toast: true,
      position: "top-end",
      icon: "error",
      title: "Please select DB Code action",
      showConfirmButton: false,
      timer: 2000,
      timerProgressBar: true,
    });

    btn.disabled = false;
    btn.innerText = "Submit";
    return;
  }

  if (blockDbSelect === "not_blocked" && !blockDbRemarks) {
    Swal.fire({
      toast: true,
      position: "top-end",
      icon: "error",
      title: "Remarks are mandatory when DB is Not Blocked",
      showConfirmButton: false,
      timer: 2500,
      timerProgressBar: true,
    });

    btn.disabled = false;
    btn.innerText = "Submit";
    return;
  }

  try {
    const formData = new FormData();
    formData.append("application_id", selected);
    formData.append("blockDbRemarks", blockDbRemarks);
    formData.append("blockDbSelect", blockDbSelect);
    formData.append(
      "total_complete_approval_level",
      total_complete_approval_level
    );

    const response = await fetch("/newoffboardApprover/blockDbSubmit", {
      method: "POST",
      body: formData,
    });

    const result = await response.json();

    Swal.fire({
      toast: true,
      position: "top-end",
      icon: result.type === "success" ? "success" : "info",
      title: result.message,
      showConfirmButton: false,
      timer: 3000,
      timerProgressBar: true,
      didClose: () => {
        if (result.type === "success") {
          closeModal("optionModal");
          location.reload();
        }
      },
    });
  } catch (err) {
    console.error("Error:", err);

    Swal.fire({
      toast: true,
      position: "top-end",
      icon: "error",
      title: "Something went wrong",
      showConfirmButton: false,
      timer: 3000,
    });

    btn.disabled = false;
    btn.innerText = "Submit";
  }

  closeBlockDbModal();
};
   
  </script>

