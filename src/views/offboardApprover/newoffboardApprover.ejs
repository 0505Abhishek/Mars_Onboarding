      <p>Please accept or decline the GST Reversal request.</p>

      <div class="form-check">
        <input class="form-check-input" type="radio" name="gstReversal" value="accept" id="revAccept">
        <label class="form-check-label mx-2" for="revAccept">Accept</label>
