<script>
  let selectedApplicationId = null;

  function openModal(id) {
    document.getElementById(id).style.display = "flex";
  }

  function closeModal(id) {
    document.getElementById(id).style.display = "none";
  }

  
  document.querySelectorAll(".openOption").forEach((btn) => {
    btn.addEventListener("click", function (e) {
      e.stopPropagation();
      selectedApplicationId = this.dataset.applicationId;
      document.getElementById("application_id").value = selectedApplicationId;
      openModal("optionModal");
    });
  });

  
  document.querySelectorAll(".close").forEach((btn) => {
    btn.onclick = () => closeModal(btn.dataset.close);
  });

  document.getElementById("btnTermination").onclick = () => {
    document.getElementById("offboard_type").value = "termination";
    closeModal("optionModal");
    openModal("terminationModal");
  };

  
  document.getElementById("btnResignation").onclick = async () => {
    if (!selectedApplicationId) {
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "error",
        title: "Please select a distributor first!",
        showConfirmButton: false,
        timer: 2000,
        timerProgressBar: true,
      });
      return;
    }

    const confirmResult = await Swal.fire({
      title: "Initiate Resignation?",
      text: "An email with resignation submission link will be sent to the distributor.",
      icon: "question",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Yes, Send Email",
      cancelButtonText: "Cancel",
    });

    if (!confirmResult.isConfirmed) return;

    

    try {
      const response = await fetch(
        "/newoffboardApprover/initiateOffboardAsmaction",
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            application_id: selectedApplicationId,
            offboard_type: "resignation",
            reason: [],
          }),
        }
      );

      const result = await response.json();
      closeModal("optionModal");
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: result.type === "success" ? "success" : "info",
        title: result.message,
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
      });
       if (result.type === "success") {
      location.reload();
    }
    } catch (err) {
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "error",
        title: "Failed to send email. Please try again.",
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
      });
    }
  };

  document.querySelectorAll("[data-back]").forEach((btn) => {
    btn.onclick = () => {
      closeModal(btn.dataset.back);
      openModal(btn.dataset.open);
    };
  });

  const form = document.getElementById("offboardForm");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

    const submitButton = form.querySelector('button[type="submit"]');
    submitButton.innerText = "Submitting...";
    submitButton.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      const reason = formData.getAll("reason[]");
      data.reason = reason;

      try {
        const res = await fetch(
          "/newoffboardApprover/initiateOffboardAsmaction",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          }
        );
        const result = await res.json();

     Swal.fire({
        toast: true,
        position: "top-end",
        icon: result.type,
        title: result.message,
        showConfirmButton: false,
        timer: 2000,
        timerProgressBar: true,
      }).then(() => {
        if (result.type === "success") {
          closeModal("terminationModal");
          location.reload();
        } else {
          submitButton.innerText = "SUBMIT";
          submitButton.disabled = false;
        }
      });
      } catch (err) {
        Swal.fire({
          toast: true,
          position: "top-end",
          icon: "error",
          title: "Something went wrong!",
          showConfirmButton: false,
          timer: 2000,
          timerProgressBar: true,
        });
      }
    });
  }
