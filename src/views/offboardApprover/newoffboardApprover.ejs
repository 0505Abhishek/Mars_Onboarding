<script>
let currentApplicationId = null;

function openInitialRSMModal(button) {

  currentApplicationId = button.getAttribute("data-application-id");

  document.getElementById("rsmDistributor").innerText =
    button.getAttribute("data-name") || "-";

  document.getElementById("rsmDbType").innerText =
    button.getAttribute("data-dbtype") || "-";

  document.getElementById("rsmOffboardDate").innerText =
    button.getAttribute("data-offboarddate") || "-";

  document.getElementById("rsmDbCode").innerText =
    button.getAttribute("data-dbcode") || "-";

  const reasonList = document.getElementById("rsmReason");
  reasonList.innerHTML = "";

  const reasonData = button.getAttribute("data-reasons");

  if (reasonData && reasonData !== "[]") {
    try {
      const reasons = JSON.parse(reasonData);
      reasons.forEach((reason, index) => {
        const li = document.createElement("li");
        li.innerText = (index + 1) + ". " + reason;
        reasonList.appendChild(li);
      });
    } catch (e) {
      reasonList.innerHTML = "<li>Invalid reason format</li>";
    }
  } else {
    reasonList.innerHTML = "<li>No specific reasons provided.</li>";
  }

  document.getElementById("rsmModalBackdrop").classList.add("show");
  document.getElementById("rsmInitialModal").classList.add("show");
}

document.getElementById("rsmModalClose").onclick = closeInitialRSMModal;
document.getElementById("rsmModalBackdrop").onclick = closeInitialRSMModal;

function closeInitialRSMModal() {
  document.getElementById("rsmModalBackdrop").classList.remove("show");
  document.getElementById("rsmInitialModal").classList.remove("show");
  document.getElementById("rsmRemarks").value = "";
  currentApplicationId = null;
}
// APPROVE
document.getElementById("rsmApproveBtn").onclick = async function () {
  if (!currentApplicationId)
    return Swal.fire("Error", "Session expired. Reopen modal.", "error");

  const remarks = document.getElementById("rsmRemarks").value.trim();
  
  const { isConfirmed } = await Swal.fire({
    title: "Approve?",
    text: "Send to next level?",
    icon: "question",
    showCancelButton: true,
    confirmButtonText: "Yes",
  });

  if (!isConfirmed) return;

  // Disable both buttons immediately
  document.getElementById("rsmApproveBtn").disabled = true;
  document.getElementById("rsmReturnBtn").disabled = true;

  try {
    const res = await fetch("/newoffboardApprover/rsmInitialAction", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        application_id: currentApplicationId,
        action: "approve",
        remarks
      }),
    });

    const result = await res.json();

    Swal.fire(
      result.success ? "Approved" : "Error",
      result.message,
      result.success ? "success" : "error"
    );

    if (result.success) location.reload();
    else {
      // Re-enable buttons if something went wrong
      document.getElementById("rsmApproveBtn").disabled = false;
      document.getElementById("rsmReturnBtn").disabled = false;
    }
  } catch (error) {
    Swal.fire("Error", "Something went wrong.", "error");
    document.getElementById("rsmApproveBtn").disabled = false;
    document.getElementById("rsmReturnBtn").disabled = false;
  }
};

// RETURN
document.getElementById("rsmReturnBtn").onclick = async function () {
  if (!currentApplicationId)
    return Swal.fire("Error", "Session expired.", "error");

  const remarks = document.getElementById("rsmRemarks").value.trim();

  if (!remarks)
    return Swal.fire("Required", "Remarks mandatory for return", "warning");

  const { isConfirmed } = await Swal.fire({
    title: "Return?",
    text: "Send back to ASM?",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes",
  });

  if (!isConfirmed) return;

  // Disable both buttons immediately
  document.getElementById("rsmApproveBtn").disabled = true;
  document.getElementById("rsmReturnBtn").disabled = true;

  try {
    const res = await fetch("/newoffboardApprover/rsmInitialAction", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        application_id: currentApplicationId,
        action: "return",
        remarks
      }),
    });

    const result = await res.json();

    Swal.fire(
      result.success ? "Returned" : "Error",
      result.message,
      result.success ? "info" : "error"
    );

    if (result.success) location.reload();
    else {
      
      document.getElementById("rsmApproveBtn").disabled = false;
      document.getElementById("rsmReturnBtn").disabled = false;
    }
  } catch (error) {
    Swal.fire("Error", "Something went wrong.", "error");
    document.getElementById("rsmApproveBtn").disabled = false;
    document.getElementById("rsmReturnBtn").disabled = false;
  }
};
</script>


<script>
let currentApplicationIdd = null;

function openGSTReversalModal(button) {
  currentApplicationIdd = button.getAttribute("data-application-id");

  document.getElementById("gstReversalModal").style.display = "block";
  document.getElementById("gstReversalBackdrop").style.display = "block";
}

function closeGSTReversalModal() {
  document.getElementById("gstReversalModal").style.display = "none";
  document.getElementById("gstReversalBackdrop").style.display = "none";

  document.querySelectorAll('input[name="gstReversal"]').forEach(r => r.checked = false);
  document.getElementById("declineReason").value = "";
  document.getElementById("declineReasonSection").style.display = "none";
}

document.addEventListener("change", function(e) {
  if (e.target.name === "gstReversal") {
    document.getElementById("declineReasonSection").style.display =
      e.target.value === "decline" ? "block" : "none";
  }
});

async function submitGSTReversal() {
  const selected = document.querySelector('input[name="gstReversal"]:checked');

  if (!selected) {
    Swal.fire("Warning", "Please select Accept or Decline", "warning");
    return;
  }

  const decision = selected.value;
  const remark = document.getElementById("declineReason").value.trim();

  if (decision === "decline" && !remark) {
    Swal.fire("Warning", "Please enter decline reason", "warning");
    return;
  }

  try {
    const response = await fetch("/newoffboardApprover/submitGstReversal", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        application_id: currentApplicationIdd,
        decision: decision,
        remark: remark
      }),
    });

    const result = await response.json();

    if (result.type === "success") {
      Swal.fire("Success", result.message, "success").then(() => {
        closeGSTReversalModal();
        location.reload();
      });
    } else {
      Swal.fire("Error", result.message, "error");
    }
  } catch (error) {
    console.error(error);
    Swal.fire("Error", "Something went wrong", "error");
  }
}
</script>

<script>
let asmSelectedApplicationId = null;

function openAsmOverrideModal(element) {

  asmSelectedApplicationId = element.dataset.applicationId;

  document.getElementById("asmClaimType").innerText =
    element.dataset.claimType || "-";

  document.getElementById("asmClaimAmount").innerText =
    element.dataset.claimAmount || "0";

  document.getElementById("asmOverrideBackdrop").classList.add("show");
  document.getElementById("asmOverrideModal").classList.add("show");

  const approval = document.getElementById("asmDbApproval");
  const declineSection = document.getElementById("asmDeclineSection");

  approval.value = "";
  declineSection.style.display = "none";

  approval.onchange = function () {
    declineSection.style.display =
      this.value === "decline" ? "block" : "none";
  };
}

function closeAsmOverrideModal() {
  document.getElementById("asmOverrideBackdrop").classList.remove("show");
  document.getElementById("asmOverrideModal").classList.remove("show");
}

document.getElementById("asmSubmitBtn").onclick = async function () {

  const btn = this;
  const approval = document.getElementById("asmDbApproval").value;

  if (!approval) {
    alert("Please select approval status.");
    return;
  }

  btn.disabled = true;
  btn.innerText = "Processing...";

  let data = {
    application_id: asmSelectedApplicationId,
    approval: approval
  };

  if (approval === "decline") {
    const amount = document.getElementById("asmCounterAmount").value.trim();
    const reason = document.getElementById("asmCounterReason").value.trim();

    if (!amount || !reason) {
      alert("Please enter both amount and reason.");
      btn.disabled = false;
      btn.innerText = "Submit";
      return;
    }

    data.amount = amount;
    data.reason = reason;
  }

  try {
    const response = await fetch(
      "/newoffboardApprover/submitDbResponseASM",
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      }
    );

    const result = await response.json();

    alert(result.message || "Response submitted successfully");
    location.reload();

  } catch (err) {
    console.error(err);
    alert("Something went wrong");
    btn.disabled = false;
    btn.innerText = "Submit";
  }
};
</script>

<script>

function openFnfAcceptanceModal(element) {
  selected = element.dataset.applicationId;
  total_complete_approval_level = element.dataset.total_complete_approval_level;

  const fnfPdf = element.dataset.fnfPdf;
  const downloadLink = document.getElementById("fnfDownloadLink");

  if (fnfPdf) {
    const filename = fnfPdf.split('/').pop();
    downloadLink.href = `/newoffboardApprover/download-fnf/${filename}`;
    downloadLink.setAttribute("download", "");
  } else {
    downloadLink.href = "#";
    downloadLink.removeAttribute("download");
  }

  document.getElementById("fnfAccModalBackdrop").classList.add("show");
  document.getElementById("fnfAccModal").classList.add("show");
}

function closeFnfAccModal() {
  document.getElementById("fnfAccModalBackdrop").classList.remove("show");
  document.getElementById("fnfAccModal").classList.remove("show");
}

async function submitFnfAction(action) {

  const confirm = await Swal.fire({
    title: "Are you sure?",
    text: `You want to ${action} this request?`,
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: action === "approve" ? "#28a745" : "#d33",
    confirmButtonText: `Yes, ${action}`,
  });

  if (!confirm.isConfirmed) return;

  try {
    const response = await fetch("/newoffboardApprover/FnfsnfSubmit", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        application_id: selected,
        total_complete_approval_level: total_complete_approval_level,
        action: action // 🔥 important
      }),
    });

    const result = await response.json();

    Swal.fire({
      toast: true,
      position: "top-end",
      icon: result.type === "success" ? "success" : "error",
      title: result.message,
      showConfirmButton: false,
      timer: 3000,
      didClose: () => {
        if (result.type === "success") {
          location.reload();
        }
      },
    });

  } catch (err) {
    console.error(err);
    Swal.fire({
      icon: "error",
      title: "Something went wrong!",
    });
  }

  closeFnfAccModal();
}


// ✅ Approve button
document.getElementById("fnfAccSubmitBtn").onclick = function () {
  submitFnfAction("approve");
};

// ❌ Reject button
document.getElementById("fnfAccRejectBtn").onclick = function () {
  submitFnfAction("decline");
};

</script>

