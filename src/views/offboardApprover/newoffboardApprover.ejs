  document.getElementById("claimSubmitBtn").onclick = async function () {

    const btn = this; 
    btn.disabled = true;
    btn.innerText = "Submitting...";

    const type = document.getElementById("claimType").value;
    const amount = document.getElementById("claimAmount").value;

    if (!type) {
      alert("Please select claim type.");
      btn.disabled = false;
      btn.innerText = "Submit";
      return;
    }

    if (amount === "" || amount <= 0) {
      alert("Please enter a valid amount.");
      btn.disabled = false;
      btn.innerText = "Submit";
      return;
    }

   
     if (!type && !amount) {
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "error",
        title: "Please select asset transfer status",
        showConfirmButton: false,
        timer: 2000,
        timerProgressBar: true,
      });
      btn.disabled = false;
      btn.innerText = "Submit";
      return;
    }

    
    try {
      const response = await fetch(
        "/newoffboardApprover/claimSubmit",
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
             application_id: selected,
            type: type,
            amount:amount,
            total_complete_approval_level:total_complete_approval_level
          }),
        }
      );

      const result = await response.json();

      Swal.fire({
        toast: true,
        position: "top-end",
        icon: result.type === "success" ? "success" : "info",
        title: result.message,
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
        didClose: () => {
          if (result.type === "success") {
            closeModal("optionModal");
            location.reload();
          }
        },
      });
    } catch (err) {
      console.error("Error initiating resignation:", err);
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "error",
        title: "Failed to send email. Please try again.",
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
      });
    }

    btn.disabled = false;
    btn.innerText = "Submit";

    closeClaimModal();
  };
</script>

