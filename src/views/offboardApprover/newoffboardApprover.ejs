  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
  rel="stylesheet"
/>
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"
/>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link
  rel="stylesheet"
  href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css"
/>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<style>
  .hidden {
    display: none;
  }

    
</style>

<style>
  .scroll-section {
    max-height: 300px;
    overflow-y: auto;
    border: 1px solid #ccc;
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 5px;
    background: #f8f9fa;
  }
</style>

<style>
  .table-dark th {
    color: #0000a0 !important;
    background-color: #e0e0fc;
    border: 1px solid rgb(224, 203, 203);
  }

  #distributorTable tbody tr:nth-child(odd) td {
    background: #ffffff !important;
  }

  #distributorTable tbody tr:nth-child(even) td {
    background: #efefff !important;
  }
</style>

<style>
  /* Fullscreen overlay */
  .overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-box {
    background: white;
    border: 3px solid #0000a0;
    border-radius: 25px;
    padding: 30px;
    width: 500px;
    text-align: center;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
  }

  .toggle-group {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin: 10px 0 20px 0;
  }

  .toggle-group label {
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  input[type="checkbox"] {
    width: 40px;
    height: 20px;
    background: #ccc;
    border-radius: 20px;
    position: relative;
    outline: none;
    cursor: pointer;
    transition: background 0.3s;
  }

  input[type="checkbox"]:checked {
    background: #14e651;
  }

  input[type="checkbox"]:checked::before {
    transform: translateX(20px);
  }

  /* Submit Button */
  .submit-btn {
    background-color: #007bff;
    color: white;
    padding: 12px 25px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-weight: bold;
  }

  .submit-btn:hover {
    background-color: #0056b3;
  }
</style>

<style>
  .distributor-field {
    margin-top: 20px;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
  }

  .distributor-field label {
    font-weight: bold;
    margin-bottom: 6px;
    font-size: 14px;
  }

  .distributor-field input[type="text"] {
    padding: 8px 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .distributor-field input[type="text"]:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
  }

  

  .close {
    float: right;
    font-size: 14px;
    cursor: pointer;
    color: #888;
    padding-top: 5px;
  }

  .resignation-header {
    background: #0d2bb3;
    padding: 25px;
    color: #fff;
    text-align: center;
    font-weight: bold;
    border-radius: 8px 8px 0 0;
  }

  .resignation-body {
    padding: 30px;
  }

  .reason-box {
    border: 1px solid #0d2bb3;
    padding: 10px 15px;
    border-radius: 4px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .btn-primary-custom {
    background: #0d2bb3;
    border: none;
    padding: 8px 25px;
    color: #fff;
    border-radius: 4px;
  }

  .btn-outline-custom {
    border: 1px solid #0d2bb3;
    padding: 8px 25px;
    border-radius: 4px;
    background: #fff;
    color: #0d2bb3;
  }

  .resignationModal {
    width: 687px !important;
    padding: 1px !important;
  }

  .terminate-box {
    width: 420px;
  }

  .reason-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 15px;
    cursor: pointer;
  }

  .reason-text {
    flex: 1;
    padding: 10px 14px;
    border: 2px solid #002aff;
    border-radius: 6px;
    font-size: 15px;
    color: #002aff;
    display: flex;
    align-items: center;
  }

  .reason-row input[type="checkbox"]:checked + .reason-text {
    background: #e9edff;
    border-color: #002aff;
    font-weight: 500;
  }

  .close-btn {
    position: absolute;
    right: 15px;
    top: 10px;
    cursor: pointer;
    color: #333;
    font-size: 18px;
  }

  .rsem-action-btn {
    padding: 6px 12px;
    background: #1ca81c;
    border: none;
    color: white;
    border-radius: 5px;
    font-size: 14px;
    cursor: pointer;
  }

  .rsem-action-btn:hover {
    background: #138813;
  }

  .action-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 20px;
  }

  .approve-btn {
    background: #0d6efd;
    color: #fff;
    padding: 10px 18px;
    border-radius: 5px;
    border: none;
  }

  /* .return-btn {
  color: #fff;
  padding: 10px 18px;
  border-radius: 5px;
  border: none;
} */

  #rsemModal {
    width: 461px !important;
    height: 650px;
    overflow-x: scroll;
  }
  #assetModal {
    width: 461px !important;
  }

  .modalwidth {
    width: 461px !important;
  }

  .section-title {
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 6px;
  }

  .section-box {
    background: #f8f9fb;
    padding: 12px 15px;
    border-radius: 8px;
    border: 1px solid #e4e6eb;
  }
  .section-box-textarea {
    background: #f8f9fb;
    border-radius: 8px;
    padding: 10px;
    border: 1px solid #e4e6eb;
  }

  .action-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 18px;
  }

  .approve-btn {
    background: #28a745;
    color: #fff;
    padding: 8px 16px;
    border: none;
    border-radius: 6px;
    font-weight: 600;
  }
  .return-btn {
    background: #3f51b5;
    color: #fff;
    padding: 8px 16px;
    border: none;
    border-radius: 6px;
    font-weight: 600;
  }

  .modal-section {
    margin-bottom: 18px;
  }

  .custom-modal::-webkit-scrollbar {
    width: 8px;
  }

  .custom-modal::-webkit-scrollbar-track {
    background: #e3e7ff;
    border-radius: 10px;
  }

  .newmodalstyle {
    width: 501px !important;
  }

  .custom-modal::-webkit-scrollbar-thumb {
    background: #3f51b5;
    border-radius: 10px;
  }

  .custom-modal::-webkit-scrollbar-thumb:hover {
    background: #283593;
  }
  .hidden-field {
    display: none;
  }

  .hidden-field.show {
    display: block;
  }

  .custom-backdrop {
    position: fixed;
    inset: 0;
    display: none;
    z-index: 99998;
  }

  .custom-backdrop.show {
    display: block;
  }

  /* Modal Box */
  .custom-modal-box {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    width: 400px;
    max-width: 90%;
    background: white;
    border-radius: 10px;
    padding: 20px;
    display: none;
    transition: 0.2s ease;
    z-index: 99999;
  }

  .custom-modal-box.show {
    display: block;
    transform: translate(-50%, -50%) scale(1);
  }

  /* Inner close button */
  .close-btn {
    position: absolute;
    right: 15px;
    top: 8px;
    cursor: pointer;
    font-size: 20px;
  }

  #rsemReason li {
    list-style: auto !important;
  }

  #rsemReason {
    padding-left: 10px;
  }

  .interviewcss{
    overflow-x: scroll;
    height: 71%;
  }
</style>

<div class="container mt-4">
  <div class="table-responsive">
    <div class="mb-3 d-flex justify-content-end">
      <div>
        <label for="statusFilter" class="form-label">Filter by Status:</label>
        <select
          id="statusFilter"
          class="form-select"
          onchange="filterTableByStatus()"
        >
          <option value="All">All</option>
          <option value="Pending">Pending</option>
          <option value="Approved">Approved</option>
          <option value="Rejected">Rejected</option>
        </select>
      </div>
    </div>

    <table id="distributorTable" class="table table-hover table-bordered">
      <thead class="table-dark">
        <tr>
          <th class="toggle-col no-sort">
            Unique Application Code
            <i class="px-2" style="cursor: pointer">
              <img
                id="toggleIcon"
                class="default-icon"
                src="../../public/images/marsoffboardarrow.png"
                alt="Toggle"
                width="16px"
                style="cursor: pointer"
              />
            </i>
          </th>
          <th class="dummy-col">Firm's Name</th>
          <th>DB Channel</th>
          <th>DB Code</th>
          <th>Distributor's Name</th>
          <th>Email ID</th>
          <th>Mobile Number</th>
          <th>Freight Expenses %</th>
          <th>Start Date</th>
          <th>Created By</th>

          <th class="dummy-col">ASM</th>
          <th class="dummy-col">RSEM</th>
          <th class="dummy-col">DT Team</th>
          <th class="dummy-col">SNF</th>
          <th class="dummy-col">TAX/GST</th>
          <th class="dummy-col">O2C</th>
          <th class="dummy-col">MDM</th>
          <th class="dummy-col">RSM</th>
          <th class="dummy-col">NSM</th>
          <th class="dummy-col">AP Team</th>
          <th class="dummy-col">RECORDS</th>
        </tr>
      </thead>

      <tbody>
        <% if (data.length > 0) { %> <% data.forEach((distributor, index) => {
        %>

        <tr
          data-application-id="<%= distributor.applicationId %>"
          data-status="<%
              if (distributor.is_final_approval == 0 && distributor.offboard_flag != 2 && distributor.distributor_flag == 1 && distributor.can_approve == 1) {
            %>Pending<%
              } else if (distributor.is_final_approval == 1 && distributor.offboard_flag != 2 && distributor.distributor_flag == 1) {
            %>Approved<%
              } else if (distributor.offboard_flag == 2 && distributor.distributor_flag == 1) {
            %>Rejected<%
              } else {
            %>Pending<%
              }
            %>"
        >
          <td><%= distributor.mars_code %></td>
          <td><%= distributor.firmName %></td>
          <td class="hidden-col"><%= distributor.dbType %></td>
          <td class="hidden-col"><%= distributor.distributor_code %></td>
          <td class="hidden-col"><%= distributor.distributorName %></td>
          <td class="hidden-col"><%= distributor.email %></td>
          <td class="hidden-col"><%= distributor.contactNumber %></td>
          <td class="hidden-col"><%= distributor.FreightExpenses %></td>

          <td class="hidden-col">
            <%= new
            Date(distributor.created_at).toLocaleDateString('en-CA') %>
          </td>

          <td class="hidden-col"><%= distributor.aseemail %></td>

          <td>
              <% 
                const appActions = get_action_button.find(
                  item => item.applicationId == distributor.applicationId
                );

                const canShowASMAction =
                  appActions && appActions.get_approvel_button.length > 0;

                const flag_check = distributor.flag;
                const status_check = distributor.offboard_status;
                const dt_team_flag = distributor.dt_team_flag;
                const db_replace_status = distributor.db_replace_status;
                const confirm_asset_status = distributor.confirm_asset_status;
              %>

              <% if (role_name === 'ASM') { %>

                <% if (status_check != 1) { %>
                  <button
                    class="btn openOption btn-primary"
                    data-appActions="<%= flag_check %>"
                    data-application-id="<%= distributor.applicationId %>"
                    data-status_asm="<%= status_check %>"
                    data-total_complete_approval_level="<%= distributor.total_complete_approval_level %>"
                  >
                    Action
                  </button>
                <% } %>

              <% if (dt_team_flag == 1) { %>
                  <% if (distributor.replacementstatus != 1) { %>
                    <button
                      onclick="openReplacementModal('<%= distributor.applicationId %>')"
                      class="btn btn-primary"
                    >
                      DB Replacement
                    </button>
                  <% } %>

                    <% if (db_replace_status == 1 && confirm_asset_status != 1) { %>
                    <button
                      class="btn btn-outline-primary"
                      onclick="openAssetModal('<%= distributor.applicationId %>')"
                    >
                      Confirm Asset Reconciliation
                    </button>
                  <% } %>

                <% } %>

                  <% 
                    const isDbExpired =
                      distributor.db_response_status === 'PENDING' &&
                      distributor.db_deadline &&
                      new Date(distributor.db_deadline) < new Date();

                    const isTermination = distributor.offboard_type === 'termination';
                  %>

                  <% if (role_name === 'ASM' && isTermination && isDbExpired) { %>
                    <button
                      class="btn btn-danger"
                      onclick="openAsmOverrideModal(this)"
                      data-application-id="<%= distributor.applicationId %>"
                      data-claim-type="<%= distributor.claim_type %>"
                      data-claim-amount="<%= distributor.claim_amount %>"
                    >
                      Claim Clearance (DB No Response)
                    </button>
                    
                  <% } %>

              <% } %>
           </td>

          <td>
            <% 
            const canShowRSEMAction = appActions && appActions.get_approvel_button && appActions.get_approvel_button.some(btn => btn.role_name == 'RSEM');
            %>
            <% if (canShowRSEMAction) { %>
            <button
              class="rsem-action-btn btn btn-primary btn-sm"
              data-application-id="<%= distributor.applicationId %>"
              data-name="<%= distributor.distributorName %>"
              data-dbtype="<%= distributor.dbType || '--' %>"
              data-dbcode="<%= distributor.distributor_code || '--' %>"
              data-offboarddate="<%= new Date(distributor.created_at).toLocaleDateString('en-CA') %>"
              data-reasons='<%- JSON.stringify(distributor.final_reason_text || []) %>'
              data-dist-noc="<%= distributor.noc_certificate || '' %>" 
              data-resign-letter="<%= distributor.resignation_letter || '' %>"
              data-resign-noc="<%= distributor.noc_file_path || '' %>"
              data-total_complete_approval_level="<%= canShowRSEMAction.total_complete_approval_level %>"
            >
              Action
            </button>
            <% } %>
          </td>
          <td>
            <% 
            const canShowDTTeamAction = appActions && appActions.get_approvel_button && appActions.get_approvel_button.filter(btn => btn.role_name == 'DT Team');
            const total_levelDTTeam = canShowDTTeamAction && canShowDTTeamAction.length > 0 && canShowDTTeamAction[0];

            %>
            <% if (canShowDTTeamAction && canShowDTTeamAction.length > 0) { %>
            <button
              class="btn btn-outline-primary"
              onclick="openAssetTransferModal(this)" data-application-id="<%= distributor.applicationId %>"
              data-total_complete_approval_level="<%= total_levelDTTeam.total_complete_approval_level %>"
              data-is-replacement="<%= distributor.is_replacement %>"
            >
              Confirm Data Transfer
            </button>
            <% } %>
          </td>
          <td>
              <% 
              const snfActions = appActions && appActions.get_approvel_button 
                  ? appActions.get_approvel_button.filter(btn => btn.role_name == 'SNF') 
                  : [];

              const firstSNFAction = snfActions && snfActions[0];
              %>

              <% if (firstSNFAction && firstSNFAction.snf_flag == 0) { %>
                  <button class="btn btn-outline-primary" 
                      onclick="openClaimModal(this)" 
                      data-application-id="<%= distributor.applicationId %>"
                      data-total_complete_approval_level="<%= firstSNFAction.total_complete_approval_level %>">
                      Claim Clearance
                  </button>
              <% } %>

              <% if (firstSNFAction && firstSNFAction.snf_flag == 1) { %>
               <button class="btn btn-outline-primary" 
                  onclick="openFnfAcceptanceModal(this)" 
                  data-application-id="<%= distributor.applicationId %>"
                  data-total_complete_approval_level="<%= firstSNFAction.total_complete_approval_level %>"
                  data-fnf-pdf="<%= distributor.fnfpdf ? distributor.fnfpdf : '' %>">
                  F&F Acceptance
                </button>
              <% } %>


           
            <%
            const apTeamBtn = appActions && appActions.get_approvel_button
              ? appActions.get_approvel_button.find(btn => btn.role_name == 'AP TEAM')
              : null;

            const isApExpired =
              distributor.ap_action_status === 'PENDING' &&
              distributor.ap_deadline &&
              new Date(distributor.ap_deadline) < new Date();

            const isTermination = distributor.offboard_type === 'termination';
            %>

            <% if (role_name === 'SNF' && isTermination && isApExpired) { %>
            <button
              class="btn btn-danger"
              onclick="openSnfProcessPaymentModal(this)"
              data-application-id="<%= distributor.applicationId %>"
              data-total_complete_approval_level="<%= apTeamBtn ? apTeamBtn.total_complete_approval_level : distributor.total_complete_approval_level %>"
            >
              Process Payment (AP No Response - 15 Days)
            </button>
            <% } %>
          </td>
          <td>
            <% 
            const canShowTaxGSTAction = appActions && appActions.get_approvel_button && appActions.get_approvel_button.filter(btn => btn.role_name == 'TAX GST');
            const total_levelTaxGST = canShowTaxGSTAction && canShowTaxGSTAction.length > 0 && canShowTaxGSTAction[0];

            %>
            <% if (canShowTaxGSTAction && canShowTaxGSTAction.length > 0) { %>
            <button class="btn btn-outline-primary" onclick="openGSTModal(this)" 
             data-application-id="<%= distributor.applicationId %>"
             data-total_complete_approval_level="<%= total_levelTaxGST.total_complete_approval_level %>">
              Validate GST & Adjust Ledger
            </button>
            <% } %>

           
         <% if (role_name === 'TAX GST') { %>
            <% if (distributor.offboard_type === 'termination' && distributor.gst_reversal == 1) { %>
              
              <button 
                class="btn btn-outline-primary"
                onclick="openGSTReversalModal(this)"
                data-application-id="<%= distributor.applicationId %>"
                data-offboard-type="<%= distributor.offboard_type %>">
                GST Reversal Confirmation
              </button>

            <% } %>

          <% } %>
          </td>
          <td>
            <% 
            const o2cActions = appActions && appActions.get_approvel_button && appActions.get_approvel_button.filter(btn => btn.role_name == 'O2C');
            const firstO2CAction = o2cActions && o2cActions[0];
            const secondO2CAction = o2cActions && o2cActions[1];
            %>
            <% if (firstO2CAction && firstO2CAction.fnf_flag == 0) { %>
            <button class="btn btn-outline-primary" onclick="openFnfModal(this)" 
             data-application-id="<%= distributor.applicationId %>" 
             data-total_complete_approval_level="<%= firstO2CAction.total_complete_approval_level %>"
>
              F&F
            </button>
            <% } %>
            <% if (firstO2CAction && firstO2CAction && firstO2CAction.fnf_flag == 1) { %>
            <button
              class="btn btn-outline-primary"
              onclick="openZeroLedgerModal(this)"
              data-application-id="<%= distributor.applicationId %>"
              data-fnf_flag="<%= firstO2CAction.fnf_flag %>"
              data-total_complete_approval_level="<%= firstO2CAction.total_complete_approval_level %>"
            >
              Open Zero Ledger
            </button>
            <% } %>

        <% if (role_name === 'O2C') { %>
           <% if (distributor.offboard_type === 'termination' && distributor.gst_reversal == 1) { %>
            <button class="btn btn-outline-primary"
              onclick="openGSTReversalModal(this)"
              data-application-id="<%= distributor.applicationId %>"
              data-offboard-type="<%= distributor.offboard_type %>">
              GST Reversal Confirmation
            </button>
           <% } %>
        <% } %>
          </td>
          <td>
            <% 
            const canShowMDMAction = appActions && appActions.get_approvel_button && appActions.get_approvel_button.filter(btn => btn.role_name == 'MDM');
            const total_level = canShowMDMAction && canShowMDMAction.length > 0 && canShowMDMAction[0];
            %>
            <% if (canShowMDMAction && canShowMDMAction.length > 0) { %>
            <button
              class="btn btn-outline-primary"
              onclick="openBlockDbModal(this)" 
               data-application-id="<%= distributor.applicationId %>"
               data-total_complete_approval_level="<%= total_level ? total_level.total_complete_approval_level : '' %>"

            >
              Block DB Code
            </button>
            <% } %>
          </td>
        
          <td>
              <% 
                const canShowRSMAction = appActions && appActions.get_approvel_button 
                  ? appActions.get_approvel_button.filter(btn => btn.role_name == 'RSM')
                  : [];

                const total_levelRSM = canShowRSMAction && canShowRSMAction.length > 0 
                  ? canShowRSMAction[0] 
                  : null;
              %>

            <% if (canShowRSMAction && canShowRSMAction.length > 0) { %>

               <% if (
                  total_levelRSM && 
                  (
                    (distributor.offboard_type === 'resignation' && Number(total_levelRSM.sequence) === 2) ||
                    (distributor.offboard_type === 'termination' && Number(total_levelRSM.sequence) === 1)
                  )
                ) { %>
                
                <button 
                  class="btn btn-warning"
                  onclick="openInitialRSMModal(this)"
                  data-application-id="<%= distributor.applicationId %>"
                  data-name="<%= distributor.distributorName %>"
                  data-dbtype="<%= distributor.dbType || '--' %>"
                  data-dbcode="<%= distributor.distributor_code || '--' %>"
                  data-offboarddate="<%= new Date(distributor.created_at).toLocaleDateString('en-CA') %>"
                  data-reasons='<%- JSON.stringify(distributor.final_reason_text || []) %>'>
                  
                  Action
                </button>
                   
                <% } else if (distributor.rsm_action_btn == 1) { %>
                  <button 
                    id="openVerifyFNFBtn"
                    onclick="openVerifyFNFBtn(this)" 
                    data-application-id="<%= distributor.applicationId %>"
                    data-total_complete_approval_level="<%= total_levelRSM ? total_levelRSM.total_complete_approval_level : '' %>"
                    data-offboard-type="<%= distributor.offboard_type %>"
                    data-exit-interview-completed="<%= distributor.exit_interview_completed %>"
                    class="btn btn-primary">
                    Verify F&F Letter
                  </button>

                <% } %>

              <% } %>
            </td>
            <td>
              <% 
              const canShowNSMction = appActions && appActions.get_approvel_button && 
                appActions.get_approvel_button.filter(btn => btn.role_name == 'NSM');

              const total_levelNSM = canShowNSMction && canShowNSMction.length > 0 && canShowNSMction[0];
              %>

              <% if (
                canShowNSMction && 
                canShowNSMction.length > 0 && 
                distributor.applicationStatus !== 'Rejected' &&
                appActions && appActions.isNSMPending  
              ) { %>

                <button id="openVerifyFNFBtn"
                  onclick="openVerifyFNFBtn(this)" 
                  data-application-id="<%= distributor.applicationId %>"
                  data-total_complete_approval_level="<%= total_levelNSM.total_complete_approval_level %>"
                  data-signed-fnf-path="<%= distributor.signed_fnf_path || '' %>"
                  data-offboard-type="<%= distributor.offboard_type %>"
                  data-exit-interview-completed="<%= distributor.exit_interview_completed %>"
                  class="btn btn-primary">
                  
                  Verify F&F Letter
                </button>

              <% } %>
            </td>
          <td>
            <% 
            const canShowAPTeamAction = appActions && appActions.get_approvel_button && appActions.get_approvel_button.filter(btn => btn.role_name == 'AP TEAM');
            const total_levelAPTeam = canShowAPTeamAction && canShowAPTeamAction.length > 0 && canShowAPTeamAction[0];
            %>
            <% if (canShowAPTeamAction && canShowAPTeamAction.length > 0) { %>
            <button id="openPaymentModal"
             onclick="openVerifyFNFBtnLetter(this)"  class="btn btn-primary"
              data-application-id="<%= distributor.applicationId %>" 
               data-total_complete_approval_level="<%= total_levelAPTeam.total_complete_approval_level %>"
>
              Process Payment
            </button>
            <% } %>
          </td>
          <td class="text-center">
            <a
              href="/newoffboardApprover/newoffboardApproverview/<%= distributor.applicationId %>"
            >
              <i class="fa fa-clipboard text-primary"></i>
            </a>
          </td>
        </tr>

        <% }) %> <% } else { %>
        <tr>
          <td colspan="23" class="text-center">No distributors found.</td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

