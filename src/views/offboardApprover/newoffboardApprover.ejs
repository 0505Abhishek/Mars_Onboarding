<div id="gstReversalBackdrop" class="custom-modal-backdrop" style="display:none;"></div>

<div id="gstReversalModal" class="custom-modal modalwidth" style="display:none;">
  <div class="custom-modal-content">
    <span class="close-btn" onclick="closeGSTReversalModal()">✖</span>

    <h4 class="mb-3">GST Reversal Confirmation</h4>

