<script>
  let applicationidselect = null;

  const Toast = Swal.mixin({
    toast: true,
    position: "top-end",
    showConfirmButton: false,
    timer: 2500,
    timerProgressBar: true,
  });

  function openReplacementModal(appId = null) {
    applicationidselect = appId;

    document.getElementById("replacementBackdrop").classList.add("show");
    document.getElementById("replacementModal").classList.add("show");
  }
  function closeReplacementModal() {
    document.getElementById("replacementBackdrop").classList.remove("show");
    document.getElementById("replacementModal").classList.remove("show");

    document
      .querySelectorAll('input[name="isReplacement"]')
      .forEach((r) => (r.checked = false));

    document.getElementById("replacementFields").classList.add("hidden");

    dbName.value = "";
    dbCode.value = "";
  }

  const yes = document.getElementById("repYes");
  const no = document.getElementById("repNo");
  const fields = document.getElementById("replacementFields");

  yes.addEventListener("change", () => fields.classList.remove("hidden"));

  no.addEventListener("change", () => {
    fields.classList.add("hidden");
    dbName.value = "";
    dbCode.value = "";
  });

  async function submitReplacement() {
    if (!applicationidselect) {
      Toast.fire({ icon: "error", title: "Application ID missing!" });
      return;
    }

    const selected = document.querySelector(
      'input[name="isReplacement"]:checked'
    )?.value;

    if (!selected) {
      Toast.fire({ icon: "warning", title: "Please select Yes or No" });
      return;
    }

    const payload = {
    application_id: applicationidselect,
    is_replacement: selected === "yes" ? 1 : 2,
    submitted_at: new Date().toISOString(),
    };


    if (selected === "yes") {
      payload.replacement_db_name = dbName.value.trim();
      payload.replacement_db_code = dbCode.value.trim();

      if (!payload.replacement_db_name || !payload.replacement_db_code) {
        Toast.fire({
          icon: "warning",
          title: "Please enter DB Name & DB Code",
        });
        return;
      }
    }

    try {
      const res = await fetch("/newoffboardApprover/submitDbReplacement", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const data = await res.json();

      if (data.success) {
        Toast.fire({
          icon: "success",
          title: "Saved successfully",
        });

        setTimeout(() => {
          closeReplacementModal();
          location.reload();
        }, 900);
      } else {
        Toast.fire({
          icon: "error",
          title: data.message || "Something went wrong",
        });
      }
    } catch (err) {
      console.error(err);
      Toast.fire({
        icon: "error",
        title: "Request failed",
      });
    }
  }
</script>

