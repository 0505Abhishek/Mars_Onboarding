<script>
  function openAssetTransferModal(element) {
    selected = element.dataset.applicationId;
    total_complete_approval_level = element.dataset.total_complete_approval_level;

    const isReplacement = element.dataset.isReplacement;
    const replacementText = document.getElementById("replacementStatus");

    if (isReplacement == "1") {
    replacementText.innerText = "Yes";
    } else if (isReplacement == "2") {
    replacementText.innerText = "No";
    } else {
    replacementText.innerText = "-";
    }

    document.getElementById("assetTransferBackdrop").classList.add("show");
    document.getElementById("assetTransferModal").classList.add("show");
    
    const TranferassetYes = document.getElementById("isAssetTransferredYes");
    const TranferassetNo = document.getElementById("isAssetTransferredNo");
    const assetRemarksBox = document.getElementById("assetRemarksBox");
    
    TranferassetYes.removeEventListener("change", handleYesChange);
    TranferassetNo.removeEventListener("change", handleNoChange);
    
    TranferassetYes.addEventListener("change", handleYesChange);
    TranferassetNo.addEventListener("change", handleNoChange);
    
    function handleYesChange() {
      assetRemarksBox.style.display = "block";
    }
    
    function handleNoChange() {
      assetRemarksBox.style.display = "none";
    }
  }

  function closeAssetTransferModal() {
    document.getElementById("assetTransferBackdrop").classList.remove("show");
    document.getElementById("assetTransferModal").classList.remove("show");
  }

  document.getElementById("assetTransferSubmit").onclick = async () => {
  const submitButton = document.getElementById("assetTransferSubmit");
  submitButton.disabled = true;
  const originalText = submitButton.innerText;
  submitButton.innerText = "Submitting...";

  submitButton.disabled = true;
    const TranferassetYes = document.getElementById("isAssetTransferredYes");
    const TranferassetNo = document.getElementById("isAssetTransferredNo");
    const assetRemarksBox = document.getElementById("isAssetTransferredtext");
    
    if (!TranferassetYes.checked && !TranferassetNo.checked) {
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "error",
        title: "Please select asset transfer status",
        showConfirmButton: false,
        timer: 2000,
        timerProgressBar: true,
      });
    submitButton.disabled = false;
    submitButton.innerText = originalText;
    return;
    }

    
    try {
      const response = await fetch(
        "/newoffboardApprover/assettransfersubmit",
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
             application_id: selected,
            transfer_assets: TranferassetYes.checked ? "yes" : "no",
            assetRemarksBox:assetRemarksBox.value
          }),
        }
      );

      const result = await response.json();

      Swal.fire({
        toast: true,
        position: "top-end",
        icon: result.type === "success" ? "success" : "info",
        title: result.message,
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
      didClose: () => {
          if (result.type === "success") {
            closeModal("optionModal");
            location.reload();
          } else {
            submitButton.disabled = false;
            submitButton.innerText = originalText;
          }
        },
      });
    } catch (err) {
      console.error("Error initiating resignation:", err);
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "error",
        title: "Failed to send email. Please try again.",
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
      });
      submitButton.disabled = false;
      submitButton.innerText = originalText;
    }
  };

</script>

<script>
let selected = null;
let total_complete_approval_level = null;

function openVerifyFNFBtn(element) {
  selected = element.dataset.applicationId;
  total_complete_approval_level = element.dataset.total_complete_approval_level;

  const offboardType = element.dataset.offboardType;
  const exitCompleted = element.dataset.exitInterviewCompleted;
  const signedFnfPath = element.dataset.signedFnfPath;

  const modal = document.getElementById("verifyFNFModal");

  modal.dataset.offboardType = offboardType;
  modal.dataset.exitCompleted = exitCompleted;

  document.getElementById("verifyFNFBackdrop").classList.add("show");
  modal.classList.add("show");

  const fnfDownloadLink = document.getElementById("fnfLetterDownload");

  if (signedFnfPath) {
    fnfDownloadLink.href = signedFnfPath;
    fnfDownloadLink.setAttribute("download", "F&F_Letter.pdf");
  } else {
    fnfDownloadLink.href = "#";
    fnfDownloadLink.removeAttribute("download");
  }
}


const interviewYes = document.getElementById("interviewYes");
const interviewNo = document.getElementById("interviewNo");
const exitInterviewQuestions = document.getElementById("exitInterviewQuestions");

interviewYes.addEventListener("change", () => {
  exitInterviewQuestions.style.display = "block";
});

interviewNo.addEventListener("change", () => {
  exitInterviewQuestions.style.display = "none";
});

document.querySelectorAll(".fnfApprove").forEach(element => {
  element.onclick = async () => {

    const isApprove = element.id === "fnfApproveBtn" ? "Approve" : "Reject";
    const fnfRemarks = document.getElementById("fnfRemarks");

    document.getElementById("fnfApproveBtn").disabled = true;
    document.getElementById("fnfRejectBtn").disabled = true;

    const originalValue = element.value;
    element.value = "Processing...";

    const modal = document.getElementById("verifyFNFModal");
    const offboardType = modal.dataset.offboardType;
    const exitCompleted = modal.dataset.exitCompleted;

    let exitInterviewRemarks = null;
    let interviewValue = null;

    if (
      offboardType &&
      offboardType.toLowerCase() === "resignation" &&
      exitCompleted == "0"
    ) {

      interviewValue =
        document.querySelector(
          'input[name="interviewConducted"]:checked'
        )?.value || null;

      if (!interviewValue) {
        Swal.fire({
          icon: "error",
          title: "Please select Interview Conducted Yes/No"
        });
        enableButtons();
        return;
      }

      if (interviewValue === "no") {
        Swal.fire({
          icon: "error",
          title: "Exit Interview is mandatory for resignation."
        });
        enableButtons();
        return;
      }

      const exitInterviewAnswers = Array.from(
        document.querySelectorAll("#exitInterviewQuestions textarea")
      ).map(t => t.value.trim());

      const anyEmpty = exitInterviewAnswers.some(ans => ans === "");

      if (anyEmpty) {
        Swal.fire({
          icon: "error",
          title: "Please answer all exit interview questions"
        });
        enableButtons();
        return;
      }

      exitInterviewRemarks = JSON.stringify(exitInterviewAnswers);
    }

    if (isApprove === "Reject" && !fnfRemarks.value.trim()) {
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "error",
        title: "Please enter remarks for rejection",
        showConfirmButton: false,
        timer: 2000
      });
      enableButtons();
      return;
    }

    try {
      const response = await fetch("/newoffboardApprover/fnfApproveBtn", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          application_id: selected,
          fnfApproveBtn: isApprove,
          fnfRemarks: fnfRemarks.value || "",
          total_complete_approval_level: total_complete_approval_level,
          exitInterviewRemarks: exitInterviewRemarks,
          interviewConducted: interviewValue
        })
      });

      const result = await response.json();

      Swal.fire({
        toast: true,
        position: "top-end",
        icon: result.type === "success" ? "success" : "info",
        title: result.message,
        showConfirmButton: false,
        timer: 3000,
        didClose: () => {
          if (result.type === "success") {
            location.reload();
          } else {
            enableButtons();
          }
        }
      });

    } catch (err) {
      console.error("Error approving F&F:", err);
      Swal.fire({
        icon: "error",
        title: "Failed to approve F&F. Please try again."
      });
      enableButtons();
    }

    function enableButtons() {
      document.getElementById("fnfApproveBtn").disabled = false;
      document.getElementById("fnfRejectBtn").disabled = false;
      document.getElementById("fnfApproveBtn").value = "Approve";
      document.getElementById("fnfRejectBtn").value = "Reject";
    }

  };
});
document.getElementById("verifyFNFClose").onclick = function () {
  document.getElementById("verifyFNFBackdrop").classList.remove("show");
  document.getElementById("verifyFNFModal").classList.remove("show");
};
</script>


<script>
  function openClaimModal(element) {
     selected = element.dataset.applicationId;
     total_complete_approval_level = element.dataset.total_complete_approval_level;
    console.log("selectedApplicationId:", selected);
    document.getElementById("claimModalBackdrop").classList.add("show");
