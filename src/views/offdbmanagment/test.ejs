<%- include("../shared/super_header.ejs") %>
    <div class="main-panel distributors-details">
        <div class="content-wrapper">
            <div class="row">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card p-3 table-responsive">
                        <div class="d-flex justify-content-between my-4">
                            <div class="business-hading d-flex justify-content-between">
                                <h4>DB Managment</h4>

                            </div>
                        </div>
                        <div class="card-body">
                          <form action="/db_managment/offboardingApproverupdate" method="post">
    <input type="hidden" name="application_id" value="<%= getdbdataById?.id %>" />

    <!-- DB Details (same rakhe hain) -->
    <div class="form-group">
        <label for="dbId">DB Id</label>
        <input type="text" class="form-control" id="dbId" name="dbId" value="<%= getdbdataById?.mars_code %>" readonly>
    </div>
    <div class="form-group">
        <label for="firmName">DB Name</label>
        <input type="text" class="form-control" id="firmName" name="firmName" value="<%= getdbdataById?.firmName %>" readonly>
    </div>
    <div class="form-group">
        <label for="email">DB Email</label>
        <input type="email" class="form-control" id="email" name="email" value="<%= getdbdataById?.email %>" readonly>
    </div>

    <!-- Territory (same rakha hai – BRD mein zarurat nahi lekin aapne bola mat hatao) -->
    <div class="form-group">
        <label for="territory">DB Territory</label>
        <div class="position-relative">
            <select class="form-control" id="territory" name="territory" required>
                <option value="">Select Territory</option>
                <% if (territory && territory.length > 0) { %>
                    <% territory.forEach(function(item) { %>
                        <option value="<%= item.id %>"
                            <%= item.id == getdbdataById?.territory_id ? 'selected' : '' %>>
                            <%= item.territory_name %>
                        </option>
                    <% }); %>
                <% } %>
            </select>
            <div id="searchDropdown" style="display: none; position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #ced4da; border-radius: 4px; z-index: 1000; max-height: 300px; overflow-y: auto;">
                <input type="text" class="form-control" id="territorySearch" placeholder="Search territory..." style="position: sticky; top: 0;">
                <div id="territoryOptions" style="padding: 8px;"></div>
            </div>
        </div>
    </div>

    <!-- Offboarding ke sahi roles (BRD ke hisaab se) -->
    <% 
        // BRD ke hisaab se offboarding approval flow (ASM ko initiate ke baad approval chain mein nahi rakha)
        let offboardRoleOrder = ['RSEM', 'SFM', 'OTC', 'Tax Team', 'RSM/SD', 'Accounts Payable', 'MDM', 'DT Team']; 
        if (getdbdataByIdApproval && getdbdataByIdApproval.length > 0) {
            getdbdataByIdApproval.sort((a, b) => {
                const indexA = offboardRoleOrder.indexOf(a.role_name);
                const indexB = offboardRoleOrder.indexOf(b.role_name);
                return indexA - indexB;
            });
        }
    %>

    <% if (getdbdataByIdApproval && getdbdataByIdApproval.length > 0) { %>
        <% getdbdataByIdApproval.forEach(function(item, idx) { %>
            <div class="form-group">
                <label for="approver_<%= idx %>">
                    <%= item.role_name %>
                </label>
                <!-- Hidden fields same rakhe hain (offboardingApproverupdate mein role_id use hota hai) -->
                <input type="hidden" name="role_id[<%= idx %>]" value="<%= item.approver_role_id %>" />
                <select class="form-control" id="approver_<%= idx %>" name="approver_id[<%= idx %>]" required>
                    <option value="">Select User</option>
                    <% if (getuserdata && getuserdata.length > 0) { %>
                        <% getuserdata.forEach(function(user) { %>
                            <% if (user.role_id == item.approver_role_id) { %>
                                <option value="<%= user.id %>"
                                    <%= user.id == item.approver_id ? 'selected' : '' %>
                                    data-parent-id="<%= user.parent_id %>">
                                    (<%= user.employee_name %>), CB<%= user.id %>
                                </option>
                            <% } %>
                        <% }); %>
                    <% } %>
                </select>
            </div>
        <% }); %>
    <% } %>

    <!-- Submit button – offboarding mein hamesha dikhega (condition hata di) -->
    <button type="submit" class="btn btn-primary">Update Approvers</button>
</form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let territorySelect, searchDropdown, territorySearch, territoryOptions;

        function showSearch(e) {
            if (e) e.preventDefault();
            searchDropdown.style.display = 'block';
            territorySearch.focus();

            // Populate options
            const options = Array.from(territorySelect.options);
            territoryOptions.innerHTML = '';
            options.forEach(option => {
                if (option.value === '') return;
                const div = document.createElement('div');
                div.className = 'p-2 hover-bg-light cursor-pointer';
                div.textContent = option.text;
                div.onclick = function () {
                    territorySelect.value = option.value;
                    updateApproversByTerritory(territorySelect.value);
                    searchDropdown.style.display = 'none';
                };
                territoryOptions.appendChild(div);
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            territorySelect = document.getElementById('territory');
            searchDropdown = document.getElementById('searchDropdown');
            territorySearch = document.getElementById('territorySearch');
            territoryOptions = document.getElementById('territoryOptions');

            // Add click event listener to select
            territorySelect.addEventListener('click', showSearch);

            // Close dropdown when clicking outside
            document.addEventListener('click', function (e) {
                if (!searchDropdown.contains(e.target) && e.target !== territorySelect) {
                    searchDropdown.style.display = 'none';
                }
            });

            territorySearch.addEventListener('input', function () {
                const searchText = this.value.toLowerCase();
                const optionDivs = territoryOptions.getElementsByTagName('div');

                for (let div of optionDivs) {
                    const text = div.textContent.toLowerCase();

                    div.style.display = text.includes(searchText) ? '' : 'none';
                }
            });

            // Prevent select from opening native dropdown
            territorySelect.addEventListener('mousedown', function (e) {

                e.preventDefault();
            });
        });

     function updateApproversByTerritory(territoryId) {
    fetch('/db_managment/get-approvers-by-territory/' + territoryId)
        .then(response => response.json())
        .then(data => {
            if (data.approvers) {
                // Yeh pura block hata do – kyuki roleOrder server-side hai
                // Ab sirf dropdown populate karo without sorting here
                <% if (getdbdataByIdApproval && getdbdataByIdApproval.length > 0) { %>
                    <% getdbdataByIdApproval.forEach(function (item, idx) { %>
                        var approverSelect = document.getElementById('approver_<%= idx %>');
                        if (approverSelect) {
                            approverSelect.innerHTML = '<option value="">Select User</option>';
                            const roleUsers = data.approvers.filter(user => user.role_id == <%= item.approver_role_id %>);
                            roleUsers.forEach(user => {
                                var opt = document.createElement('option');
                                opt.value = user.id;
                                opt.textContent = ' (' + user.employee_name + '), CB' + user.id;
                                opt.setAttribute('data-parent-id', user.parent_id);
                                approverSelect.appendChild(opt);
                            });
                        }
                    <% }); %>
                <% } %>
            }
        })
        .catch(error => console.error('Error:', error));
}




        // function updateNextDropdown(currentIdx, parentId) {
        //     var nextIdx = currentIdx + 1;
        //     var nextSelect = document.getElementById('approver_' + nextIdx);

        //     if (!nextSelect) return;

        //     fetch('/db_managment/by-parent/' + parentId)
        //         .then(response => response.json())
        //         .then(data => {
        //             nextSelect.innerHTML = '<option value="">Select User</option>';
        //             if (data.users && data.users.length > 0) {
        //                 data.users.forEach(function(user) {
        //                     var opt = document.createElement('option');
        //                     opt.value = user.id;
        //                     opt.textContent = user.name + ' (' + user.employee_name + '), CB0000' + user.id + ', role ' + user.role;
        //                     opt.setAttribute('data-parent-id', user.parent_id);
        //                     nextSelect.appendChild(opt);
        //                 });
        //             }
        //         });
        // }

        document.addEventListener('DOMContentLoaded', function () {
            // Add territory change event listener
            const territorySelect = document.getElementById('territory');
            if (territorySelect) {
                territorySelect.addEventListener('change', function () {
                    const selectedTerritoryId = this.value;
                    if (selectedTerritoryId) {
                        updateApproversByTerritory(selectedTerritoryId);
                    }
                });
            }

            // Add approver change event listeners
            <% if (getdbdataByIdApproval && getdbdataByIdApproval.length > 0) { %>
                <% getdbdataByIdApproval.forEach(function (item, idx) { %>
                    var select = document.getElementById('approver_<%= idx %>');
                if (select) {
                    select.addEventListener('change', function () {
                        var selectedOption = this.options[this.selectedIndex];
                        var parentId = selectedOption.getAttribute('data-parent-id');
                        //updateNextDropdown(<%= idx %>, parentId);
                    });
                }
                <% }); %>
            <% } %>
        });
    </script>

    <style>
        .hover-bg-light:hover {
            background-color: #f8f9fa;
        }

        .cursor-pointer {
            cursor: pointer;
        }
    </style>
    <%- include("../shared/super_footer.ejs") %>