<%- include("../shared/super_header.ejs") %>
    <div class="main-panel distributors-details">
        <div class="content-wrapper">
            <div class="row">
                <div class="m-3 mt-0">
                    <a href="/region" class="btn btn-primary"><i class="fa fa-arrow-left"></i> Back</a>
                </div>
                <div class="col-12 grid-margin stretch-card">
                    <div class="card p-3 table-responsive">
                        <div class="d-flex justify-content-between ">
                            <div class="business-hading d-flex justify-content-between">
                                <h4>Region Add</h4>
                            </div>
                        </div>
                        <div class="card-body">
                            <form action="/region/addregion" method="POST">
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label for="edit-region-name" class="form-label">Region Name</label>
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="mdi mdi-map-marker"></i>
                                            </span>
                                            <input type="text" class="form-control" id="edit-region-name" name="region_name" placeholder="Enter Region Name" required="">
                                        </div>
                                    </div>
                                    
                                </div>
                                <button type="submit" class="btn btn-primary">Save</button>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
<%- include("../shared/super_footer.ejs") %>