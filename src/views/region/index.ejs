<%- include("../shared/super_header.ejs") %>
<style>
  .custom-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #e9ecef;
    padding-bottom: 15px;
  }

  .custom-modal-title {
    margin: 0;
    font-size: 1.25rem;
  }

  .custom-modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6c757d;
  }

  .custom-modal-body {
    padding: 20px 0;
  }

  .custom-modal-footer {
    display: flex;
    justify-content: flex-end;
    border-top: 1px solid #e9ecef;
    padding-top: 15px;
  }

  .custom-modal-footer button {
    margin-left: 10px;
  }
</style>
<div class="main-panel distributors-details">
  <div class="content-wrapper">
    <div class="row">
      <div class="col-12 grid-margin stretch-card">
        <div class="card p-3 table-responsive">
          <div class="d-flex justify-content-between my-4">
            <div class="business-hading d-flex justify-content-between">
              <h4>Region Management</h4>
            </div>
            <div>
              <div>
                <a href="/region/add" class="text-white">
                  <button class="btn btn-primary btn-sm mr-2">
                    Add New Region
                  </button>
                </a>
                <a href="/territory" class="text-white">
                  <button class="btn btn-primary btn-sm mr-2">
                    Territory Management
                  </button>
                </a>
                <a href="/so" class="text-white">
                  <button class="btn btn-primary btn-sm mr-2">
                    So Territory
                  </button>
                </a>
              </div>
              <div class="mt-2">
                <a href="/tab/1" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    ASM
                  </button>
                </a>
                <a href="/tab/2" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    RSEM
                  </button>
                </a>
                <a href="/tab/3" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    MIS
                  </button>
                </a>
                <a href="/tab/4" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    RSM
                  </button>
                </a>
                <a href="/tab/11" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    Supply
                  </button>
                </a>
                <a href="/tab/5" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    CE
                  </button>
                </a>
                <a href="/tab/6" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    O2C
                  </button>
                </a>

                <a href="/tab/7" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    SNF
                  </button>
                </a>
                <a href="/tab/8" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    MDM
                  </button>
                </a>
                <a href="/tab/9" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    DT Team
                  </button>
                </a>
                <a href="/tab/14" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    NSM
                  </button>
                </a>

                <a href="/tab/12" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    TAX GST
                  </button>
                </a>
                <a href="/tab/15" class="text-white">
                  <button class="btn btn-primary float-right btn-sm mr-2">
                    ACCOUNTS PAYABLE
                  </button>
                </a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table
                id="regionTable"
                class="display table table-bordered table-hover"
                style="width: 100%"
              >
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Region Name</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% regions.forEach(function(region) { %>
                  <tr>
                    <td><%= region.id %></td>
                    <td><%= region.region_name %></td>
                    <td>
                      <button
                        class="btn btn-sm btn-warning edit-region"
                        data-id="<%= region.id %>"
                        data-name="<%= region.region_name %>"
                        onclick="openEditRegionModal(this)"
                      >
                        Edit
                      </button>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom Edit Region Modal -->
  <div id="customEditRegionModal" class="custom-modal">
    <div class="custom-modal-content" style="max-width: 500px">
      <div class="custom-modal-header">
        <h5 class="custom-modal-title">Edit Region</h5>
        <button class="custom-modal-close" onclick="closeEditRegionModal()">
          &times;
        </button>
      </div>
      <form id="editRegionForm" action="/region/edit" method="POST">
        <div class="custom-modal-body">
          <input type="hidden" id="edit-region-id" name="id" />
          <div class="form-group mb-3">
            <label for="edit-region-name" class="form-label">Region Name</label>
            <div class="input-group">
              <span class="input-group-text">
                <i class="mdi mdi-map-marker"></i>
              </span>
              <input
                type="text"
                class="form-control"
                id="edit-region-name"
                name="region_name"
                placeholder="Enter Region Name"
                required
              />
            </div>
            <small class="text-muted"
              >Enter the updated name for the region</small
            >
          </div>
        </div>
        <div class="custom-modal-footer">
          <button
            type="button"
            class="btn btn-secondary"
            onclick="closeEditRegionModal()"
          >
            Cancel
          </button>
          <button type="submit" class="btn btn-primary">
            <i class="mdi mdi-content-save"></i> Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../shared/super_footer.ejs') %>

<script>
  $(document).ready(function () {
    // DataTable initialization
    $("#regionTable").DataTable({
      responsive: true,
      pageLength: 10,
      lengthMenu: [
        [10, 25, 50, -1],
        [10, 25, 50, "All"],
      ],
      language: {
        search: "_INPUT_",
        searchPlaceholder: "Search regions...",
      },
      columnDefs: [
        {
          targets: 2,
          orderable: false,
        },
      ],
    });
  });

  function openEditRegionModal(button) {
    const id = button.getAttribute("data-id");
    const name = button.getAttribute("data-name");

    document.getElementById("edit-region-id").value = id;
    document.getElementById("edit-region-name").value = name;

    document.getElementById("customEditRegionModal").style.display = "block";
  }

  function closeEditRegionModal() {
    document.getElementById("customEditRegionModal").style.display = "none";
  }

  // Close modal if clicked outside
  window.onclick = function (event) {
    const modal = document.getElementById("customEditRegionModal");
    if (event.target == modal) {
      modal.style.display = "none";
    }
  };
</script>
