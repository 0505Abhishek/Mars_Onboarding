<%- include("../shared/super_header.ejs") %>
    <div class="main-panel distributors-details">
        <div class="content-wrapper">
            <div class="row">
                <div class="col-12 grid-margin stretch-card">
                    <div class="card p-3 table-responsive">
                        <div class="d-flex justify-content-between my-4">
                            <div class="business-hading d-flex justify-content-between">
                                <h4>DB REPORT</h4>
                            </div>
                        </div>
                        <div class="card-body">
                            <table id="userTable" class="display table invite table-bordered mt-3 table-hover responsive nowrap" style="width: 100%">
                                <thead>
                                    <tr>
                                        <th>ASM Name</th>
                                        <th>Territory Name</th>
                                        <th>Distributor Code</th>
                                        <th>Distributor Name</th>
                                        <th>PAN Number</th>
                                        <th>GST Number</th>
                                        <th>Address1</th>
                                        <th>City</th>
                                        <th>State</th>
                                        <th>Pincode</th>
                                        <th>Email Id</th>
                                        <th>Contact Number</th>
                                        <th>Distributor CreatedOn</th>
                                        <th>Distributor Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if(getdbdata.length > 0) { %>
                                        <% getdbdata.forEach(function(item) { %>
                                            <tr>
                                                <td><%= item.employee_name || 'N/A' %></td> 
                                                <td><%= item?.territory_name %></td>
                                                <td><%= item.cdCode || 'N/A' %></td> 
                                                <td><%= item.distributorName || 'N/A' %></td>
                                                <td><%= item.pan_number || 'N/A' %></td>
                                                <td><%= item.gst_number || 'N/A' %></td>
                                                <td><%= item.address1 || 'N/A' %></td>
                                                <td><%= item.city || 'N/A' %></td>
                                                <td><%= item.state || 'N/A' %></td>
                                                <td><%= item.pin_code || 'N/A' %></td>
                                                <td><%= item.email || 'N/A' %></td>
                                                <td><%= item.contactNumber || 'N/A' %></td>
                                                <td><%= new Date(item.create_date).toLocaleDateString('en-CA') %></td>
                                               <td><span style="background:#28a745; color:white; padding:4px 10px; border-radius:6px; font-size:13px;">Onboarded</span></td>
                                            </tr>
                                        <% }); %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="custom-modal-backdrop" id="modalBackdrop"></div>

    <div class="custom-modal" id="customModal">
        <div class="modal-header">
            <h5>Import File</h5>
            <button class="btn-close" id="closeModalBtn"></button>
        </div>
        <div class="modal-body">
            <div>
                <a id="downloadCsv" class="btn mb-3">Download
                    Template<span class="p-1 ms-2 rounded-circle border border-primary"><i
                            class="mdi mdi-format-vertical-align-bottom"></i></span></a>

            </div>
            <div class="text-center mb-4">
                <i class="mdi mdi-file-upload-outline fs-1 text-primary"></i>
                <h6 class="mt-3">Upload CSV File</h6>
                <p class="text-muted">Please upload a CSV file with user data</p>
            </div>

            <form action="/db_managment/upload" method="POST" enctype="multipart/form-data" class="text-center">
                <div class="file-upload mb-4">
                    <label class="btn btn-outline-primary btn-sm w-100">
                        <i class="mdi mdi-file-upload"></i> Choose File
                        <input type="file" class="d-none" name="file" id="fileInput" accept=".csv" required
                            onchange="document.getElementById('fileName').textContent = this.files[0].name">
                    </label>
                    <small class="text-muted d-block mt-2">Only .csv files are allowed</small>
                    <p class="text-muted mt-2" id="fileName">No file chosen</p>
                </div>
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="mdi mdi-upload"></i> Upload
                </button>
            </form>
        </div>
    </div>
    <div class="custom-modal" id="customModalDocument">
        <div class="modal-header">
            <h5>Upload Document</h5>
            <button class="btn-close" id="closeModalBtnDocument"></button>
        </div>
        <div class="modal-body">
            <div class="text-center mb-4">
                <i class="mdi mdi-file-upload-outline fs-1 text-primary"></i>
                <h6 class="mt-3">Upload Document</h6>
                <p class="text-muted">Please upload a Document</p>
            </div>

            <form action="/db_managment/upload_document" method="POST" enctype="multipart/form-data"
                class="text-center">
                <div class="file-upload mb-4">
                    <label class="btn btn-outline-primary btn-sm w-100">
                        <i class="mdi mdi-file-upload"></i> Choose File
                        <input type="file" class="d-none" name="file" id="fileInputDocument" multiple accept=".pdf"
                            required
                            onchange="document.getElementById('fileNameDocument').textContent = this.files[0].name">
                    </label>
                    <small class="text-muted d-block mt-2">Only .pdf files are allowed</small>
                    <!-- <p class="text-muted mt-2" id="fileNameDocument">No file chosen</p> -->
                </div>
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="mdi mdi-upload"></i> Upload
                </button>
            </form>
        </div>
    </div>

    <div class="custom-modal" id="customModalUpdateTerritory">
        <div class="modal-header">
            <h5>Update DB Territory</h5>
            <button class="btn-close" id="closeModalBtnUpdateTerritory"></button>
        </div>
        <div class="modal-body">
            <div>
                <a id="downloadCsvUpdateTerritory" class="btn mb-3">Download
                    Template<span class="p-1 ms-2 rounded-circle border border-primary"><i
                            class="mdi mdi-format-vertical-align-bottom"></i></span></a>

            </div>
            <div class="text-center mb-4">
                <i class="mdi mdi-file-upload-outline fs-1 text-primary"></i>
                <h6 class="mt-3">Update DB Territory</h6>
                <p class="text-muted">Please update DB Territory</p>
            </div>

            <form action="/db_managment/update_territory" method="POST" enctype="multipart/form-data"
                class="text-center">
                <div class="file-upload mb-4">

                    <label class="btn btn-outline-primary btn-sm w-100">
                        <i class="mdi mdi-file-upload"></i> Choose File
                        <input type="file" class="d-none" name="file" id="fileInputUpdateTerritory" multiple
                            accept=".csv" required
                            onchange="document.getElementById('fileNameUpdateTerritory').textContent = this.files[0].name">
                    </label>
                    <small class="text-muted d-block mt-2">Only .csv files are allowed</small>
                    <!-- <p class="text-muted mt-2" id="fileNameUpdateTerritory">No file chosen</p> -->
                </div>
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="mdi mdi-upload"></i> Upload
                </button>
            </form>
        </div>
    </div>
    <script>
        const openBtn = document.getElementById('openModalBtn');
        const closeBtn = document.getElementById('closeModalBtn');
        const modal = document.getElementById('customModal');
        const backdrop = document.getElementById('modalBackdrop');

        openBtn.addEventListener('click', () => {
            modal.classList.add('show');
            backdrop.classList.add('show');
        });

        closeBtn.addEventListener('click', () => {
            modal.classList.remove('show');
            backdrop.classList.remove('show');
        });
        backdrop.addEventListener('click', () => {
            modal.classList.remove('show');
            backdrop.classList.remove('show');
        });
    </script>


    <script>

        document.getElementById('downloadCsv').addEventListener('click', function () {
            const headers = [
                "ASM User Id",
                "Territory Name",
                "Distributor Code",
                "DistributorName",
                "PAN Number",
                "GST Number",
                "Address1",
                "City",
                "State",
                "Pincode",
                "Email Id",
                "Contact Number",
                "Contact Person",
                "Distributor Status",
                "Distributor CreatedOn",
                "Distributor DeactivatedOn",
                "PDF Document"
            ];

            let csvContent = "data:text/csv;charset=utf-8," + headers.join(',') + '\n';

            // Create a CSV string
            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);

            link.setAttribute("download", "DB_Management_upload_" + new Date().toISOString() + ".csv");
            document.body.appendChild(link); // Required for Firefox

            link.click();
        });
    </script>

    <script>
        const openBtnDocument = document.getElementById('openModalBtnDocument');
        const closeBtnDocument = document.getElementById('closeModalBtnDocument');
        const modalDocument = document.getElementById('customModalDocument');
        const backdropDocument = document.getElementById('modalBackdrop');

        openBtnDocument.addEventListener('click', () => {
            modalDocument.classList.add('show');
            backdropDocument.classList.add('show');
        });

        closeBtnDocument.addEventListener('click', () => {
            modalDocument.classList.remove('show');
            backdropDocument.classList.remove('show');
        });
        backdropDocument.addEventListener('click', () => {
            modalDocument.classList.remove('show');
            backdrop.classList.remove('show');
        });
    </script>

    <script>
        const openBtnUpdateTerritory = document.getElementById('openModalBtnUpdateTerritory');
        const closeBtnUpdateTerritory = document.getElementById('closeModalBtnUpdateTerritory');
        const modalUpdateTerritory = document.getElementById('customModalUpdateTerritory');
        const backdropUpdateTerritory = document.getElementById('modalBackdropUpdateTerritory');

        openBtnUpdateTerritory.addEventListener('click', () => {
            modalUpdateTerritory.classList.add('show');
            backdropUpdateTerritory.classList.add('show');
        });

        closeBtnUpdateTerritory.addEventListener('click', () => {
            modalUpdateTerritory.classList.remove('show');
            backdropUpdateTerritory.classList.remove('show');
        });
        backdropUpdateTerritory.addEventListener('click', () => {
            modalUpdateTerritory.classList.remove('show');
            backdropUpdateTerritory.classList.remove('show');
        });
    </script>


    <script>

        document.getElementById('downloadCsvUpdateTerritory').addEventListener('click', function () {
            const headers = [
                "Territory Name",
                "Distributor ID",
            ];

            let csvContent = "data:text/csv;charset=utf-8," + headers.join(',') + '\n';

            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);

            link.setAttribute("download", "DB_Territory_upload_" + new Date().toISOString() + ".csv");
            document.body.appendChild(link); 

            link.click();
        });
    </script>
    <%- include("../shared/super_footer.ejs") %>

        <script type="text/javascript" src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
        <script type="text/javascript"
            src="https://cdn.datatables.net/buttons/2.3.6/js/dataTables.buttons.min.js"></script>
        <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.6/js/buttons.html5.min.js"></script>
        <link rel="stylesheet" type="text/css"
            href="https://cdn.datatables.net/buttons/2.3.6/css/buttons.dataTables.min.css">

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            $(document).ready(function () {
                $('#userTable').DataTable({
                    dom: 'Bfrtip',
                    buttons: [
                        'copy', 'csv', 'excel', 'pdf', 'print'
                    ],
                    order: [[5, 'desc']], 
                });
            });
        </script>