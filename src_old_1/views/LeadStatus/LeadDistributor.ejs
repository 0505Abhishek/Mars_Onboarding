</style>


<style>
    .file-upload {
      display: inline-block;
      background: #007bff; /* blue */
      color: white;
      padding: 6px 12px;
      border-radius: 5px;
      cursor: pointer;
      font-size: 14px;
    }

    .file-upload:hover {
      background: #0056b3;
    }

    .file-upload i {
      margin-right: 5px;
    }

    /* Green style after file is uploaded */
    .file-upload.uploaded {
      background: #28a745 !important; /* Bootstrap green */
    }

    input[type="file"] {
      display: none;
    }
  </style>

