                                    <label for="marsIntegrationNo">No</label>
                                </div>
                            </div>
                        
                                              
                
                            <h4>Logistics</h4>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the distributor have controlled temperature storage and transportation?</label>
                                <div>
                                    <input type="radio" id="temp_storage_yes" name="temp_storage" value="Yes" required>
                                    <label for="temp_storage_yes">Yes</label>
                                    <input type="radio" id="temp_storage_no" name="temp_storage" value="No" required>
