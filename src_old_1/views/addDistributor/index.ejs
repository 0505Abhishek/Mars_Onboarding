                            </div>
                        
                            <!-- Confectionery Sales Share Percentage -->
                            <div class="mb-3">
                                <label class="form-label" for="confectionery_sales_share">What is the share of confectionery on total distributors' sales?</label>
                                <input type="number" id="confectionery_sales_share" name="confectionery_sales_share" class="form-control" placeholder="Enter percentage">
                            </div>
                        
                            <!-- FTEs Dedicated to MW Dropdown -->
                            <div class="mb-3">
                                <label class="form-label" for="fte_dedicated">How many of distributors' FTEs are dedicated to MW?</label>
                                <select id="fte_dedicated" name="fte_dedicated" class="form-control">
                                    <option value="" disabled selected>Select an option</option>
                                    <option value="1-10">1-10</option>
                                    <option value="Above 10">Above 10</option>
                                </select>
                            </div>
                        
                            <!-- MW Influence Level Dropdown -->
                            <div class="mb-3">
                                <label class="form-label" for="mw_influence">What is the level of MW influence / sharing in the distributor's business planning process?</label>
                                <select id="mw_influence" name="mw_influence" class="form-control">
                                    <option value="" disabled selected>Select an option</option>
                                    <option value="High">High</option>
                                    <option value="Average">Average</option>
                                    <option value="Low">Low</option>
                                </select>
                            </div>
                
                            <h4>Digital Readiness</h4>
                        
                            <div class="mb-3">
                                <label class="form-label" for="capital_infrastructure">
                                    Does the distributor have sufficient capital and/or infrastructure to increase coverage?
                                </label>
                                <select id="capital_infrastructure" name="capital_infrastructure" class="form-control">
                                    <option value="">Select an option</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="dtr_nps_score">
                                    What is the DTR NPS score from their customers (stores)?
                                </label>
                                <input type="number" id="dtr_nps_score" name="dtr_nps_score" class="form-control" placeholder="Enter numeric score">
                            </div>
                        </div>
                        
                    </div> 

                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex gap-2"> 
                            <button style="width: 160px;" type="button" class="btn btn-primary prev">Back</button> 
                            <button style="width: 160px;" type="button" class="btn btn-primary" id="saveDraft">Save Draft</button> 
                        </div>
                        <button style="width: 160px;" type="submit" class="btn btn-primary">Send to RSEM</button>
                    </div>
                    
                </div>
                
            </form>
        </div>
    </div>
</div>
  

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {

    function showToast(message) {
        Swal.fire({
            toast: true,
            position: "top-end", 
            icon: "warning",
            title: message,
            showConfirmButton: false,
            timer: 2000 
        });
    }

    document.querySelectorAll("#monthlyTurnover").forEach(input => {
    input.addEventListener("input", function () {
        this.value = this.value.replace(/[^0-9.]/g, "");

        let parts = this.value.split(".");

        if (parts.length > 2) {
            showToast("Only one decimal point is allowed!");
            this.value = parts[0] + "." + parts[1];
        }

        this.value = this.value.replace(/^0+(?!\.)/, "");

        if (this.value.startsWith(".")) {
            showToast("Number cannot start with a dot!");
            this.value = "";
        }

        let totalLength = this.value.replace(".", "").length;
        if (totalLength > 20) {
            showToast("Maximum 20 digits allowed!");
            this.value = this.value.slice(0, 21);
        }
    });
});
           
        

    document.getElementById("contactNumber").addEventListener("input", function () {
        this.value = this.value.replace(/\D/g, "");
        if (this.value.startsWith("0")) {
            showToast("Mobile number cannot start with 0!");
            this.value = "";
            return;
        }

        if (this.value.length > 10) {
            showToast("Contact Number cannot exceed 10 digits!");
            setTimeout(() => {
                this.value = this.value.slice(0, 10); 
            }, 10); 
        }
});


    document.getElementById("email").addEventListener("blur", function () {
        let emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        // Validate email format when the user leaves the field
        if (this.value && !emailPattern.test(this.value)) {
            showToast("Please enter a valid email address!");
            this.value = "";
        }
    });


    document.querySelectorAll("#firmName, #distributorName").forEach(input => {
    input.addEventListener("input", function () {
        // Limit to 50 characters
        if (this.value.length > 50) {
            showToast("Maximum 50 characters allowed!");
            this.value = this.value.slice(0, 50);
        }
    });
 });

});
  
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('input[type="number"]').forEach(input => {
        input.addEventListener('input', function () {
            this.value = this.value.replace(/[^0-9]/g, ''); 
        });
    });
});


</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        <% if (notification) { %>
            Swal.fire({
                icon: '<%= notification.type %>', 
                title: '<%= notification.message %>',
                showConfirmButton: false,
                timer: 2000
            });
        <% } %>
    });
</script>

<script>
    $(document).ready(function () {
    let currentStep = 1;

    $(".next").click(function () {
        let isValid = true;

        $("#step" + currentStep + " :input[required]").each(function () {
            let inputType = $(this).attr("type");
            let inputValue = ($(this).val() || "").trim();

            let errorMessage = "";

            $(this).siblings(".invalid-feedback").remove();

            if (inputType === "radio") {
                let radioName = $(this).attr("name");
                let errorDiv = $("#" + radioName + "Error");

                if ($("input[name='" + radioName + "']:checked").length === 0) {
                    isValid = false;
                    $("input[name='" + radioName + "']").addClass("is-invalid");
                    errorDiv.text("Please select an option.");
                } else {
                    $("input[name='" + radioName + "']").removeClass("is-invalid");
                    errorDiv.text("");
                }
            }

            else if (inputType === "file") {
                if (!$(this)[0].files.length) {
                    isValid = false;
                    $(this).addClass("is-invalid");
                    errorMessage = "Please upload a file.";
                } else {
                    $(this).removeClass("is-invalid");
                }
            }
           else if ($(this).attr("id") === "contactNumber") {
                let mobilePattern = /^[1-9]\d{9}$/;

                if (!mobilePattern.test(inputValue)) {
                    isValid = false;
                    $(this).addClass("is-invalid");
                    errorMessage = "Enter a valid 10-digit mobile number (without leading zeros).";
                } else {
                    $(this).removeClass("is-invalid");
                }
            }
            else {
                if (!inputValue) {
                    isValid = false;
                    $(this).addClass("is-invalid");
                    errorMessage = "This field is required.";
                } else {
                    $(this).removeClass("is-invalid");
                }
            }

            if (!isValid && errorMessage) {
                $(this).after(`<div class="invalid-feedback">${errorMessage}</div>`);
            }
        });

        if (isValid) {
            $("#step" + currentStep).addClass("hidden");
            currentStep++;
            $("#step" + currentStep).removeClass("hidden");
        } else {
            Swal.fire({
                icon: "error",
                title: "Validation Failed!",
                text: "Please fill all required fields correctly before proceeding.",
                confirmButtonText: "OK"
            });
        }
    });

    $(".prev").click(function () {
        $("#step" + currentStep).addClass("hidden");
        currentStep--;
        $("#step" + currentStep).removeClass("hidden");
    });

    $("#contactNumber").on("input", function () {
        this.value = this.value.replace(/\D/g, ""); 

        if (this.value.length > 10) {
            this.value = this.value.slice(0, 10);
        }
    });

    // Save Draft
    $(document).on("click", "#saveDraft", function () {
            let distributorId = new URLSearchParams(window.location.search).get("id");

            let territoryElement = document.getElementById('territory_id');
            let territoryValue = territoryElement ? territoryElement.value.trim() : "";

            if (territoryValue === "") {
                Swal.fire({
                    icon: "warning",
                    title: "Territory Required!",
                    text: "Please select a territory before saving the draft.",
                    showConfirmButton: true
                });
                return; 
            }

            let formData = new FormData($("#multiStepForm")[0]);

            formData.append("id", distributorId);
    
            $.ajax({
                url: "/Add_distributor/save_draft",
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    Swal.fire({
                        icon: "success",
                        title: "Draft Saved Successfully!",
                        showConfirmButton: false,
                        timer: 2000
                    });
    
                    if (response.distributorId && response.distributorId !== null) {
                        setTimeout(() => {
                            window.location.href = `/edit_distributor?id=${response.distributorId}`;
                        }, 500);
                    } else {
                        Swal.fire({
                            icon: "error",
                            title: "Distributor ID Not Found!",
                            text: "Please try again later.",
                            showConfirmButton: true
                        });
                    }
                },
                error: function (error) {
                    console.error("AJAX Error:", error);
                    Swal.fire({
                        icon: "error",
                        title: "Failed to Save Draft!",
                        text: error.responseText || "An error occurred",
                        showConfirmButton: true
                    });
                }
            });
        });
    });

  </script>
    


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const submitButton = document.querySelector("button[type='submit']");
        const form = document.querySelector("form");
    
        function validateStep2() {
            let isValid = true;
            let step2Fields = document.querySelectorAll("#step2 input, #step2 select");
    
            step2Fields.forEach((field) => {
                let inputType = field.type;
                
                if (inputType === "radio") {
                    let name = field.name;
                    if (!document.querySelector(`input[name='${name}']:checked`)) {
                        isValid = false;
                        field.classList.add("is-invalid");
                    } else {
                        field.classList.remove("is-invalid");
                    }
                } 
                else if (inputType === "file") {
                    if (!field.files.length) {
                        isValid = false;
                        field.classList.add("is-invalid");
                    } else {
                        field.classList.remove("is-invalid");
                    }
                } 
                else {
                    if (!field.value.trim()) {
                        isValid = false;
                        field.classList.add("is-invalid");
                    } else {
                        field.classList.remove("is-invalid");
                    }
                }
            });
    
            return isValid;
        }
    
        form.addEventListener("submit", function (event) {
            if (!validateStep2()) {
                event.preventDefault();
                Swal.fire({
                    icon: "error",
                    title: "Incomplete Form",
                    text: "Please fill all fields before submitting.",
                    confirmButtonText: "OK"
                });
            } else {
                const submitButton = event.submitter;
                submitButton.disabled = true;
                submitButton.textContent = "Processing...";

                // Disable other buttons
                const otherButtons = form.querySelectorAll('button:not([type="submit"])');
                otherButtons.forEach(btn => {
                    btn.disabled = true;
                });

                setTimeout(() => {
                    submitButton.classList.add("btn-secondary");
                }, 100);
            }
        });


        
    
    });
</script>


<script>
    document.addEventListener("DOMContentLoaded", function () {
      const replacementRadio = document.getElementById("replacement");
      const replacementOptionsContainer = document.getElementById("replacement-options-container");
    
      replacementRadio.addEventListener("change", function () {
        if (this.checked) {
          replacementOptionsContainer.style.display = "block";
        }
      });
    
      // Optionally hide the field if other radios are selected
      const radios = document.querySelectorAll('input[name="applicationType"]');
      radios.forEach(radio => {
        radio.addEventListener('change', function () {
          if (this.value !== "Replacement") {
            replacementOptionsContainer.style.display = "none";
          }
        });
      });
    });
</script>
    
