                                </div>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="delivery_time">What is the average delivery time for the distributor?</label>
                                <input type="number" id="delivery_time" name="delivery_time" class="form-control" placeholder="Enter delivery time in days" required>
