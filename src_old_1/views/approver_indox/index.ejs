<%- include("../shared/header.ejs") %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css">

<style>
    .hidden { display: none; }
</style>
<style>
    .scroll-section {
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
    .modal-backdrop {
        display: none !important;
    }

    .modal-body {
        max-height: 440px;
        overflow-y: auto;
    }
    .modal-dialog{
        width:75%;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th, td {
        border: 1px solid #ccc;
        padding: 10px;
        text-align: center;
    }

    .view-icon {
        cursor: pointer;
        font-size: 20px;
    }
  </style>

  <style>
    .table-dark th {
        color: #0000A0 !important; 
        background-color: #E0E0FC;
        border: 1px solid rgb(224, 203, 203);
    }
    #distributorTable tbody tr:nth-child(odd) td {
        background: #FFFFFF !important; 
    }
    #distributorTable tbody tr:nth-child(even) td {
        background: #EFEFFF !important; 
    }
    .dt-buttons .btn, .buttons-copy, .buttons-csv {
        background-color: #007bff !important;
        color: white !important; 
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
    }
  </style>


   
<div class="container mt-4">
    <div class="d-flex justify-content-between mb-2">
        <script>
            const distributorsData = <%- JSON.stringify(distributors) %>;
        </script>

           <div class="d-flex gap-2 ms-auto">
            <select id="statusFilter" class="form-select">
                <option value="">Filter by Status</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Correction">Correction</option>
                <option value="Rejected">Rejected</option>
            </select>

            <select id="typeFilter" class="form-select">
                <option value="" selected disabled>Select Forwarded To</option>
                
                <% if (token[0]?.role_id !== 4) { %>
                    <option value="4">Pending at RSM</option>
                <% } %>
                <% if (token[0]?.role_id !== 5) { %>
                    <option value="5">Pending at O2C</option>
                <% } %>
                <% if (token[0]?.role_id !== 6) { %>
                    <option value="6">Pending at SNF</option>
                <% } %>
                <% if (token[0]?.role_id !== 7) { %>
                    <option value="7">Pending at MDM</option>
                <% } %>
                <% if (token[0]?.role_id !== 8) { %>
                    <option value="8">Pending at DT Team</option>
                <% } %>
            </select>
            
            
            
        </div>
    </div>

    <div class="table-responsive">
        <table id="distributorTable" class="table table-striped table-bordered display nowrap" style="width:100%">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Firm Name</th>
                    <th>DB Type</th>
                    <th>Application Type</th>
                    <th>Distributor Name</th>
                    <th>email</th>
                    <th>contactNumber</th>
                    <th>Start Date</th>
                    <th>Initiator Email</th>
                    <th>Status</th>
                    <th>Pending Level</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="distributorBody">
                <% if (distributors?.length > 0) { %>
                    <% distributors.forEach((distributor) => { %>
                        <tr>
                            <td><%= distributor?.id ?? 'N/A' %></td>
                            <td><%= distributor?.firmName ?? 'N/A' %></td>
                            <td><%= distributor?.dbType ?? 'N/A' %></td>
                            <td><%= distributor?.applicationType ?? 'N/A' %></td>
                            <td><%= distributor?.distributorName ?? 'N/A' %></td>
                            <td><%= distributor?.email ?? 'N/A' %></td>
                            <td><%= distributor?.contactNumber ?? 'N/A' %></td>
                            <td><%= distributor?.applicationStartDate ? new Date(distributor?.applicationStartDate).toLocaleDateString('en-GB') : 'N/A' %></td>
                            <td><%= distributor?.aseemail ?? 'N/A' %></td>
                            <td>
                                <% if ((distributor.lower_pending == 1 || distributor.lower_pending == 0) && distributor.is_final_approver == 0 && distributor.flag == 0) { %>
                                    <span class="badge bg-primary text-white">Pending</span>
                                <% } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 1) { %>
                                    <span class="badge bg-success">Approved</span>
                                <% } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 0 && distributor.flag == 3 && distributor.applicationStatus == 'Correction') { %>
                                    <span class="badge bg-warning text-dark">Correction</span>
                                <% } else if (distributor.flag === 2) { %>
                                    <span class="badge bg-danger text-white">Rejected</span>
                                <% } else { %>
                                    <span class="badge bg-primary text-white">Pending</span>    
                                <% } %>
                            </td>
                            <td>
                                <%= distributor?.flag == 2 
                                ? 'Rejected' 
                                : distributor?.current_pending_approver_role 
                                    ? `Pending On ${distributor.current_pending_approver_role}` 
                                    : 'Onboarded' %>
                            </td>
                             <td>
                                <% if (distributor.lower_pending == 0 && distributor.is_final_approver == 0 && distributor.flag == 0) { %>
                                    <a href="/approver_indox/<%= distributor.id %>">
                                        <button class="btn btn-primary">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="14" class="text-center">No distributors found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    $(document).ready(function () {
        let table = $('#distributorTable').DataTable({
            paging: true,
            searching: true,
            ordering: true,
            info: true,
            lengthMenu: [5, 10, 25, 50],
            pageLength: 10,
        });

        // Custom filter for status
        $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
            const status = $('#statusFilter').val().toLowerCase();
            const statusText = data[9].toLowerCase(); 
            return status ? statusText.includes(status) : true;
        });

        $('#statusFilter').on('change', function () {
            table.draw();
        });

        $('#typeFilter').on('change', function () {
            const forwardedTo = $(this).val();
            const forwardedToText = $('#typeFilter option:selected').text(); // get option label

            fetch(`/approver_indox/hierarchyRole/distributors?forwardedTo=${encodeURIComponent(forwardedTo)}`)
                .then(res => res.json())
                .then(response => {
                    const distributors = Array.isArray(response?.data) ? response.data : [];

                    table.clear().destroy();

                    // Clear current rows
                    $('#distributorBody').empty();

                    if (distributors.length > 0) {
                        distributors.forEach(distributor => {
                            const row = `
                                <tr>
                                    <td>${distributor.id || 'N/A'}</td>
                                    <td>${distributor.firmName || 'N/A'}</td>
                                    <td>${distributor.dbType || 'N/A'}</td>
                                    <td>${distributor.applicationType || 'N/A'}</td>
                                    <td>${distributor.distributorName || 'N/A'}</td>
                                    <td>${distributor.email || 'N/A'}</td>
                                    <td>${distributor.contactNumber || 'N/A'}</td>
                                    <td>${distributor.applicationStartDate ? new Date(distributor.applicationStartDate).toLocaleDateString('en-GB') : 'N/A'}</td>
                                    <td>${distributor.aseemail || 'N/A'}</td>
                                    <td><span class="badge bg-primary text-white">Pending</span></td>
                                    <td>${forwardedToText}</td>
                                    <td></td>
                                </tr>`;
                            $('#distributorBody').append(row);
                        });
                    }  else {
                        $('#distributorBody').append(`<tr>${'<td>-</td>'.repeat(12)}</tr>`);
                    }

                    table = $('#distributorTable').DataTable({
                        paging: true,
                        searching: true,
                        ordering: true,
                        info: true,
                        lengthMenu: [5, 10, 25, 50],
                        pageLength: 10,
                    });
                })
                .catch(err => {
                    console.error('Error fetching filtered data:', err);
                });
        });

        function getStatusBadge(distributor) {
            if ((distributor.lower_pending == 1 || distributor.lower_pending == 0) && distributor.is_final_approver == 0 && distributor.flag == 0) {
                return `<span class="badge bg-primary text-white">Pending</span>`;
            } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 1) {
                return `<span class="badge bg-success">Approved</span>`;
            } else if (distributor.lower_pending == 0 && distributor.is_final_approver == 0 && distributor.flag == 3 && distributor.applicationStatus == 'Correction') {
                return `<span class="badge bg-warning text-dark">Correction</span>`;
            } else if (distributor.flag === 2) {
                return `<span class="badge bg-danger text-white">Rejected</span>`;
            }
            return '';
        }

        function getAction(distributor) {
            if (distributor.lower_pending == 0 && distributor.is_final_approver == 0 && distributor.flag == 0) {
                return `<a href="/approver_indox/${distributor.id}">
                            <button class="btn btn-primary">
                                <i class="fa fa-eye"></i>
                            </button>
                        </a>`;
            }
            return '';
        }
    });
</script>




<script>
    function confirmDelete(id) {
    Swal.fire({
        title: "Are you sure?",
        text: "You won't be able to revert this!",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Yes, delete it!"
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/edit_distributor/delete_distributor?id=${id}`;
        }
    });
}
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        <% if (notification) { %>
            Swal.fire({
                icon: '<%= notification.type %>', 
                title: '<%= notification.message %>',
                showConfirmButton: false,
                timer: 2000
            });
        <% } %>
    });
</script>


