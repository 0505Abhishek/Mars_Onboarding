<%- include("../shared/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
    .hidden { display: none; }
</style>
<style>
    .scroll-section {
      max-height: 600px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
  </style>



   
<div class="container mt-5">
    <div class="card">
        <div class="card-body">
            <form id="multiStepForm" method="post" action="/edit_distributor?id=<%= distributorData.id %>">
                
                <!-- Step 1: Add Distributor -->
                <div class="step" id="step1">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 style="color: #41378d;">Distributor</h2>
                        <a href="/distributor_draft_list" class="btn btn-primary">Draft List</a>
                    </div>
                
                    <!-- Application Type -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Application Type</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="new" value="New" 
                                    <% if(distributorData.applicationType === 'New') { %> checked <% } %> required>
                                <label class="form-check-label" for="new">New</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="applicationType" id="replacement" value="Replacement"
                                    <% if(distributorData.applicationType === 'Replacement') { %> checked <% } %> required>
                                <label class="form-check-label" for="replacement">Replacement</label>
                            </div>
                        </div>
                    </div>
                
                    <!-- Hidden select initially -->
                    <div class="mb-3" id="replacement-options-container" style="display: none;">
                        <label for="replacementOption" class="form-label fw-bold">Choose Replacement Option</label>
                        <select id="replacementOption" name="replacedFirmName" class="form-select">
                            <option value="<%= distributorData?.replacedFirmName ? 'selected' : '' %>"><%= distributorData?.replacedFirmName %></option>
                            <% replacementOptions?.forEach(function(option) { %>
                                <option value="<%= option?.firmName %>"><%= option?.firmName %></option>
                            <% }) %>
                        </select>
                        <div class="text-danger error-message" id="replacementOptionError"></div>
                   </div>

                    <!-- DB Type -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="dbType" class="form-label fw-bold">DB Type</label>
                            <select class="form-select" id="dbType" name="dbType" required>
                                <option value=""  <% if(!distributorData?.dbType) { %> selected <% } %>>Select DB Type</option>
                                <option value="Hub" <% if(distributorData?.dbType === 'Hub') { %> selected <% } %>>Hub</option>
                                <option value="TT" <% if(distributorData?.dbType === 'TT') { %> selected <% } %>>TT</option>
                                <option value="MT" <% if(distributorData?.dbType === 'MT') { %> selected <% } %>>MT</option>
                                <option value="OOH" <% if(distributorData?.dbType === 'OOH') { %> selected <% } %>>OOH</option>
                                <option value="DCOM" <% if(distributorData?.dbType === 'DCOM') { %> selected <% } %>>DCOM</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3 position-relative">
                            <label for="dbType" class="form-label fw-bold">Territory</label>
                        
                            <select 
                                class="form-select" 
                                id="territory_id" 
                                name="territory_id" 
                                required 
                                <%= distributorData && distributorData.isFlagstatus == 1 ? "disabled" : "" %>
                            >
                                <option value="" disabled <%= !distributorData || !distributorData.territory_id ? "selected" : "" %>>
                                    Select Territory Type
                                </option>
                                <% territories.forEach(function(territory) { %>
                                    <option 
                                        value="<%= territory.territory_id %>" 
                                        <%= distributorData && distributorData.territory_id == territory.territory_id ? "selected" : "" %>>
                                        <%= territory.territory_name %>
                                    </option>
                                <% }) %>
                            </select>
                        
                            <% if (distributorData && distributorData.invite_send_flag == 1) { %>
                                <div 
                                    class="territory-overlay" 
                                    onclick="territoryBlockedAlert()" 
                                    style="position:absolute; top:0; left:0; right:0; bottom:0; z-index:5; cursor:not-allowed;">
                                </div>
                                <input type="hidden" name="territory_id" value="<%= distributorData.territory_id %>">
                            <% } %>
                        
                            <div class="text-danger error-message" id="TerritoryError"></div>
                        </div>          
                    </div>
                    
                
                    <!-- Two-Column Form Layout -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="firmName" class="form-label fw-bold">Firm's Name</label>
                            <input type="text" class="form-control" id="firmName" name="firmName" value="<%= distributorData.firmName %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="distributorName" class="form-label fw-bold">Distributor's Name</label>
                            <input type="text" class="form-control" id="distributorName" name="distributorName" value="<%= distributorData.distributorName %>" required>
                        </div>
                    </div>
                
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label fw-bold">Email ID</label>
                            <input type="email" class="form-control" id="email" name="email" value="<%= distributorData.email %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="contactNumber" class="form-label fw-bold">Contact Number</label>
                            <input type="text" class="form-control" id="contactNumber" name="contactNumber" value="<%= distributorData.contactNumber %>" required>
                        </div>
                    </div>
                
                    
                    <div class="row">
                        <!-- Years of Experience in Distribution Business -->
                        <div class="col-md-6 mb-3">
                            <label for="experienceDistribution" class="form-label fw-bold">Years of Experience in Distribution Business</label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="experienceDistribution" 
                                name="experienceDistribution" 
                                value="<%= distributorData.experienceDistribution %>" 
                                required
                            >
                        </div>
                    
                        <!-- Years of Experience in FMCG Distribution Business -->
                        <div class="col-md-6 mb-3">
                            <label for="experienceFMCG" class="form-label fw-bold">Years of Experience in FMCG Distribution Business</label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="experienceFMCG" 
                                name="experienceFMCG" 
                                value="<%= distributorData.experienceFMCG %>" 
                                required
                            >
                        </div>
                    </div>
                    
                    
                    <div class="row">
                        <!-- Number of Outlets Covered -->
                        <div class="col-md-6 mb-3">
                            <label for="outletsCovered" class="form-label fw-bold">Number of Outlets Covered</label>
                            <input 
                                type="text" 
                                class="form-control" 
                                id="outletsCovered" 
                                name="outletsCovered" 
                                value="<%= distributorData.outletsCovered %>" 
                                required
                            >
                        </div>
                        
                    
                        <!-- Total Monthly Turnover -->
                        <div class="col-md-6 mb-3">
                            <label for="monthlyTurnover" class="form-label fw-bold">Total Monthly Turnover</label>
                            <input type="text" class="form-control" id="monthlyTurnover" name="monthlyTurnover" placeholder="Enter Monthly Turnover" required inputmode="decimal" value="<%= distributorData.monthlyTurnover || '' %>" />
                            <div class="text-danger error-message" id="monthlyTurnoverError"></div>
                        </div>
                    </div>
                    
                    
                
                    <div class="d-flex justify-content-between w-100">
                        <button style="width:150px" type="button" class="btn btn-primary" id="saveDraft">Save Draft</button>
                        <button style="width:150px" type="button" class="btn btn-primary next">Next</button>
                    </div>
                </div>
                
                
                <!-- Step 2: Questions -->
                <div class="step hidden" id="step2">
                    <div class="container mt-4">
                        <h2>Distributor Evaluation Form</h2>
                
                        <!-- Scroll 1: Commercial Structure -->
                        <div class="scroll-section">
                            <h4>Commercial Structure</h4>
                        
                            <div class="mb-3">
                                <label class="form-label" for="stores_covered">How many stores does the DTR cover?</label>
                                <select id="stores_covered" name="stores_covered" class="form-control">
                                    <option value="">Select</option>
                                    <option value="Less than 1k" <%= distributorData.stores_covered === 'Less than 1k' ? 'selected' : '' %>>Less than 1k</option>
                                    <option value="1k-3k" <%= distributorData.stores_covered === '1k-3k' ? 'selected' : '' %>>1k-3k</option>
                                    <option value="3k-5k" <%= distributorData.stores_covered === '3k-5k' ? 'selected' : '' %>>3k-5k</option>
                                    <option value="Above 5k" <%= distributorData.stores_covered === 'Above 5k' ? 'selected' : '' %>>Above 5k</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="roi">What is the Annual Return of Investment (ROI %)?</label>
                                <input type="number" id="roi" name="roi" class="form-control" placeholder="Enter ROI percentage" value="<%= distributorData.roi || '' %>">
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the distributor work with other FMCG companies?</label>
                                <div class="d-flex align-items-center">
                                    <input type="radio" id="fmcg_yes" name="fmcg_companies" value="Yes" <%= distributorData.fmcg_companies === 'Yes' ? 'checked' : '' %>>
                                    <label for="fmcg_yes" class="ms-2 me-3">Yes</label>
                        
                                    <input type="radio" id="fmcg_no" name="fmcg_companies" value="No" <%= distributorData.fmcg_companies === 'No' ? 'checked' : '' %>>
                                    <label for="fmcg_no" class="ms-2">No</label>
                                </div>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="fmcg_experience">How many years of FMCG experience does the distributor have?</label>
                                <select id="fmcg_experience" name="fmcg_experience" class="form-control">
                                    <option value="">Select</option>
                                    <option value="1" <%= distributorData.fmcg_experience === '1' ? 'selected' : '' %>>1</option>
                                    <option value="2" <%= distributorData.fmcg_experience === '2' ? 'selected' : '' %>>2</option>
                                    <option value="3" <%= distributorData.fmcg_experience === '3' ? 'selected' : '' %>>3</option>
                                    <option value="4" <%= distributorData.fmcg_experience === '4' ? 'selected' : '' %>>4</option>
                                    <option value="5" <%= distributorData.fmcg_experience === '5' ? 'selected' : '' %>>5</option>
                                    <option value="Above 5 Years" <%= distributorData.fmcg_experience === 'Above 5 Years' ? 'selected' : '' %>>Above 5 Years</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="stores_mars">How many stores does the DB cover with Mars Wrigley?</label>
                                <select id="stores_mars" name="stores_mars" class="form-control">
                                    <option value="">Select</option>
                                    <option value="Less than 1k" <%= distributorData.stores_mars === 'Less than 1k' ? 'selected' : '' %>>Less than 1k</option>
                                    <option value="1k-3k" <%= distributorData.stores_mars === '1k-3k' ? 'selected' : '' %>>1k-3k</option>
                                    <option value="3k-5k" <%= distributorData.stores_mars === '3k-5k' ? 'selected' : '' %>>3k-5k</option>
                                    <option value="Above 5k" <%= distributorData.stores_mars === 'Above 5k' ? 'selected' : '' %>>Above 5k</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="sales_reps">How many sales reps (DSR, KAE, ISR, etc.) does the distributor have?</label>
                                <select id="sales_reps" name="sales_reps" class="form-control">
                                    <option value="">Select</option>
                                    <option value="1-10" <%= distributorData.sales_reps === '1-10' ? 'selected' : '' %>>1-10</option>
                                    <option value="Above 10" <%= distributorData.sales_reps === 'Above 10' ? 'selected' : '' %>>Above 10</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="growth_percentage">Existing Business Growth - Same Manufacturer Growth</label>
                                <p>
                                    If Growth > 10% → Score: 1 <br>
                                    If Growth 0% - 10% → Score: 0.5 <br>
                                    If Growth < 0% → Score: 0
                                </p>
                                <select id="growth_percentage" name="growth_percentage" class="form-control">
                                    <option value="">Select</option>
                                    <option value="1" <%= distributorData.growth_percentage === '1' ? 'selected' : '' %>>1</option>
                                    <option value="0.5" <%= distributorData.growth_percentage === '0.5' ? 'selected' : '' %>>0.5</option>
                                    <option value="0" <%= distributorData.growth_percentage === '0' ? 'selected' : '' %>>0</option>
                                </select>
                            </div>
                        
                
                        <!-- Scroll 2: Commercial WoW -->
                            <h4>Commercial WoW</h4></br>
                            <div class="mb-3">
                                <label class="form-label" for="perfect_store_score">What is the average Perfect Store Overall score in the stores covered by the distributor?</label>
                                <input type="number" id="perfect_store_score" name="perfect_store_score" class="form-control" placeholder="Enter store score" value="<%= distributorData.perfect_store_score %>">
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="selling_model">What selling model does the distributor operate with?</label>
                                <input type="text" id="selling_model" name="selling_model" class="form-control" placeholder="Enter selling model" value="<%= distributorData.selling_model %>">
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="mw_compliance">Is the distributor compliant with MW standards?</label>
                                <input type="text" id="mw_compliance" name="mw_compliance" class="form-control" placeholder="Enter compliance details" value="<%= distributorData.mw_compliance %>">
                            </div>
                
                        <!-- Scroll 3: Data Sharing -->
                            <h4>Data Sharing</h4></br>
                            <div class="mb-3">
                                <label class="form-label">Does the distributor provide visibility on distributor cost structure to MW?</label>
                                <div>
                                    <input type="radio" id="cost_structure_yes" name="cost_structure" value="Yes" 
                                        <%= distributorData.cost_structure === 'Yes' ? 'checked' : '' %>>
                                    <label for="cost_structure_yes">Yes</label>
                        
                                    <input type="radio" id="cost_structure_no" name="cost_structure" value="No" 
                                        <%= distributorData.cost_structure === 'No' ? 'checked' : '' %>>
                                    <label for="cost_structure_no">No</label>
                                </div>
                            </div>
                        
                
                        <!-- Scroll 4: Platform to Scale Up -->
                            <h4>Digital Readiness</h4></br>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the DB have a data operator for DMS?</label>
                                <div>
                                    <input type="radio" id="data_operator_yes" name="data_operator" value="Yes" <%= distributorData.data_operator === "Yes" ? "checked" : "" %> >
                                    <label for="data_operator_yes">Yes</label>
                                    <input type="radio" id="data_operator_no" name="data_operator" value="No" <%= distributorData.data_operator === "No" ? "checked" : "" %> >
                                    <label for="data_operator_no">No</label>
                                </div>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the DB have an internet connection?</label>
                                <div>
                                    <input type="radio" id="internet_access_yes" name="internet_access" value="Yes" <%= distributorData.internet_access === "Yes" ? "checked" : "" %> >
                                    <label for="internet_access_yes">Yes</label>
                                    <input type="radio" id="internet_access_no" name="internet_access" value="No" <%= distributorData.internet_access === "No" ? "checked" : "" %> >
                                    <label for="internet_access_no">No</label>
                                </div>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the DB use a printer?</label>
                                <div>
                                    <input type="radio" id="printer_use_yes" name="printer_use" value="Yes" <%= distributorData.printer_use === "Yes" ? "checked" : "" %> >
                                    <label for="printer_use_yes">Yes</label>
                                    <input type="radio" id="printer_use_no" name="printer_use" value="No" <%= distributorData.printer_use === "No" ? "checked" : "" %> >
                                    <label for="printer_use_no">No</label>
                                </div>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="dms_count">How many DMS for other companies including does the DB use?</label>
                                <select id="dms_count" name="dms_count" class="form-control">
                                    <option value="">Select an option</option>
                                    <option value="1" <%= distributorData.dms_count === "1" ? "selected" : "" %>>1</option>
                                    <option value="2" <%= distributorData.dms_count === "2" ? "selected" : "" %>>2</option>
                                    <option value="3" <%= distributorData.dms_count === "3" ? "selected" : "" %>>3</option>
                                    <option value="4" <%= distributorData.dms_count === "4" ? "selected" : "" %>>4</option>
                                    <option value="5" <%= distributorData.dms_count === "5" ? "selected" : "" %>>5</option>
                                    <option value="Above 5" <%= distributorData.dms_count === "Above 5" ? "selected" : "" %>>Above 5</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label">Which system is used to print final in-market bill?</label>
                                <div>
                                    <input type="radio" name="print_system" value="Ivy DMS" id="ivyDMS" <%= distributorData.print_system === "Ivy DMS" ? "checked" : "" %> >
                                    <label for="ivyDMS">Ivy DMS</label>
                                </div>
                                <div>
                                    <input type="radio" name="print_system" value="Own system" id="ownSystem" <%= distributorData.print_system === "Own system" ? "checked" : "" %> >
                                    <label for="ownSystem">Own system</label>
                                </div>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label">If DB is not using Ivy DMS, is DB ok to integrate their system with Mars DMS for final in-market bill?</label>
                                <div>
                                    <input type="radio" name="mars_integration" value="Yes" id="marsIntegrationYes" <%= distributorData.mars_integration === "Yes" ? "checked" : "" %> >
                                    <label for="marsIntegrationYes">Yes</label>
                                </div>
                                <div>
                                    <input type="radio" name="mars_integration" value="No" id="marsIntegrationNo" <%= distributorData.mars_integration === "No" ? "checked" : "" %> >
                                    <label for="marsIntegrationNo">No</label>
                                </div>
                            </div>
                        
                
                            <h4>Logistics</h4></br>
                        
                            <div class="mb-3">
                                <label class="form-label">Does the distributor have controlled temperature storage and transportation?</label>
                                <div>
                                    <input type="radio" id="temp_storage_yes" name="temp_storage" value="Yes" <%= distributorData.temp_storage === "Yes" ? "checked" : "" %> required>
                                    <label for="temp_storage_yes">Yes</label>
                                    <input type="radio" id="temp_storage_no" name="temp_storage" value="No" <%= distributorData.temp_storage === "No" ? "checked" : "" %> required>
                                    <label for="temp_storage_no">No</label>
                                </div>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="delivery_time">What is the average delivery time for the distributor?</label>
                                <input type="number" id="delivery_time" name="delivery_time" class="form-control" placeholder="Enter delivery time in days" value="<%= distributorData.delivery_time %>" required>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="returns_rate">What is the average returns rate on total sales for the distributor?</label>
                                <input type="number" id="returns_rate" name="returns_rate" class="form-control" placeholder="Enter returns percentage" value="<%= distributorData.returns_rate %>" required>
                            </div>
                
                            <h4>Partnership</h4></br>
                        
                            <!-- MW Sales Share Percentage -->
                            <div class="mb-3">
                                <label class="form-label" for="mw_sales_share">What is the share of MW sales on total confectionery sales for the distributor?</label>
                                <input type="number" id="mw_sales_share" name="mw_sales_share" class="form-control" placeholder="Enter percentage" value="<%= distributorData.mw_sales_share %>">
                            </div>
                        
                            <!-- Openness to Change Dropdown -->
                            <div class="mb-3">
                                <label class="form-label" for="openness_change">What is the openness to change of the distributor?</label>
                                <select id="openness_change" name="openness_change" class="form-control">
                                    <option value="" >Select an option</option>
                                    <option value="Ready to change" <%= distributorData.openness_change === "Ready to change" ? "selected" : "" %>>Ready to change</option>
                                    <option value="Somewhat ready to change" <%= distributorData.openness_change === "Somewhat ready to change" ? "selected" : "" %>>Somewhat ready to change</option>
                                    <option value="Not ready to change" <%= distributorData.openness_change === "Not ready to change" ? "selected" : "" %>>Not ready to change</option>
                                </select>
                            </div>
                        
                            <!-- Confectionery Sales Share Percentage -->
                            <div class="mb-3">
                                <label class="form-label" for="confectionery_sales_share">What is the share of confectionery on total distributors' sales?</label>
                                <input type="number" id="confectionery_sales_share" name="confectionery_sales_share" class="form-control" placeholder="Enter percentage" value="<%= distributorData.confectionery_sales_share %>">
                            </div>
                        
                            <!-- FTEs Dedicated to MW Dropdown -->
                            <div class="mb-3">
                                <label class="form-label" for="fte_dedicated">How many of distributors' FTEs are dedicated to MW?</label>
                                <select id="fte_dedicated" name="fte_dedicated" class="form-control">
                                    <option value="" >Select an option</option>
                                    <option value="1-10" <%= distributorData.fte_dedicated === "1-10" ? "selected" : "" %>>1-10</option>
                                    <option value="Above 10" <%= distributorData.fte_dedicated === "Above 10" ? "selected" : "" %>>Above 10</option>
                                </select>
                            </div>
                        
                            <!-- MW Influence Level Dropdown -->
                            <div class="mb-3">
                                <label class="form-label" for="mw_influence">What is the level of MW influence / sharing in the distributor's business planning process?</label>
                                <select id="mw_influence" name="mw_influence" class="form-control">
                                    <option value="" >Select an option</option>
                                    <option value="High" <%= distributorData.mw_influence === "High" ? "selected" : "" %>>High</option>
                                    <option value="Average" <%= distributorData.mw_influence === "Average" ? "selected" : "" %>>Average</option>
                                    <option value="Low" <%= distributorData.mw_influence === "Low" ? "selected" : "" %>>Low</option>
                                </select>
                            </div>
                        

                            <h4>Digital Readiness</h4></br>
                        
                            <div class="mb-3">
                                <label class="form-label" for="capital_infrastructure">
                                    Does the distributor have sufficient capital and/or infrastructure to increase coverage?
                                </label>
                                <select id="capital_infrastructure" name="capital_infrastructure" class="form-control">
                                    <option value="">Select an option</option>
                                    <option value="Yes" <%= distributorData.capital_infrastructure === 'Yes' ? 'selected' : '' %>>Yes</option>
                                    <option value="No" <%= distributorData.capital_infrastructure === 'No' ? 'selected' : '' %>>No</option>
                                </select>
                            </div>
                        
                            <div class="mb-3">
                                <label class="form-label" for="dtr_nps_score">
                                    What is the DTR NPS score from their customers (stores)?
                                </label>
                                <input type="number" id="dtr_nps_score" name="dtr_nps_score" class="form-control" 
                                    placeholder="Enter numeric score" value="<%= distributorData.dtr_nps_score %>">
                            </div>
                        
                
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap">
                        <!-- Left side buttons -->
                        <div class="d-flex gap-2 flex-wrap">
                            <button style="width: 160px;" type="button" class="btn btn-primary prev">Back</button>
