<script>
    document.addEventListener("DOMContentLoaded", function () {
        const replacementRadio = document.getElementById("replacement");
        const replacementOptionsContainer = document.getElementById("replacement-options-container");
        const radios = document.querySelectorAll('input[name="applicationType"]');
    
        function toggleReplacementOptions() {
            if (replacementRadio.checked) {
                replacementOptionsContainer.style.display = "block";
            } else {
                replacementOptionsContainer.style.display = "none";
            }
        }
    
        toggleReplacementOptions();
    
        radios.forEach(radio => {
            radio.addEventListener("change", toggleReplacementOptions);
        });
    });
</script>


