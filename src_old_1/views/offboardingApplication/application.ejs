<%- include("../shared/header.ejs") %>
<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Custom CSS -->
<style>
    .form-card {
      background-color: #f4f1ff;
      border-radius: 25px;
      padding: 20px 40px;
      max-width: 740px;
      margin: auto;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
  
    .form-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }
  
    .form-row label {
      flex: 1;
      font-weight: 600;
      color: #2d2d2d;
    }
  
    .form-check-label {
      margin-right: 15px;
      font-weight: 600;
      color: #2e2da5;
    }
  
    .form-check-input {
      width: 50px;
      height: 25px;
      cursor: pointer;
    }
  
    .submit-btn {
      background-color: #2264e5;
      color: white;
      padding: 10px 40px;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      transition: 0.3s ease;
    }
  
    .submit-btn:hover {
      background-color: #1a4cb8;
    }
  
    .rounded-input {
      border-radius: 10px;
    }
  
    .heading {
      font-weight: bold;
      font-size: 20px;
      color: #2e2da5;
      text-align: center;
      margin-bottom: 30px;
    }
  
    .d-flex {
      display: flex;
      align-items: center;
    }
  
    .gap-4 {
      gap: 1.5rem;
    }
  
    .text-center {
      text-align: center;
    }
  
    .mt-4 {
      margin-top: 1.5rem;
    }
  
    .w-50 {
      width: 50%;
    }

  .custom-radio:checked {
    background-color: #28a745 !important; 
    border-color: #28a745 !important;
  }

  .custom-radio:checked:focus {
    box-shadow: 0 0 0 0.25rem rgba(40, 167, 69, 0.25);
  }

  </style>
  
<div class="container mt-5">
    <div class="heading">Kindly fill in the following details.</div>

    <div class="form-card">  
      <form action="/offboardApplication/<%= application_id %>" method="POST" enctype="multipart/form-data" id="offboardingForm">
        
        <% if (roleName && roleName.toLowerCase() === 'dt team') { %>
          <!-- Question 1 -->
          <div class="form-row">
            <label>1. Outlet or 3P transfer to the replacement DB? <span class="text-danger">*</span></label>
            <div class="d-flex gap-4">
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="replacement_DB" value="yes">
                <label class="form-check-label">YES</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="replacement_DB" value="no">
                <label class="form-check-label">NO</label>
              </div>
            </div>
          </div>

          <!-- Question 2 -->
          <div class="form-row">
            <label>2. Ivy retailer master Transfer? <span class="text-danger">*</span></label>
            <div class="d-flex gap-4">
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="master_Transfer" value="yes">
                <label class="form-check-label">YES</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="master_Transfer" value="no">
                <label class="form-check-label">NO</label>
              </div>
            </div>
          </div>

          <!-- Question 3 -->
          <div class="form-row">
            <label>3. Ivy retailer stock Transfer? <span class="text-danger">*</span></label>
            <div class="d-flex gap-4">
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="stock_Transfer" value="yes">
                <label class="form-check-label">YES</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="stock_Transfer" value="no">
                <label class="form-check-label">NO</label>
              </div>
            </div>
          </div>
        <% } %>

        <% if (roleName === 'ASM') { %>
          <!-- Question 4 -->
          <div class="form-row">
            <label>1. Asset Reconciliation? <span class="text-danger">*</span></label>
            <div class="d-flex gap-4">
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="Asset_Reconciliation" value="yes">
                <label class="form-check-label">YES</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="Asset_Reconciliation" value="no">
                <label class="form-check-label">NO</label>
              </div>
            </div>
          </div>
        <% } %>

        <% if (roleName === 'SNF') { %>
          <!-- Question 5 -->
          <div class="form-row">
            <label>1. Claim Clearance? <span class="text-danger">*</span></label>
            <div class="d-flex gap-4">
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="Claim_Clearance" value="yes">
                <label class="form-check-label">YES</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input custom-radio required-field" type="radio" name="Claim_Clearance" value="no">
                <label class="form-check-label">NO</label>
              </div>
            </div>
          </div>

          <!-- NOC Upload -->
          <div class="form-row" id="nocUploadField">
            <label for="noc_file">2. NOC Upload? <span class="text-danger">*</span></label>
            <input type="file" name="noc_file" id="noc_file" class="form-control rounded-input w-50 required-field" accept="image/*,application/pdf">
          </div>

          <!-- Question 6 -->
          <div class="form-row">
            <label>3. Pending Amount? <span class="text-danger">*</span></label>
            <input type="text" name="pending_amount" class="form-control rounded-input w-50 required-field">
          </div>
        <% } %>

        <!-- Submit Button -->
        <div class="text-center mt-4">
          <button type="submit" class="submit-btn">Submit</button>
        </div>
      </form>
    </div>
</div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
  <script>
    // Form validation
    document.getElementById('offboardingForm').addEventListener('submit', function(event) {
    event.preventDefault(); 

    let requiredFields = document.querySelectorAll('.required-field');
    let isValid = true;
    const submitBtn = document.querySelector('.submit-btn');

    requiredFields.forEach(field => {
        if ((field.type === 'radio' && !document.querySelector(`input[name="${field.name}"]:checked`)) || 
            (field.type !== 'radio' && field.value.trim() === '')) {
            isValid = false;
            field.classList.add('border-danger');
        } else {
            field.classList.remove('border-danger');
        }
    });

    if (!isValid) {
        Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: 'Please fill in all required fields before submitting!',
        });
        return;
    }

    // Disable the button and change text
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    this.submit(); 
});

  </script>

  <script>
    document.getElementById('noc_file').addEventListener('change', function () {
      const file = this.files[0];
      if (file) {
        const allowedTypes = ['application/pdf', 'image/jpeg', 'image/png', 'image/jpg'];
  
        if (!allowedTypes.includes(file.type)) {
          alert('Only PDF or image files are allowed.');
          this.value = ''; 
        }
      }
    });
  </script>
  


<%- include("../shared/footer.ejs") %>
