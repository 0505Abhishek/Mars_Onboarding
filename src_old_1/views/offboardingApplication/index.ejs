<%- include("../shared/header.ejs") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
    .hidden { display: none; }
</style>

<style>
    .scroll-section {
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      background: #f8f9fa;
    }
</style>

<style>

    .table-dark th {
        color: #0000A0 !important; 
        background-color: #E0E0FC;
        border: 1px solid rgb(224, 203, 203);
    }

    #distributorTable tbody tr:nth-child(odd) td {
        background: #FFFFFF !important; 
    }

    #distributorTable tbody tr:nth-child(even) td {
        background: #EFEFFF !important; 
    }

</style>

<style>
    /* Fullscreen overlay */
.overlay {
position: fixed;
top: 0;
left: 0;
width: 100%;
height: 100%;
background: rgba(0, 0, 0, 0.2);
display: flex;
align-items: center;
justify-content: center;
}

/* Modal box styling */
.modal-box {
background: white;
border: 3px solid #0000A0;
border-radius: 25px;
padding: 30px;
width: 500px;
text-align: center;
box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
}

.toggle-group {
display: flex;
justify-content: center;
gap: 20px;
margin: 10px 0 20px 0;
}

.toggle-group label {
font-weight: bold;
display: flex;
align-items: center;
gap: 5px;
}

input[type="checkbox"] {
width: 40px;
height: 20px;
appearance: none;
background: #ccc;
border-radius: 20px;
position: relative;
outline: none;
cursor: pointer;
transition: background 0.3s;
}

input[type="checkbox"]::before {
content: '';
width: 18px;
height: 18px;
background: white;
border-radius: 50%;
position: absolute;
top: 1px;
left: 1px;
transition: transform 0.3s;
}

input[type="checkbox"]:checked {
background: #14e651;
}

input[type="checkbox"]:checked::before {
transform: translateX(20px);
}

/* Submit Button */
.submit-btn {
background-color: #007bff;
color: white;
padding: 12px 25px;
border: none;
border-radius: 12px;
cursor: pointer;
font-weight: bold;
}

.submit-btn:hover {
background-color: #0056b3;
}

</style>
 
<style>
  .distributor-field {
  margin-top: 20px;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
}

.distributor-field label {
  font-weight: bold;
  margin-bottom: 6px;
  font-size: 14px;
}

.distributor-field input[type="text"] {
  padding: 8px 10px;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 14px;
  outline: none;
  transition: border-color 0.3s ease;
}

.distributor-field input[type="text"]:focus {
  border-color: #007BFF;
  box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
}

</style>


<div class="container mt-4">

    <div class="table-responsive">
        <div class="mb-3 d-flex justify-content-end">
            <div>
              <label for="statusFilter" class="form-label">Filter by Status:</label>
              <select id="statusFilter" class="form-select" onchange="filterTableByStatus()" style="width: auto;">
                <option value="All">All</option>
                <option value="Pending">Pending</option>
                <option value="Submitted">Submitted</option>
              </select>
            </div>
          </div>
        <table id="distributorTable" class="table table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Application Type</th>
                    <th>DB Type</th>
                    <th>Firm's Name</th>
                    <th>Distributor's Name</th>
                    <th>Email ID</th>
                    <th>Mobile Number</th>
                    <th>Start Date</th>
                    <th>Status</th>
                    <th>Created By</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                    <% if (data.length > 0) { %>
                        <% data.forEach((distributor) => { 
                            let status = 'Pending';
                            if (distributor.is_final_approval == 1 && distributor.offboard_flag != 2 && distributor.distributor_flag == 1) {
                                status = 'Submitted';
                            } else if (distributor.is_final_approval == 0 && distributor.offboard_flag != 2 && distributor.distributor_flag == 1 && distributor.can_approve == 1) {
                                status = 'Pending';
                            }
                        %>
                            <tr data-status="<%= status %>">
                            <td><%= distributor.applicationType%></td> 
                            <td><%= distributor.dbType%></td> 
                            <td><%= distributor.firmName %></td>
                            <td><%= distributor.distributorName %></td>
                            <td><%= distributor.email %></td>
                            <td><%= distributor.contactNumber %></td>
                            <td><%= new Date(distributor.offboardCreateDate).toLocaleDateString('en-GB') %></td>
                            <td>
                                <% if (distributor.is_final_approval == 0 && distributor.offboard_flag != 2 && distributor.distributor_flag == 1 && distributor.can_approve == 1) { %>
                                  <span class="badge bg-primary text-white">Pending</span> 
                                <% } else if (distributor.is_final_approval == 1 && distributor.offboard_flag != 2 && distributor.distributor_flag == 1) { %>
                                  <span class="badge bg-success text-white">Submitted</span>
                                  <% } else{ %>
                                    <span class="badge bg-primary text-white">Pending</span> 
                                <% } %>
                            </td>
                            
                            <td><%= distributor.aseemail %></td> 
                            <td>
                            <% if(distributor.is_final_approval == 0 && distributor.offboard_flag != 2 && distributor.can_approve == 1) { %>
                                <a href="/offboardApplication/<%= distributor.applicationId %>">
                                    <button class="btn btn-primary">
                                    <i class="fa fa-eye"></i>
                                </button>
                                </a>
                            <% } %>
                            </td>                              
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="8" class="text-center">No distributors found.</td>
                    </tr>
                <% } %>
            </tbody>  
        </table>
  </div>
</div>


<script>
    function confirmDelete(id) {
    Swal.fire({
        title: "Are you sure?",
        text: "You won't be able to revert this!",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Yes, delete it!"
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = `/edit_distributor/delete_distributor?id=${id}`;
        }
    });
}
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        <% if (notification) { %>
            Swal.fire({
                icon: '<%= notification.type %>', 
                title: '<%= notification.message %>',
                showConfirmButton: false,
                timer: 2000
            });
        <% } %>
    });
</script>

<script>
    $(document).ready(function () {
      const table = $('#distributorTable').DataTable({
        "paging": true,
        "searching": true,
        "ordering": true,
        "info": true,
        "lengthMenu": [5, 10, 25, 50],
        "pageLength": 5
      });
  
      // Status filter dropdown logic
      $('#statusFilter').on('change', function () {
        const status = this.value;
        if (status === "All") {
          table.columns(7).search("").draw(); // Column 7 is 'Status'
        } else {
          table.columns(7).search(status, true, false).draw(); // exact match
        }
      });
    });
</script>
  
