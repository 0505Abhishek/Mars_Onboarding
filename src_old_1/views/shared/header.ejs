    <script>
        function toggleUserInfo() {
            let userInfo = document.getElementById("userInfo");
            userInfo.style.display = (userInfo.style.display === "block") ? "none" : "block";
        }
    
        // Close dropdown when clicking outside
        document.addEventListener("click", function(event) {
            let userContainer = document.querySelector(".user-container");
            let userInfo = document.getElementById("userInfo");
            
            if (!userContainer.contains(event.target)) {
                userInfo.style.display = "none";
            }
        });


        document.addEventListener("DOMContentLoaded", function () {
            const navLinks = document.querySelectorAll(".nav-link");
            const currentPath = window.location.pathname;

            // Set active class based on the current path
            let activeLinkFound = false;

            navLinks.forEach(link => {
                if (link.getAttribute("href") === currentPath) {
                    link.classList.add("active");
                    activeLinkFound = true;
                } else {
                    link.classList.remove("active");
                }
            });

            // Ensure that the active class remains on the correct link if no match found
            if (!activeLinkFound) {
                const activeLink = Array.from(navLinks).find(link => {
                    return link.getAttribute("href").includes(currentPath.split("/")[1]);
                });
                if (activeLink) {
                    activeLink.classList.add("active");
                }
            }
        });

    </script>

    <style>
    .menu-icon {
        font-size: 24px; 
    }

    .logo-src1{
    font-family: Arial, sans-serif;
    font-size: 50px;
    font-weight: bold;
    color: white;
    padding: 10px 20px;
    display: inline-block;
    border-radius: 5px;
    }
    .app-header__content{
    background-color: #0000A0; 
    }
    .app-header__content {
