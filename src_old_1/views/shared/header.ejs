    <style>
    .nav-link {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: white;
        padding: 10px;
        white-space: nowrap;
        transition: 0.3s;
    }

    .nav-link.active {
        background-color: white;
        color: #0000A0 !important;
        border-radius: 5px;
    }

    .icon-container {
        display: flex;
        align-items: center;
    }

    .nav-icon {
        width: 24px;
        height: 24px;
        display: block;
    }

    .active-icon {
        display: none;
    }

    .nav-link.active .default-icon {
        display: none;
    }

    .nav-link.active .active-icon {
        display: block;
    }

    .icon-container .menu-title{
      padding-left:10px;
    }
    
    .nav-link:hover .default-icon {
    display: none;
    }

    .nav-link:hover .active-icon {
        display: block;
    }


    </style>
    
    <style>
        .user-info {
            display: none;
            position: absolute;
            top: 50px;
            right: 10px;
            background: white;
            color: black;
            padding: 10px;
            border-radius: 5px;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
            width: 200px;
            z-index: 9;
        }

        .user-container {
            position: relative;
            text-align: center;
            cursor: pointer;
        }

        .user-name {
            color: white;
            font-size: 14px;
            margin-top: 5px;
        }
    </style> 
   
