<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Distributor Resignation Form</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
      font-family: 'Segoe UI', sans-serif;
    }

    .header {
      background-color: #0000a8;
      color: white;
      padding: 20px 0;
      text-align: center;
      font-size: 2rem;
      font-weight: bold;
      letter-spacing: 2px;
    }

    .form-container {
      background-color: #f6f7fb;
      padding: 30px;
      border-radius: 15px;
      max-width: 700px;
      margin: 40px auto;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .form-heading {
      font-weight: 600;
      text-align: center;
      color: #2b2b8f;
      margin-bottom: 10px;
    }

    .form-subtext {
      text-align: center;
      color: #5a5a89;
      margin-bottom: 30px;
      font-size: 1rem;
    }
    .form-check-input {
      appearance: none; 
      -webkit-appearance: none;
      border: 2px solid #0000a8;
      width: 1.5em;
      height: 1.5em;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s ease-in-out;
      position: relative;
      background-color: #fff;
    }

    .form-check-input:checked {
      background-color: #0000a8;
      border-color: #0000a8;
    }

    .form-check-input:checked::after {
      color: white;
      font-size: 1em;
      position: absolute;
      top: 0;
      left: 3px;
    }

    .form-label {
      font-weight: 500;
    }

  </style>
</head>
<body>

  <div class="header">MARS WRIGLEY</div>

  <div class="form-container">
    <h2 class="form-heading">Distributor Resignation Form</h2>
    <p class="form-subtext">
      We’re sorry to see you go, and thank you for being a valued part of Mars Wrigley.<br>
      Kindly fill in the following details so we can begin processing your resignation smoothly.
    </p>
  
    <form id="resignationForm" method="POST" action="/webPage/<%= token %>">
      
      <input type="hidden" name="token" value="<%= token %>" />

      <!-- Section 1 -->
      <div class="p-4 mb-4 rounded" style="border: 1px solid #ccc; background-color: #f9f9f9;">

        <div class="mb-3">
          <label for="firmName" class="form-label">Firm's Name</label>
          <input type="text" class="form-control" id="firmName" name="firmName" placeholder="Enter your firm name" value="<%= data?.firmName%>" readonly>
        </div>

        <div class="mb-3">
          <label for="distributorName" class="form-label">Distributor's Name</label>
          <input type="text" class="form-control" id="distributorName" name="distributorName" placeholder="Enter your name" value="<%= data?.distributorName%>" readonly>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label">Email ID</label>
          <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" value="<%= data?.email%>" readonly>
        </div>

        <div class="mb-3">
          <label for="contact_no" class="form-label">Contact No.</label>
          <input type="text" class="form-control" id="contact_no" name="contact_no" placeholder="Enter your contact no." value="<%= data?.contactNumber%>" readonly>
        </div>

      </div>

      <!-- Section 2 -->
      <div class="p-4 mb-4 rounded" style="border: 1px solid #ccc; background-color: #f9f9f9;">

        <div class="mb-4">
          <label for="gsvAverage" class="form-label">
            A. Average Business Value in GSV Per Period (L3P Average)
          </label>
          <input type="text" class="form-control" id="gsvAverage" name="gsvAverage" placeholder="Enter average GSV per period" required>
        </div>

        <label class="form-label">
          B. Please select Reason to exit <span class="text-muted">(Multiple can be selected)</span>
        </label>
        
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span>1. Low turnover</span>
          <input class="form-check-input" type="checkbox" value="1" id="reason1" name="low_turnover" >
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span>2. Low ROI%</span>
          <input class="form-check-input" type="checkbox" value="1" id="reason2" name="low_roi" >
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span>3. Limitation in Investment</span>
          <input class="form-check-input" type="checkbox" value="1" id="reason3" name="limitation_in_investment" >
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span>4. DB going out of business</span>
          <input class="form-check-input" type="checkbox" value="1" id="reason4" name="db_going_out_of_business" >
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span>5. Increasing Cost</span>
          <input class="form-check-input" type="checkbox" value="1" id="reason5" name="increasing_cost" >
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span>6. Not ready for additional infrastructure needed (warehouse/delivery vehicle, etc)</span>
          <input class="form-check-input" type="checkbox" value="1" id="reason6" name="not_ready_for_additional_infrastructure" >
        </div>
                

      <!-- Submit Button -->
      <div class="d-flex justify-content-center">
        <button type="submit" class="btn btn-primary" style="width: 150px;">Submit</button>
      </div>

    </form>
  </div>
  

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
 
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const fieldLimits = {
        gsvAverage: 10,
      };
  
      const inputFields = document.querySelectorAll("input");
  
      inputFields.forEach((input) => {
        input.addEventListener("input", function () {
          const fieldId = input.id;
          const fieldValue = input.value;
  
          if (fieldLimits[fieldId] && fieldValue.length > fieldLimits[fieldId]) {
            input.value = fieldValue.slice(0, fieldLimits[fieldId]);
  
            Swal.fire({
              icon: "warning",
              title: "Input Limit Exceeded",
              text: `The maximum length for '${input.labels?.[0]?.textContent || fieldId}' is ${fieldLimits[fieldId]} characters.`,
              position: "top-end",
              toast: true,
              showConfirmButton: false,
              timer: 3000,
            });
          }
        });
      });
  
    });
  </script>
  
  <script>
    document.getElementById("resignationForm").addEventListener("submit", function (e) {
      const checkboxes = document.querySelectorAll(
        'input[name="low_turnover"], input[name="low_roi"], input[name="limitation_in_investment"], input[name="db_going_out_of_business"], input[name="increasing_cost"], input[name="not_ready_for_additional_infrastructure"]'
      );
  
      const atLeastOneChecked = Array.from(checkboxes).some(checkbox => checkbox.checked);
  
      if (!atLeastOneChecked) {
        e.preventDefault();
  
        Swal.fire({
          icon: 'warning',
          title: 'Oops!',
          text: 'Please select at least one reason for exit before submitting.',
          confirmButtonColor: '#3085d6',
        });
      } else {
        // Disable the submit button after valid submission
        const submitBtn = document.querySelector("#resignationForm button[type='submit']");
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerText = "Submitting..."; // Optional: change text
        }
      }
    });
  </script>
  
  
  

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
